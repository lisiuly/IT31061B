  2135 00000532 60                  		RTS
  2136                              
  2137                              ; 输入: 无。
  2138                              ; 输出: 清当前帧缓存和 CaptureActive，准备重新从停止位开始抓数。
  2139                              ; 调试: 看 R_RFBitCnt 是否回 0，R_RFCaptureActive 是否清零。
  2140 00000533                     F_RF_ResetPacketBuffer:			; 清当前 36bit 收包缓存，不动双帧 pending 缓存
  2141 00000533 A9 00               		LDA		#00H
  2142 00000535 85 00               		STA		R_RFBitCnt
  2143 00000537 85 0D               		STA		R_RFParsePending
  2144 00000539 85 0E               		STA		R_RFCaptureActive
