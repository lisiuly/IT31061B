   703                      <       %F_Initinal_IO	.MACRO
   704                      <       		LDA		#00000000b		
   705                      <       		STA		P_IO_PortA_Dir
   706                      <       		LDA		#00000000b		
   707                      <       		STA		P_IO_PortA_Data	
   708                      <       		
   709                      <       		LDA		#0
   710                      <       		STA		P_IO_PortB_Attrib
   711                      <       		LDA		#00000011b		
   712                      <       		STA		P_IO_PortB_Dir
   713                      <       		LDA		#00000000b		
   714                      <       		STA		P_IO_PortB_Data		;PB1蜂鸣器，PB0背光
   715                      <       
