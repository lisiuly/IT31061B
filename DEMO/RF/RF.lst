  2256 000005F2 60                  		RTS
  2257                              
  2258 000005F3                     RF_Service2KHzSample_LowEnd:
  2259 000005F3 A9 02               		LDA		#D_Bit1
  2260 000005F5 8D 19 00            		STA		R_RFSamplePrev
  2261 000005F8 AD 1A 00            		LDA		R_RFLowSampleCnt
  2262 000005FB F0 F5               		BEQ		RF_Service2KHzSample_End
