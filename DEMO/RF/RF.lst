  2115 00000514 29 08               		AND		#D_RFNeedPair
  2116 00000516 D0 19               		BNE		RF_RequestChannelPacketAccept
  2117 00000518 A5 01               		LDA		R_RFPacket0
  2118 0000051A CD 18 00            		CMP		R_RF2IdL
  2119 0000051D F0 12               		BEQ		RF_RequestChannelPacketAccept
  2120 0000051F 18                  		CLC
  2121 00000520 60                  		RTS
  2122                              
  2123 00000521                     RF_IsChannel3PacketAccepted:
  2124 00000521 AD 20 00            		LDA		R_RF3Flags
  2125 00000524 29 08               		AND		#D_RFNeedPair
  2126 00000526 D0 09               		BNE		RF_RequestChannelPacketAccept
  2127 00000528 A5 01               		LDA		R_RFPacket0
  2128 0000052A CD 22 00            		CMP		R_RF3IdL
  2129 0000052D F0 02               		BEQ		RF_RequestChannelPacketAccept
  2130 0000052F 18                  		CLC
