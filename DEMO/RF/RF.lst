  2104                              		; NeedPair 说明 CH1 还没绑定过 ID，当前包直接允许写入。
  2105 00000506 D0 29               		BNE		RF_RequestChannelPacketAccept
  2106 00000508 A5 01               		LDA		R_RFPacket0
  2107 0000050A CD 0E 00            		CMP		R_RF1IdL
  2108                              		; 已配对后只有 ID 一致才允许恢复/更新该通道。
  2109 0000050D F0 22               		BEQ		RF_RequestChannelPacketAccept
  2110 0000050F 18                  		CLC
  2111 00000510 60                  		RTS
  2112                              
  2113 00000511                     RF_IsChannel2PacketAccepted:
