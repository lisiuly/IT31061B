   731                      <       		STA		P_IO_PortE_Dir
   732                      <       		LDA		#00000000b			
   733                      <       		STA		P_IO_PortE_Data		
   734                      <       		
   735                      <       		LDA		#00
   736                      <       		STA		P_IO_Ctrl			;all as normal IO
   737                      <       		.ENDM
