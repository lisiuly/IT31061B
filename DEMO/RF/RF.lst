  1926 00000411                     RF_SelectedChannelEnter60MinLongRecv:
  1927                              		; 第一次累计到 60 分钟，先拉起一次 3 分钟长接收尝试找回信号。
  1928 00000411 A9 01               		LDA		#01H
  1929 00000413 9D 25 00            		STA		R_RF1RetryStage,X
  1930 00000416 A9 FF               		LDA		#C_RFSyncIdle
