   388                      <       ;Macro Name: %M_ClearWatchDog
   389                      <       ;Purpose: Clear Watchdog
   390                      <       ;Destroy: A
   391                      <       ;;============================================================================
   392                      <       %M_ClearWatchDog:		.MACRO 
   393                      <       	LDA		#D_WDT_Clear
   394                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   395                      <       	.ENDM
   396                      <       ;;============================================================================
   397                      <       ;Macro Name: %M_DisAllInt
   398                      <       ;Purpose: Disable all interrupt 
   399                      <       ;Destroy: A
   400                      <       ;;============================================================================
   401                      <       %F_InitINT:		.MACRO
   402                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   403                      <       		STA		P_TIMER_TimeBase_Sel		
   404                      <       		LDA		#D_2KHzInt+D_128HzInt+D_TMBAInt+D_TMBBInt;+D_Timer0Int
   405                      <       		STA		P_INT_Ctrl
   406                      <       		LDA		#00
   407                      <       		STA		P_INT_Ctrl2		;disable TMR1 INT
   408                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   409                      <       ;		STA		P_TIMER_Timer0_Ctrl
   410                      <       ;		LDA		#0xC8
   411                      <       ;		LDA		#0xFC
   412                      <       ;		STA		P_TIMER_TM0Data_LB		;8k
   413                      <       ;		LDA		#0xFF
   414                      <       ;		STA		P_TIMER_TM0Data_HB
   415                      <       	.ENDM
   416                      <       ;;============================================================================
   417                      <       ;Macro Name: %DisableLCD
   418                      <       ;Purpose: Disable LCD
   419                      <       ;Destroy: A
   420                      <       ;;============================================================================
   421                      <       %DisableLCD:		.MACRO
   422                      <       	
   423                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   424                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   425                      <       		
   426                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
   427                      <       		STA     P_LCD_VLCD_Ctrl
   428                      <       	.ENDM
