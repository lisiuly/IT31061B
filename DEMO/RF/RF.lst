  1938                              ; 这三个函数只是给通用分钟状态机装不同的 X/Y 偏移。
  1939                              ; 调试: 看 X/Y 是否落在 0/0、0Ah/01h、14h/02h。
  1940 00000425                     F_RF_ServiceChannel1Minute:		; 按分钟累计 CH1 掉码时长并触发 60/120/180 分钟策略
  1941 00000425 A2 00               		LDX		#00H
  1942 00000427 A0 00               		LDY		#00H
  1943 00000429 4C 3A 04            		JMP		F_RF_ServiceSelectedChannelMinute
  1944                              
  1945 0000042C                     F_RF_ServiceChannel2Minute:		; 按分钟累计 CH2 掉码时长并触发 60/120/180 分钟策略
  1946 0000042C A2 0A               		LDX		#0AH
  1947 0000042E A0 01               		LDY		#01H
  1948 00000430 4C 3A 04            		JMP		F_RF_ServiceSelectedChannelMinute
  1949                              
  1950 00000433                     F_RF_ServiceChannel3Minute:		; 按分钟累计 CH3 掉码时长并触发 60/120/小时重试策略
  1951 00000433 A2 14               		LDX		#14H
  1952 00000435 A0 02               		LDY		#02H
  1953                              		; 60 分钟先触发一次 3 分钟长接收；120 分钟后改成每小时 1 次，总共 3 次。
  1954 00000437 4C 3A 04            		JMP		F_RF_ServiceSelectedChannelMinute
  1955                              
  1956                              ; 输入: X=通道数据偏移，Y=同步计时偏移。
  1957                              ; 输出: LostCnt 非 0 时按分钟累计 MissMin，并在 60/120 分钟点切换到 3 分钟长接收/小时重试。
  1958                              ; 调试: 重点看 MissMin、RetryStage、RetryTm、对应 SyncTm。
  1959 0000043A                     F_RF_ServiceSelectedChannelMinute:	; X=通道记录偏移(0/10/20), Y=同步计时偏移(0/1/2)
  1960 0000043A BD 12 00            		LDA		R_RF1LostCnt,X
  1961                              		; LostCnt 为 0 说明这一路没有掉码，不需要累计分钟数。
  1962 0000043D F0 1C               		BEQ		RF_ServiceSelectedChannelMinute_End
  1963 0000043F BD 14 00            		LDA		R_RF1RetryStage,X
  1964 00000442 C9 05               		CMP		#C_RFFinalRetryStage
  1965 00000444 B0 15               		BCS		RF_ServiceSelectedChannelMinute_End
  1966                              		; RetryStage=2~4 表示 120 分钟后的小时重试窗口。
  1967 00000446 C9 02               		CMP		#C_RFHourlyRetryStageFirst
  1968 00000448 B0 31               		BCS		RF_ServiceSelectedChannelRetryHourly
  1969 0000044A BD 13 00            		LDA		R_RF1MissMin,X
  1970 0000044D 18                  		CLC
  1971 0000044E 69 01               		ADC		#01H
  1972 00000450 9D 13 00            		STA		R_RF1MissMin,X
  1973 00000453 C9 3C               		CMP		#C_RFFail60Min
  1974 00000455 F0 05               		BEQ		RF_SelectedChannelEnter60MinLongRecv
  1975 00000457 C9 78               		CMP		#C_RFFail120Min
  1976 00000459 F0 0E               		BEQ		RF_SelectedChannelEnter120MinLongRecv
  1977 0000045B                     RF_ServiceSelectedChannelMinute_End:
  1978 0000045B 60                  		RTS
  1979                              
  1980 0000045C                     RF_SelectedChannelEnter60MinLongRecv:
  1981                              		; 第一次累计到 60 分钟，先拉起一次 3 分钟长接收尝试找回信号。
  1982 0000045C A9 01               		LDA		#01H
  1983 0000045E 9D 14 00            		STA		R_RF1RetryStage,X
  1984 00000461 A9 FF               		LDA		#C_RFSyncIdle
  1985 00000463 99 07 00            		STA		R_RF1SyncTm,Y
