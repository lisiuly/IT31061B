  1242                              ;==========================================
  1243                              ; code starting 
  1244                              ;==========================================
  1245 00000000                     .CODE
  1246                              
  1247                              ; 输入: 无。
  1248                              ; 输出: 清所有 RF 运行态，三路通道都回到 NeedPair，默认当前显示 CH1。
  1249                              ; 调试: 上电后先看 R_RFStatus、R_RFChannel、R_RFViewChannel、R_RF1Flags~R_RF3Flags。
  1250 00000000                     F_RF_Init:					; RF模块初始化
  1251 00000000 A9 00               		LDA		#00H
  1252 00000002 8D 00 00            		STA		R_RFStatus
  1253 00000005 8D 03 00            		STA		R_RFRequestChannel
  1254 00000008 8D 04 00            		STA		R_RFLongRecvTm
  1255 0000000B 8D 05 00            		STA		R_RFAutoSwitchTm
  1256 0000000E 8D 06 00            		STA		R_RFRecvWindowTm
  1257 00000011 8D 0A 00            		STA		R_RFBitCnt
  1258 00000014 8D 11 00            		STA		R_RFPendingValid
  1259 00000017 8D 17 00            		STA		R_RFCaptureActive
  1260 0000001A 8D 19 00            		STA		R_RFSamplePrev
  1261 0000001D 8D 1A 00            		STA		R_RFLowSampleCnt
  1262 00000020 8D 1B 00            		STA		R_RFHalfSecDiv
  1263 00000023 8D 24 00            		STA		R_RF1MissMin
  1264 00000026 8D 25 00            		STA		R_RF1RetryStage
  1265 00000029 8D 26 00            		STA		R_RF1RetryTm
  1266 0000002C 8D 2E 00            		STA		R_RF2MissMin
  1267 0000002F 8D 2F 00            		STA		R_RF2RetryStage
  1268 00000032 8D 30 00            		STA		R_RF2RetryTm
