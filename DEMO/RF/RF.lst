  2221 000005BA A5 13               		LDA		P_IO_PortD_Data
  2222 000005BC 29 02               		AND		#D_Bit1
  2223 000005BE 8D 19 00            		STA		R_RFSamplePrev
  2224 000005C1 A9 00               		LDA		#00H
  2225 000005C3 8D 1A 00            		STA		R_RFLowSampleCnt
