  1913 000003FB C9 02               		CMP		#02H
  1914 000003FD F0 31               		BEQ		RF_ServiceSelectedChannelRetry180
  1915 000003FF BD 24 00            		LDA		R_RF1MissMin,X
  1916 00000402 18                  		CLC
  1917 00000403 69 01               		ADC		#01H
  1918 00000405 9D 24 00            		STA		R_RF1MissMin,X
