  2227                              
  2228 000005C7                     RF_Service2KHzSample_Active:
  2229 000005C7 A5 13               		LDA		P_IO_PortD_Data
  2230 000005C9 29 02               		AND		#D_Bit1
  2231                              		; PD1 为高时，如果上一拍也是高，就什么都不做；如果上一拍是低，就表示一段低脉冲结束了。
  2232 000005CB F0 0B               		BEQ		RF_Service2KHzSample_Low
  2233 000005CD AD 19 00            		LDA		R_RFSamplePrev
  2234 000005D0 F0 21               		BEQ		RF_Service2KHzSample_LowEnd
  2235 000005D2 A9 02               		LDA		#D_Bit1
  2236 000005D4 8D 19 00            		STA		R_RFSamplePrev
  2237 000005D7 60                  		RTS
  2238                              
  2239 000005D8                     RF_Service2KHzSample_Low:
  2240 000005D8 AD 19 00            		LDA		R_RFSamplePrev
  2241 000005DB F0 0B               		BEQ		RF_Service2KHzSample_LowHold
  2242                              		; 刚从高跳低，开始统计这段低电平持续了多少个 2kHz 样本。
  2243 000005DD A9 00               		LDA		#00H
  2244 000005DF 8D 19 00            		STA		R_RFSamplePrev
  2245 000005E2 A9 01               		LDA		#01H
  2246 000005E4 8D 1A 00            		STA		R_RFLowSampleCnt
