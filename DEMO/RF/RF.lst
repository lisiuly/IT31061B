  2026                              ; 输入: 无。
  2027                              ; 输出: 仅清掉 pending 有效标志，让下一帧重新成为“第一帧”。
  2028                              ; 调试: 盯 R_RFPendingValid。
  2029 000004AA                     F_RF_ClearPendingFrame:			; 清空双帧确认缓存状态
  2030 000004AA A9 00               		LDA		#00H
  2031 000004AC 85 07               		STA		R_RFPendingValid
  2032 000004AE 60                  		RTS
  2033                              
  2034                              ; 输入: 当前帧 R_RFPacket0~4。
  2035                              ; 输出: 把当前帧拷到 pending 缓存，供下一帧做完全一致比较。
  2036                              ; 调试: 盯 R_RFPending0~4。
  2037 000004AF                     F_RF_SavePendingFrame:			; 保存当前帧，供下一帧做完全一致比对
  2038 000004AF A5 01               		LDA		R_RFPacket0
  2039 000004B1 85 08               		STA		R_RFPending0
  2040 000004B3 A5 02               		LDA		R_RFPacket1
  2041 000004B5 85 09               		STA		R_RFPending1
  2042 000004B7 A5 03               		LDA		R_RFPacket2
  2043 000004B9 85 0A               		STA		R_RFPending2
  2044 000004BB A5 04               		LDA		R_RFPacket3
  2045 000004BD 85 0B               		STA		R_RFPending3
  2046 000004BF A5 05               		LDA		R_RFPacket4
  2047 000004C1 85 0C               		STA		R_RFPending4
  2048 000004C3 A9 01               		LDA		#01H
  2049 000004C5 85 07               		STA		R_RFPendingValid
  2050 000004C7 60                  		RTS
  2051                              
  2052                              ; 输入: 当前帧和 pending 帧。
  2053                              ; 输出: SEC=两帧完全一致，CLC=不一致或这是第一帧。
  2054                              ; 调试: 重点对比 R_RFPacket0~4 和 R_RFPending0~4。
  2055 000004C8                     F_RF_IsCurrentFrameConfirmed:		; 判断当前帧是否和上一帧完全一致
  2056                              		; 发射端会连续重复发同一帧，接收端必须连续两帧完全一致才允许后续落库。
  2057 000004C8 A5 07               		LDA		R_RFPendingValid
  2058                              		; 还没有 pending 时，当前帧只保存，不算确认成功。
  2059 000004CA D0 05               		BNE		RF_CheckPendingFrame
  2060 000004CC 20 AF 04            		JSR		F_RF_SavePendingFrame
  2061 000004CF 18                  		CLC
  2062 000004D0 60                  		RTS
  2063                              
  2064 000004D1                     RF_CheckPendingFrame:
  2065                              		; 五个 Packet 字节必须全等，任何一字节不同都把当前帧改写成新的 pending。
  2066 000004D1 A5 01               		LDA		R_RFPacket0
  2067 000004D3 C5 08               		CMP		R_RFPending0
  2068 000004D5 D0 1A               		BNE		RF_SaveCurrentAsPending
  2069 000004D7 A5 02               		LDA		R_RFPacket1
  2070 000004D9 C5 09               		CMP		R_RFPending1
  2071 000004DB D0 14               		BNE		RF_SaveCurrentAsPending
  2072 000004DD A5 03               		LDA		R_RFPacket2
  2073 000004DF C5 0A               		CMP		R_RFPending2
  2074 000004E1 D0 0E               		BNE		RF_SaveCurrentAsPending
  2075 000004E3 A5 04               		LDA		R_RFPacket3
  2076 000004E5 C5 0B               		CMP		R_RFPending3
  2077 000004E7 D0 08               		BNE		RF_SaveCurrentAsPending
  2078 000004E9 A5 05               		LDA		R_RFPacket4
  2079 000004EB C5 0C               		CMP		R_RFPending4
  2080 000004ED D0 02               		BNE		RF_SaveCurrentAsPending
  2081 000004EF 38                  		SEC
  2082 000004F0 60                  		RTS
  2083                              
  2084 000004F1                     RF_SaveCurrentAsPending:
  2085                              		; 连续帧不一致，说明当前帧不能用，但它可能是新一轮重复帧的第一帧。
  2086 000004F1 20 AF 04            		JSR		F_RF_SavePendingFrame
  2087 000004F4 18                  		CLC
  2088 000004F5 60                  		RTS
  2089                              
  2090                              ; 输入: R_RFRequestChannel 和当前帧里的 Packet0(ID)。
  2091                              ; 输出: SEC=允许写入该通道，CLC=拒绝；已配对通道只接受相同 ID。
  2092                              ; 调试: 看 R_RFRequestChannel、对应通道 Flags 的 NeedPair 位、对应通道 IdL。
  2093 000004F6                     F_RF_IsRequestChannelPacketAccepted:	; 判断当前包是否允许写入请求通道
  2094                              		; 只有 NeedPair 通道允许接收新 ID；已配对通道必须同 ID 才能恢复或更新。
  2095 000004F6 AD 03 00            		LDA		R_RFRequestChannel
  2096 000004F9 C9 02               		CMP		#D_RFCh2
  2097 000004FB F0 14               		BEQ		RF_IsChannel2PacketAccepted
  2098 000004FD C9 03               		CMP		#D_RFCh3
  2099 000004FF F0 20               		BEQ		RF_IsChannel3PacketAccepted
