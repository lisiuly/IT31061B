   531                      <       ;----------------------------------------------------------
   532                      <       ;/***********************************************/
   533                      <       ;         i.L=1 
   534                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   535                      <                 lda     i               ;ex.  
   536                      <                 ora     #L              ;  %bits 10H,_BIT0
   537                      <       		                   ;  10H.0=1
   538                      <                 sta     i               ;
   539                      <                .ENDM    
   540                      <       
   541                      <       ;/***********************************************/
   542                      <       ;         i.L=0
   543                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   544                      <                 lda     i               ;ex.  
   545                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   546                      <                 sta     i
   547                      <                .ENDM    
   548                      <       
   549                      <       ;/***********************************************/
   550                      <       ;         if(i.L==1) goto N
   551                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   552                      <                 lda     i               ;ex.   
   553                      <                 and     #L              ;  %btst 10H,_BIT0,N
   554                      <                 bne     N               ;  if(10H.0=1) goto N 
   555                      <                .ENDM    
   556                      <                                         
   557                      <       ;/***********************************************/
   558                      <       ;         if(i.L==0) goto N
   559                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   560                      <                 lda     i               ;ex.   
   561                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   562                      <                 beq     N               ;  if(10H.0=0) goto N 
   563                      <                .ENDM    
   564                      <       ;/***********************************************/
   565                      <       ;         if(i==#0) goto N
   566                      <       %jz:     .MACRO   i,N             ;BYTE i;
   567                      <                 lda     i               ;ex.
   568                      <                 beq     N               ;  %jz 10H,N
   569                      <                .ENDM                    ;  if(10H==#0) goto N
   570                      <       
   571                      <       ;/***********************************************/
   572                      <       ;         if(i!=#0) goto N
   573                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   574                      <                 lda     i               ;ex.
   575                      <                 bne     N               ;  %jnz 10H,N
   576                      <                .ENDM                    ;  if($10!=#0) goto N
