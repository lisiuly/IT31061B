  1249                              ;==========================================
  1250                              ; code starting 
  1251                              ;==========================================
  1252 00000000                     .CODE
  1253                              
  1254                              ; 输入: 无。
  1255                              ; 输出: 清所有 RF 运行态，三路通道都回到 NeedPair，默认当前显示 CH1。
  1256                              ; 调试: 上电后先看 R_RFStatus、R_RFChannel、R_RFViewChannel、R_RF1Flags~R_RF3Flags。
  1257 00000000                     F_RF_Init:					; RF模块初始化
  1258 00000000 A9 00               		LDA		#00H
  1259 00000002 8D 00 00            		STA		R_RFStatus
  1260 00000005 8D 03 00            		STA		R_RFRequestChannel
  1261 00000008 8D 04 00            		STA		R_RFLongRecvTm
  1262 0000000B 8D 05 00            		STA		R_RFAutoSwitchTm
  1263 0000000E 8D 06 00            		STA		R_RFRecvWindowTm
  1264 00000011 85 00               		STA		R_RFBitCnt
  1265 00000013 85 07               		STA		R_RFPendingValid
  1266 00000015 85 0D               		STA		R_RFParsePending
  1267 00000017 85 0E               		STA		R_RFCaptureActive
  1268 00000019 85 10               		STA		R_RFSamplePrev
  1269 0000001B 85 11               		STA		R_RFHighSampleCnt
  1270 0000001D 85 12               		STA		R_RFLowSampleCnt
