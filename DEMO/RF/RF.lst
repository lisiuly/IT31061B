  1920 0000040A F0 05               		BEQ		RF_SelectedChannelEnter60MinLongRecv
  1921 0000040C C9 78               		CMP		#C_RFFail120Min
  1922 0000040E F0 0E               		BEQ		RF_SelectedChannelEnter120MinLongRecv
  1923 00000410                     RF_ServiceSelectedChannelMinute_End:
  1924 00000410 60                  		RTS
