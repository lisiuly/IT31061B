   235                      <       ;**********************************************************************
   236                      <       ;ROM Checksum
   237                      <       ;**********************************************************************
   238                      <       ;.IF (GPL813P01Ax+GPL813P01Bx+GPL813P01Cx)
   239                      <       ;	D_BankNum:						.EQU	1	
   240                      <       ;.ENDIF
   241                      <       
   242                      <       	D_Bank0UserRomStartAddr:		.EQU	0xE000		;0x4800 ~ 0x7FDF:User ROM Code
   243                      <       	D_Bank0UserRomEndAddr:			.EQU	0xFFDF
   244                      <       	D_NMIandResetVectorStartAddr:	.EQU	0xFFFC		;0xFFF8 ~ 0xFFF9:User ROM Code, 0xFFFA ~ 0xFFFF:NMI & Reset & IRQ vector
   245                      <       	D_NMIandResetVectorEndAddr:		.EQU	0xFFFF
   246                      <       
   247                      <       ; ========================================================================================
   248                      <       ; Macro Name	: M_UserRomChecksum
   249                      <       ; Parameters	: None
   250                      <       ; Return Value	: R_ChecksumResult: bit[7:0]
   251                      <       ;				: R_ChecksumResult + 1: bit[15:8]
   252                      <       ;				: R_ChecksumResult + 2: bit[23:16]
   253                      <       ;				: R_ChecksumResult + 3: bit[31:24]
   254                      <       ; Description	: Calculate user ROM area code checksum
   255                      <       ; Destroy		: A, Y
   256                      <       ; Example		: %M_UserRomChecksum	R_ChecksumAddrPtr, R_ChecksumResult
   257                      <       ; ========================================================================================	
   258                      <       %M_UserRomChecksum:	.MACRO	R_ChecksumAddrPtr, R_ChecksumResult
   259                      <       	
   260                      <       	LDA		#0
   261                      <       	STA		R_ChecksumResult						;Result Byte0
   262                      <       	STA		R_ChecksumResult + 1				;Result Byte1
   263                      <       	STA		R_ChecksumResult + 2				;Result Byte2
   264                      <       	STA		R_ChecksumResult + 3				;Result Byte3
   265                      <       ;=================== Bank 0 ==================================================	
   266                      <       	LDA		#.HIGH.D_Bank0UserRomStartAddr
   267                      <       	STA		R_ChecksumAddrPtr + 1				;Start High Byte
   268                      <       	LDA		#.LOW.D_Bank0UserRomStartAddr
   269                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   270                      <       		
   271                      <       	LDY		#0	
   272                      <       
   273                      <       L_ChecksumLoop1?
   274                      <       	STA		P_WDT_Flag_Clear	
   275                      <       	CLC
   276                      <       	LDA		(R_ChecksumAddrPtr),Y
   277                      <       	ADC		R_ChecksumResult						;Result Low Byte
   278                      <       	STA		R_ChecksumResult						;Result Low Byte
   279                      <       	BCC		L_CheckAddress1?
   280                      <       	INC		R_ChecksumResult + 1				;Result Byte1
   281                      <       	BNE		L_CheckAddress1?
   282                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   283                      <       	BNE		L_CheckAddress1?
   284                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   285                      <       		
   286                      <       L_CheckAddress1?:
   287                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   288                      <       	CMP		#.HIGH.D_Bank0UserRomEndAddr		;End High Byte
   289                      <       	BNE		L_IncreaseAdd1?
   290                      <       	
   291                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   292                      <       	CMP		#.LOW.D_Bank0UserRomEndAddr			;End Low Byte
   293                      <       	BEQ		L_ExitRomSum1?
   294                      <       	
   295                      <       L_IncreaseAdd1?:
   296                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   297                      <       	BNE		L_ChecksumLoop1?
   298                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   299                      <       	JMP		L_ChecksumLoop1?	
   300                      <       		
   301                      <       L_ExitRomSum1?:	
   302                      <       
   303                      <       ;===================NMI & Reset Vector==================================================		
   304                      <       	LDA		#.HIGH.D_NMIandResetVectorStartAddr
   305                      <       	STA		R_ChecksumAddrPtr + 1				; Start High Byte
   306                      <       	LDA		#.LOW.D_NMIandResetVectorStartAddr
   307                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   308                      <       		
   309                      <       L_ChecksumLoop2?
   310                      <       	STA		P_WDT_Flag_Clear		
   311                      <       	CLC
   312                      <       	LDA		(R_ChecksumAddrPtr),Y
   313                      <       	ADC		R_ChecksumResult						;Result Low Byte
   314                      <       	STA		R_ChecksumResult						;Result Low Byte
   315                      <       	BCC		L_CheckAddress2?
   316                      <       	INC		R_ChecksumResult + 1				;Result Byte2
   317                      <       	BNE		L_CheckAddress2?
   318                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   319                      <       	BNE		L_CheckAddress2?
   320                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   321                      <       		
   322                      <       L_CheckAddress2?:
   323                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   324                      <       	CMP		#.HIGH.D_NMIandResetVectorEndAddr	;End High Byte
   325                      <       	BNE		L_IncreaseAdd2?
   326                      <       	
   327                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   328                      <       	CMP		#.LOW.D_NMIandResetVectorEndAddr	;End Low Byte
   329                      <       	BEQ		L_ExitRomSum2?
   330                      <       	
   331                      <       L_IncreaseAdd2?:
   332                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   333                      <       	BNE		L_ChecksumLoop2?
   334                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   335                      <       	JMP		L_ChecksumLoop2?	
   336                      <       		
   337                      <       L_ExitRomSum2?:	
   338                      <       ;;=====================Bank area================================================		
   339                      <       	
   340                      <       	.ENDM
   341                      <       ;================================================================================
   342                      <       
   343                      <       			.ENDIF
   344                      <       .ENDIF
   345                      <       	.ENDIF
