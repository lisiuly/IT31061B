   718                      <       		LDA		#00000000b
   719                      <       		STA		P_IO_PortC_Data		; PC7 debug output, default low.
   720                      <       		
   721                      <       		LDA		#00h
   722                      <       		STA		P_IO_PortD_Attrib		
   723                      <       		LDA		#00000001b		
   724                      <       		STA		P_IO_PortD_Dir
   725                      <       		STA		P_IOD_DIR_Map	
   726                      <       		LDA		#00000010b
   727                      <       		STA		P_IO_PortD_Data		
   728                      <       		STA		R_PortD_Data_Buf
   729                      <       
