   541                      <       ;----------------------------------------------------------
   542                      <       ;/***********************************************/
   543                      <       ;         i.L=1 
   544                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   545                      <                 lda     i               ;ex.  
   546                      <                 ora     #L              ;  %bits 10H,_BIT0
   547                      <       		                   ;  10H.0=1
   548                      <                 sta     i               ;
   549                      <                .ENDM    
   550                      <       
   551                      <       ;/***********************************************/
   552                      <       ;         i.L=0
   553                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   554                      <                 lda     i               ;ex.  
   555                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   556                      <                 sta     i
   557                      <                .ENDM    
   558                      <       
   559                      <       ;/***********************************************/
   560                      <       ;         if(i.L==1) goto N
   561                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   562                      <                 lda     i               ;ex.   
   563                      <                 and     #L              ;  %btst 10H,_BIT0,N
   564                      <                 bne     N               ;  if(10H.0=1) goto N 
   565                      <                .ENDM    
   566                      <                                         
   567                      <       ;/***********************************************/
   568                      <       ;         if(i.L==0) goto N
   569                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   570                      <                 lda     i               ;ex.   
   571                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   572                      <                 beq     N               ;  if(10H.0=0) goto N 
   573                      <                .ENDM    
   574                      <       ;/***********************************************/
   575                      <       ;         if(i==#0) goto N
   576                      <       %jz:     .MACRO   i,N             ;BYTE i;
   577                      <                 lda     i               ;ex.
   578                      <                 beq     N               ;  %jz 10H,N
   579                      <                .ENDM                    ;  if(10H==#0) goto N
   580                      <       
   581                      <       ;/***********************************************/
   582                      <       ;         if(i!=#0) goto N
   583                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   584                      <                 lda     i               ;ex.
   585                      <                 bne     N               ;  %jnz 10H,N
   586                      <                .ENDM                    ;  if($10!=#0) goto N
