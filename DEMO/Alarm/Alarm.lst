   407                      <       ;Macro Name: %M_DisAllInt
   408                      <       ;Purpose: Disable all interrupt 
   409                      <       ;Destroy: A
   410                      <       ;;============================================================================
   411                      <       %F_InitINT:		.MACRO
   412                      <       		LDA		#00000111b		;2HZ Ł¨bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   413                      <       		STA		P_TIMER_TimeBase_Sel		
   414                      <       		LDA		#D_2KHzInt+D_128HzInt+D_TMBAInt+D_TMBBInt;+D_Timer0Int
   415                      <       		STA		P_INT_Ctrl
   416                      <       		LDA		#00
   417                      <       		STA		P_INT_Ctrl2		;disable TMR1 INT
   418                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   419                      <       ;		STA		P_TIMER_Timer0_Ctrl
   420                      <       ;		LDA		#0xC8
   421                      <       ;		LDA		#0xFC
   422                      <       ;		STA		P_TIMER_TM0Data_LB		;8k
   423                      <       ;		LDA		#0xFF
   424                      <       ;		STA		P_TIMER_TM0Data_HB
   425                      <       	.ENDM
