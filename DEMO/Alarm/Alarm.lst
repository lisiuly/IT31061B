   887                      <       LCDConvert		.MACRO  com,seg
   888                      <       ;			DB	com*8+(seg/8)+00H,1<<(seg.AND.07H)
   889                      <       ;			DB	(com*8+07H)-(seg/8),1<<(seg.AND.07H)	;LB25B
   890                      <       ;			DB	com*4+(seg/8)+50H,1<<(seg.AND.07H)	;L11A\B
   891                      <       ;			DB	com*6+(seg/8)+20H,1<<(seg.AND.07H)	;L31B
   892                      <       ;LCDConvert:		.Macro	com,seg
   893                      <       ;			DB	com*4+(seg/8)+A0H,1<<(seg.AND.07H)	;GPL10A
   894                      <       			DB	com*10H+(seg/8)+00H,1<<(seg.AND.07H)	;GPL813P01;
   895                      <       			
   896                      <       			.ENDM
