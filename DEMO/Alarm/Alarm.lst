   632                      <       ; Macro Name:	%FillSram
   633                      <       ; Description:	Fill data to SRAM whole space
   634                      <       ; Input:		mData
   635                      <       ;-----------------------------------------------------------------------------	
   636                      <       %FillSram		.MACRO	mData
   637                      <       		
   638                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   639                      <       		STA		C_SramAddrStart
   640                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   641                      <       		STA		C_SramAddrStart+1
   642                      <       		
   643                      <       		LDX     #0
   644                      <       ?L_FillLoop#:
   645                      <               LDA     mData
   646                      <       		STA     (C_SramAddrStart,X)
   647                      <       		
   648                      <       		LDA     C_SramAddrStart+1
   649                      <       		CMP     #.HIGH.C_SramAddrEnd
   650                      <       		BCC     ?L_IncSramAddr#
   651                      <       		LDA     C_SramAddrStart
   652                      <       		CMP     #.LOW.C_SramAddrEnd
   653                      <       		BCS     ?L_End#
   654                      <       		
   655                      <       ?L_IncSramAddr#:    ;Increase sram address
   656                      <               INC     C_SramAddrStart
   657                      <       		BNE     ?L_FillLoop#
   658                      <       		INC     C_SramAddrStart+1
   659                      <       		%WatchDogClear
   660                      <               JMP     ?L_FillLoop#
   661                      <       ?L_End#:
   662                      <               
   663                      <               LDA     mData
   664                      <               STA     C_SramAddrStart
   665                      <               STA     C_SramAddrStart+1
   666                      <               
   667                      <               LDX		#00H
   668                      <       ?L_HSRAMloop:
   669                      <       		LDA		mData
   670                      <       		STA		$180,X
   671                      <       		INX	
   672                      <       		CPX		#80H
   673                      <       		BNE		?L_HSRAMloop
   674                      <       		
   675                      <       	.ENDM
   676                      <       	
   677                      <       ;-----------------------------------------------------------------------------
   678                      <       ; Macro Name:	%ClrSRAM
   679                      <       ; Description:	Clear SRAM $60 ~ $95F
   680                      <       ;-----------------------------------------------------------------------------	
   681                      <       %ClrSRAM:	.MACRO
   682                      <       
   683                      <       		%FillSram	#0
   684                      <       
   685                      <       	.ENDM
   686                      <       ;-----------------------------------------------------------------------------
   687                      <       ;-----------------------------------------------------------------------------
   688                      <       ; Macro Name:	%FillLcdDpram
   689                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   690                      <       ;-----------------------------------------------------------------------------
   691                      <       %FillLcdDpram	.MACRO	mData
   692                      <       		
   693                      <       		%WatchDogClear
   694                      <       		LDX		#00H
   695                      <       		LDY		#00H
   696                      <       ?L_ClrDpramLoop:
   697                      <       		LDA     mData
   698                      <       		STA		$3E00,X
   699                      <       		INY
   700                      <       		CPY		#04H
   701                      <       		BNE		?L_ClrDpramLoopI
   702                      <       		LDY		#00H
   703                      <       		TXA
   704                      <       		CLC
   705                      <       		ADC		#0CH
   706                      <       		TAX
   707                      <       ?L_ClrDpramLoopI:		
   708                      <       		INX
   709                      <       		CPX		#80H
   710                      <       		BNE		?L_ClrDpramLoop
   711                      <       	.ENDM
