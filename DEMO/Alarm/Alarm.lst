  1478                              ;-------------------------------------------------------
  1479                              ; 输入：R_TempCH, R_TempCL 当前温度原始值。
  1480                              ; 输出：生成室内摄氏显示缓冲，并继续生成华氏显示缓冲。
  1481                              ; 调试：看 R_DispTemper+0/+1 与原始温度的 BCD 对应关系。
  1482 000000C6                     ProcessTemperature:
  1483 000000C6 AD 04 00            	LDA		R_TempCH
  1484 000000C9 29 7F               	AND		#7FH
  1485 000000CB AA                  	TAX
  1486 000000CC AD 05 00            	LDA		R_TempCL
  1487 000000CF 20 00 00            	JSR		F_CAL_HEX_BCD2
  1488 000000D2 AD 00 00            	LDA		OUT_M
  1489 000000D5 8D 1B 00            	STA		R_DispTemper+0
  1490 000000D8 AD 00 00            	LDA		OUT_L
  1491 000000DB 8D 1C 00            	STA		R_DispTemper+1
  1492 000000DE 4C E1 00            	JMP		ConvertToFahrenheit
  1493                              
  1494                              ;-------------------------------------------------------
  1495                              ; 输入：R_TempCH, R_TempCL 当前温度原始值。
  1496                              ; 输出：生成室内华氏显示缓冲 R_DispTemper_F。
  1497                              ; 调试：看 X_M/X_L 和 R_DispTemper_F 是否与换算结果一致。
  1498 000000E1                     ConvertToFahrenheit:
  1499 000000E1 AD 04 00            	LDA		R_TempCH
  1500 000000E4 AA                  	TAX
  1501 000000E5 AD 05 00            	LDA		R_TempCL
  1502 000000E8 20 00 00            	JSR		F_CHANGE_CF
  1503 000000EB AE 00 00            	LDX		X_M
  1504 000000EE AD 00 00            	LDA		X_L
  1505 000000F1 20 00 00            	JSR		F_CAL_HEX_BCD2
  1506 000000F4 AD 00 00            	LDA		OUT_M
  1507 000000F7 8D 15 00            	STA		R_DispTemper_F+0
  1508 000000FA AD 00 00            	LDA		OUT_L
  1509 000000FD 8D 16 00            	STA		R_DispTemper_F+1
  1510 00000100 60                  	RTS
  1511                              
  1512                              ;-------------------------------------------------------
  1513                              ; 输入：R_HUM 当前原始湿度值。
  1514                              ; 输出：把湿度夹到 1~99 后转换成 BCD 显示格式。
  1515                              ; 调试：重点看 0、1、99、100 这几个边界值的 R_DispHum。
  1516 00000101                     ProcessHumidity:
  1517 00000101 AD 06 00            	LDA		R_HUM
  1518 00000104 F0 0A               	BEQ		ProcessHumidity_Clamp1
  1519 00000106 C9 64               	CMP		#C_HumRaw100
  1520 00000108 90 0C               	BCC		ProcessHumidity_ConvertBCD
  1521 0000010A A9 99               	LDA		#C_HumDisp99
  1522 0000010C 8D 21 00            	STA		R_DispHum
  1523 0000010F 60                  	RTS
  1524                              
  1525 00000110                     ProcessHumidity_Clamp1:
  1526 00000110 A9 01               	LDA		#01H
  1527 00000112 8D 21 00            	STA		R_DispHum
  1528 00000115 60                  	RTS
  1529                              
  1530 00000116                     ProcessHumidity_ConvertBCD:
  1531 00000116 A2 00               	LDX		#00H
  1532 00000118 AD 06 00            	LDA		R_HUM
  1533 0000011B 20 00 00            	JSR		F_CAL_HEX_BCD2
  1534 0000011E AD 00 00            	LDA		OUT_L
  1535 00000121 8D 21 00            	STA		R_DispHum
  1536 00000124 60                  	RTS
