  1336 00000000                     .CODE
  1337                              ;-------------------------------------------------------
  1338                              ; şŻĘý: F_JudgeRFC
  1339                              ; ×÷ÓĂ: ÎÂĘŞ¶Č˛ÉŃůÍłŇ»ČëżÚŁ¬Ö»ÔÚŐű·Ö 00 ĂëµÄ°ëĂë±ßŃŘ´Ą·˘Ň»´ÎˇŁ
  1340                              .PUBLIC		F_JudgeRFC
  1341 00000000                     F_JudgeRFC:
  1342                              	%btst	R_KeyFlag,D_KeyRelDis,ExitJudge
  1343 00000000 AD 00 00          1           lda     R_KeyFlag               ;ex.   
  1344 00000003 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1345 00000005 D0 55             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1346                              	%btst	R_RFStatus,D_RFLongRecv,ExitJudge
  1347 00000007 AD 00 00          1           lda     R_RFStatus               ;ex.   
  1348 0000000A 29 01             1           and     #D_RFLongRecv              ;  %btst 10H,_BIT0,N
  1349 0000000C D0 4E             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1350 0000000E AD 02 00            	LDA		RTC+2
  1351 00000011 C9 00               	CMP		#00H
  1352 00000013 D0 47               	BNE		ExitJudge
  1353                              	%btst	R_TimeStatus,HalfSecToggle,ExitJudge
