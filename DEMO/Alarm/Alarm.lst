  1383 0000003C F0 0B               	BEQ		TemperatureIsPositive
  1384                              	%bits	R_SpecFlag,D_Neg
  1385 0000003E AD 10 00          1           lda     R_SpecFlag               ;ex.  
  1386 00000041 09 10             1           ora     #D_Neg              ;  %bits 10H,_BIT0
  1387                            1 		                   ;  10H.0=1
  1388 00000043 8D 10 00          1           sta     R_SpecFlag               ;
  1389 00000046 4C 51 00            	JMP		LoadTemperatureValue
