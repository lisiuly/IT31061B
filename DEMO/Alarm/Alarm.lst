  1339 00000000                     .CODE
  1340                              ;-------------------------------------------------------
  1341                              ; 函数: F_JudgeRFC
  1342                              ; 作用: 温湿度采样统一入口，只在整分 00 秒的半秒边沿触发一次。
  1343                              .PUBLIC		F_JudgeRFC
  1344 00000000                     F_JudgeRFC:
  1345                              	%btst	R_KeyFlag,D_KeyRelDis,ExitJudge
  1346 00000000 AD 00 00          1           lda     R_KeyFlag               ;ex.   
  1347 00000003 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1348 00000005 D0 55             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1349                              	%btst	R_RFStatus,D_RFLongRecv,ExitJudge
  1350 00000007 AD 00 00          1           lda     R_RFStatus               ;ex.   
  1351 0000000A 29 01             1           and     #D_RFLongRecv              ;  %btst 10H,_BIT0,N
  1352 0000000C D0 4E             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1353 0000000E AD 02 00            	LDA		RTC+2
  1354 00000011 C9 00               	CMP		#00H
  1355 00000013 D0 47               	BNE		ExitJudge
  1356                              	%btst	R_TimeStatus,HalfSecToggle,ExitJudge
  1357 00000015 AD 00 00          1           lda     R_TimeStatus               ;ex.   
  1358 00000018 29 40             1           and     #HalfSecToggle              ;  %btst 10H,_BIT0,N
  1359 0000001A D0 40             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1360 0000001C 4C 1F 00            	JMP		F_UpdateTHFromGXHTV4
  1361                              
  1362                              ;-------------------------------------------------------
  1363                              ; 函数: F_UpdateTHFromGXHTV4
