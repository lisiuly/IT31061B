  1394 0000004C 29 EF             1           and     #.NOT.D_Neg         ;  %bitr 10H,_BIT0;  10H.0=0
  1395 0000004E 8D 10 00          1           sta     R_SpecFlag
  1396                              
  1397 00000051                     LoadTemperatureValue:
