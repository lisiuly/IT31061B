  1539                              ; 函数: F_Judge_HHLL
  1540                              ; 作用: 重算当前温湿度 HH/LL 状态位。
  1541 00000125                     F_Judge_HHLL:
  1542                              	%bitr	R_SpecFlag,(D_TempLL+D_TempHH+D_HumLL+D_HumHH)
  1543 00000125 AD 10 00          1           lda     R_SpecFlag               ;ex.  
  1544 00000128 29 99             1           and     #.NOT.(D_TempLL+D_TempHH+D_HumLL+D_HumHH)         ;  %bitr 10H,_BIT0;  10H.0=0
  1545 0000012A 8D 10 00          1           sta     R_SpecFlag
  1546 0000012D 20 33 01            	JSR		F_Judge_TempHHLL
  1547 00000130 4C 61 01            	JMP		F_Judge_HumHHLL
  1548                              
  1549                              ; 输入：当前室内温度显示缓冲与负号标志。
  1550                              ; 输出：按规格重算温度 HH/LL 状态位。
  1551                              ; 调试：看 D_TempHH/D_TempLL 在高低边界附近是否按预期翻转。
  1552 00000133                     F_Judge_TempHHLL:
  1553                              	%btst	R_SpecFlag,D_Neg,JudgeTempLL
  1554 00000133 AD 10 00          1           lda     R_SpecFlag               ;ex.   
  1555 00000136 29 10             1           and     #D_Neg              ;  %btst 10H,_BIT0,N
  1556 00000138 D0 17             1           bne     JudgeTempLL               ;  if(10H.0=1) goto N 
  1557 0000013A AD 1B 00            	LDA		R_DispTemper+0
  1558 0000013D C9 05               	CMP		#05H
  1559 0000013F 90 0F               	BCC		JudgeTempExit
  1560 00000141 D0 05               	BNE		SetTempHH
  1561 00000143 AD 1C 00            	LDA		R_DispTemper+1
  1562 00000146 F0 08               	BEQ		JudgeTempExit
  1563 00000148                     SetTempHH:
  1564                              	%bits	R_SpecFlag,D_TempHH
  1565 00000148 AD 10 00          1           lda     R_SpecFlag               ;ex.  
  1566 0000014B 09 40             1           ora     #D_TempHH              ;  %bits 10H,_BIT0
  1567                            1 		                   ;  10H.0=1
  1568 0000014D 8D 10 00          1           sta     R_SpecFlag               ;
  1569 00000150                     JudgeTempExit:
  1570 00000150 60                  	RTS
  1571                              
  1572 00000151                     JudgeTempLL:
  1573 00000151 AD 1B 00            	LDA		R_DispTemper+0
  1574 00000154 C9 01               	CMP		#01H
  1575 00000156 90 F8               	BCC		JudgeTempExit
  1576                              	%bits	R_SpecFlag,D_TempLL
  1577 00000158 AD 10 00          1           lda     R_SpecFlag               ;ex.  
  1578 0000015B 09 20             1           ora     #D_TempLL              ;  %bits 10H,_BIT0
  1579                            1 		                   ;  10H.0=1
  1580 0000015D 8D 10 00          1           sta     R_SpecFlag               ;
  1581 00000160 60                  	RTS
  1582                              
  1583                              ; 输入：当前室内湿度显示状态。
  1584                              ; 输出：当前产品固定不产生湿度 HH/LL，直接返回。
