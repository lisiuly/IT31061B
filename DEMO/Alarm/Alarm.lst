   398                      <       ;Macro Name: %M_ClearWatchDog
   399                      <       ;Purpose: Clear Watchdog
   400                      <       ;Destroy: A
   401                      <       ;;============================================================================
   402                      <       %M_ClearWatchDog:		.MACRO 
   403                      <       	LDA		#D_WDT_Clear
   404                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   405                      <       	.ENDM
   406                      <       ;;============================================================================
   407                      <       ;Macro Name: %M_DisAllInt
   408                      <       ;Purpose: Disable all interrupt 
   409                      <       ;Destroy: A
   410                      <       ;;============================================================================
   411                      <       %F_InitINT:		.MACRO
   412                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   413                      <       		STA		P_TIMER_TimeBase_Sel		
   414                      <       		LDA		#D_128HzInt+D_TMBAInt+D_TMBBInt;D_Timer0Int+
   415                      <       		STA		P_INT_Ctrl
   416                      <       ;		LDA		#00
   417                      <       ;		STA		P_INT_Ctrl2		;disable TMR1 INT
   418                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   419                      <       ;		STA		P_TIMER_Timer0_Ctrl
   420                      <       ;		LDA		#0FCH
   421                      <       ;		STA		P_TIMER_TM0Data_LB		; Timer0 reload = FFFCh, scope now shows about 4.096kHz IRQ on this board.
   422                      <       ;		LDA		#0FFH
   423                      <       ;		STA		P_TIMER_TM0Data_HB
   424                      <       ;		STA		P_TIMER_TM0Load_Ctrl
   425                      <       	.ENDM
   426                      <       ;;============================================================================
   427                      <       ;Macro Name: %DisableLCD
   428                      <       ;Purpose: Disable LCD
   429                      <       ;Destroy: A
   430                      <       ;;============================================================================
   431                      <       %DisableLCD:		.MACRO
   432                      <       	
   433                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   434                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
