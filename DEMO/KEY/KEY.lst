   597                      <       ; Macro Name:	%InitLCD
   598                      <       ; Description:	Initialize LCD configuration after power on
   599                      <       ;-----------------------------------------------------------------------------	
   600                      <       %InitLCD:		.MACRO
   601                      <       
   602                      <       		LDA		#(D_Duty_1_5+D_Bias_1_3+D_ScanEnable)
   603                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   604                      <       		
