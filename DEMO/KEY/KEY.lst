  1276                              D_KeyAllTime		equ		0x02
  1277                              D_KeyLight			equ		0x04
  1278                              D_KeyUnused		equ		0x08
  1279                              
  1280                              
  1281 0000000C FF                  R_DebounceCnt		ds		1
