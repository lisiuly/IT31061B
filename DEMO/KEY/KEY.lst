   487                      <       ;;==========================================================================
   488                      <       ;%M_SetPC7_OutputL:	.MACRO
   489                      <       ;        LDA		P_IO_PortC_Attrib
   490                      <       ;		AND     #7FH
   491                      <       ;		STA		P_IO_PortC_Attrib
