   692                      <       %F_Initinal_IO	.MACRO
   693                      <       		LDA		#00000000b		
   694                      <       		STA		P_IO_PortA_Dir
   695                      <       		LDA		#00000000b		
   696                      <       		STA		P_IO_PortA_Data	
   697                      <       		
   698                      <       		LDA		#0
   699                      <       		STA		P_IO_PortB_Attrib
   700                      <       		LDA		#00000011b		
   701                      <       		STA		P_IO_PortB_Dir
   702                      <       		LDA		#00000000b		
   703                      <       		STA		P_IO_PortB_Data		;PB1룝츤포，PB0교밟
   704                      <       
   705                      <       		LDA		#00H
   706                      <       		STA		P_IO_PortC_Dir
   707                      <       		LDA		#00000000b
   708                      <       		STA		P_IO_PortC_Data	
   709                      <       		
   710                      <       		LDA		#00h
   711                      <       		STA		P_IO_PortD_Attrib		
   712                      <       		LDA		#00000001b		
   713                      <       		STA		P_IO_PortD_Dir
   714                      <       		STA		P_IOD_DIR_Map	
   715                      <       		LDA		#00000010b
   716                      <       		STA		P_IO_PortD_Data		
   717                      <       		STA		R_PortD_Data_Buf
   718                      <       
   719                      <       		LDA		#00000000b			;PE0/PE1/PE2 홍꼬鱗槨객숩渴흙
   720                      <       		STA		P_IO_PortE_Dir
   721                      <       		LDA		#00000000b			
   722                      <       		STA		P_IO_PortE_Data		
   723                      <       		
   724                      <       		LDA		#00
   725                      <       		STA		P_IO_Ctrl			;all as normal IO
   726                      <       		.ENDM
