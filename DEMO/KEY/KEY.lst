  1288                              ;=====================================================
  1289 00000000                     .CODE
  1290                              
  1291 00000000                     F_KeyScan:	
  1292                              		; PE0 = LIGHT, PE1 = C/F, PE2 = CH
  1293 00000000 A5 03               		LDA		P_IO_PortE_Data
  1294 00000002 29 07               		AND		#(D_Bit2+D_Bit1+D_Bit0)
  1295 00000004 F0 38               		BEQ		?ReleaseAllKey
  1296                              
  1297 00000006 A9 00               		LDA		#00H
  1298 00000008 85 09               		STA		R_KeyTemp
  1299                              
  1300 0000000A A5 03               		LDA		P_IO_PortE_Data
  1301 0000000C 29 01               		AND		#D_Bit0
  1302 0000000E F0 06               		BEQ		?L_CheckFcClearKey
  1303 00000010 A5 09               		LDA		R_KeyTemp
  1304 00000012 09 04               		ORA		#D_KeyLight
  1305 00000014 85 09               		STA		R_KeyTemp
  1306                              
  1307 00000016                     	?L_CheckFcClearKey:
  1308 00000016 A5 03               		LDA		P_IO_PortE_Data
  1309 00000018 29 02               		AND		#D_Bit1
  1310 0000001A F0 06               		BEQ		?L_CheckAllTimeKey
  1311 0000001C A5 09               		LDA		R_KeyTemp
  1312 0000001E 09 01               		ORA		#D_KeyFcClear
  1313 00000020 85 09               		STA		R_KeyTemp
  1314                              
  1315 00000022                     	?L_CheckAllTimeKey:
  1316 00000022 A5 03               		LDA		P_IO_PortE_Data
  1317 00000024 29 04               		AND		#D_Bit2
  1318 00000026 F0 06               		BEQ		?L_HaveKey
  1319 00000028 A5 09               		LDA		R_KeyTemp
  1320 0000002A 09 02               		ORA		#D_KeyAllTime
  1321 0000002C 85 09               		STA		R_KeyTemp
  1322                              
  1323 0000002E                     	?L_HaveKey:
  1324 0000002E A5 09               		LDA		R_KeyTemp
  1325 00000030 C5 0A               		CMP		R_KeyValue
  1326 00000032 F0 42               		BEQ		?CheckKeyDebounce
  1327 00000034 A5 09               		LDA		R_KeyTemp
  1328 00000036 85 0A               		STA		R_KeyValue
  1329 00000038 A9 02               		LDA		#C_KeyDebounce
  1330 0000003A 85 0C               		STA		R_DebounceCnt
  1331 0000003C 58                  		CLI
  1332 0000003D 60                  		RTS
  1333                              				
  1334 0000003E                     ?ReleaseAllKey:					;객숩姦렴
  1335                              		%btst	R_KeyFlag,D_KeyRelDis,?L_Exit	
  1336 0000003E A5 01             1           lda     R_KeyFlag               ;ex.   
  1337 00000040 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1338 00000042 D0 1B             1           bne     ?L_Exit               ;  if(10H.0=1) goto N 
  1339 00000044 A5 0B               		LDA	R_OldKeyValue
  1340 00000046 F0 17               		BEQ	?L_Exit
  1341                              		
  1342 00000048                     	?L_Dis_KeyTone:		
  1343 00000048 A5 0B               		LDA		R_OldKeyValue
  1344 0000004A C9 04               		CMP		#D_KeyLight
  1345 0000004C D0 03               		BNE		$+5		
  1346 0000004E 4C C6 00            		JMP		Enable_LightKey			
  1347                              
  1348 00000051 C9 02               		CMP		#D_KeyAllTime
  1349 00000053 D0 03               		BNE		$+5		
  1350 00000055 4C A8 00            		JMP		Enable_AllTimeKey
  1351                              
  1352 00000058 C9 01               		CMP		#D_KeyFcClear
  1353 0000005A D0 03               		BNE		$+5		
  1354 0000005C 4C AE 00            		JMP		Enable_FcClearKey
  1355                              		
  1356 0000005F                     	?L_Exit:		        ; 쉥객숩令긴좆헌쥐，藁놔
  1357 0000005F A9 00               		LDA		#00
  1358 00000061 85 0B               		STA		R_OldKeyValue
  1359 00000063 85 0A               		STA		R_KeyValue
  1360 00000065 85 09               		STA		R_KeyTemp
  1361 00000067 A9 02               		LDA	#C_KeyDebounce
  1362 00000069 85 0C               		STA	R_DebounceCnt
  1363 0000006B A9 04               		LDA	#C_LongKey2Sec
  1364 0000006D 85 06               		STA	R_LongKeyTime
