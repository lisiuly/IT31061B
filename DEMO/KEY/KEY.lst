   377                      <       ;Macro Name: %M_ClearWatchDog
   378                      <       ;Purpose: Clear Watchdog
   379                      <       ;Destroy: A
   380                      <       ;;============================================================================
   381                      <       %M_ClearWatchDog:		.MACRO 
   382                      <       	LDA		#D_WDT_Clear
   383                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   384                      <       	.ENDM
   385                      <       ;;============================================================================
   386                      <       ;Macro Name: %M_DisAllInt
   387                      <       ;Purpose: Disable all interrupt 
   388                      <       ;Destroy: A
   389                      <       ;;============================================================================
   390                      <       %F_InitINT:		.MACRO
   391                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   392                      <       		STA		P_TIMER_TimeBase_Sel		
   393                      <       		LDA		#D_2KHzInt+D_128HzInt+D_TMBAInt+D_TMBBInt;+D_Timer0Int
   394                      <       		STA		P_INT_Ctrl
   395                      <       		LDA		#00
   396                      <       		STA		P_INT_Ctrl2		;disable TMR1 INT
   397                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   398                      <       ;		STA		P_TIMER_Timer0_Ctrl
   399                      <       ;		LDA		#0xC8
   400                      <       ;		LDA		#0xFC
   401                      <       ;		STA		P_TIMER_TM0Data_LB		;8k
   402                      <       ;		LDA		#0xFF
   403                      <       ;		STA		P_TIMER_TM0Data_HB
   404                      <       	.ENDM
   405                      <       ;;============================================================================
   406                      <       ;Macro Name: %DisableLCD
   407                      <       ;Purpose: Disable LCD
   408                      <       ;Destroy: A
   409                      <       ;;============================================================================
   410                      <       %DisableLCD:		.MACRO
   411                      <       	
   412                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   413                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   414                      <       		
   415                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
   416                      <       		STA     P_LCD_VLCD_Ctrl
   417                      <       	.ENDM
