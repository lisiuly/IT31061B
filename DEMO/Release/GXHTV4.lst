   286                              ;;*****************
   287                              ;;crc校验，最高位是1就^0x31
   288                              ;高位数据放 R_temp1 低位数据放 R_temp0 crc数据放 R_temp2 进
   289                              ;相等返回 c=1 
   290 0000ECC1                     F_crc_check_handle:;
   291 0000ECC1 A5 A9               	LDA		CNT4
   292 0000ECC3 85 A6               	STA		CNT1
   293 0000ECC5 A5 AA               	LDA		CNT5
   294 0000ECC7 85 A7               	STA		CNT2
   295                              
   296 0000ECC9 A9 08               	LDA		#0x08
   297 0000ECCB 85 A8               	STA 	CNT3
   298 0000ECCD A5 A6               	LDA 	CNT1
   299 0000ECCF 49 FF               	EOR  	#0xff
   300 0000ECD1 85 A6               	STA 	CNT1
   301 0000ECD3                     F_crc_check_h_loop:
   302 0000ECD3 A5 A6               	LDA		CNT1
   303 0000ECD5 29 80               	AND		#0x80
   304                              ;	BIT		#BIT7
   305 0000ECD7 F0 0C               	BEQ 	F_crc_check_h_loop_clr
   306 0000ECD9                     F_crc_check_h_loop_set:
   307 0000ECD9 18                  	CLC
   308 0000ECDA 26 A6               	ROL 	CNT1 
   309 0000ECDC A5 A6               	LDA 	CNT1
   310 0000ECDE 49 31               	EOR  	#0x31
   311 0000ECE0 85 A6               	STA 	CNT1
   312 0000ECE2 4C E8 EC            	JMP 	F_crc_check_h_loop_0
   313 0000ECE5                     F_crc_check_h_loop_clr:
   314 0000ECE5 18                  	CLC 	
   315 0000ECE6 26 A6               	ROL 	CNT1
   316 0000ECE8                     F_crc_check_h_loop_0:
   317 0000ECE8 C6 A8               	DEC 	CNT3 
   318 0000ECEA D0 E7               	BNE 	F_crc_check_h_loop
   319                              ;======================
   320 0000ECEC A9 08               	LDA		#0x08
   321 0000ECEE 85 A8               	STA 	CNT3
   322 0000ECF0 A5 A6               	LDA 	CNT1			;前一位CRC结果
   323 0000ECF2 45 A7               	EOR 	CNT2
   324 0000ECF4 85 A6               	STA 	CNT1
   325 0000ECF6                     F_crc_check_l_loop:
   326 0000ECF6 A5 A6               	LDA		CNT1
   327 0000ECF8 29 80               	AND		#0x80
   328                              ;	BIT		#BIT7
   329 0000ECFA F0 0C               	BEQ 	F_crc_check_l_loop_clr
   330 0000ECFC                     F_crc_check_l_loop_set:
   331 0000ECFC 18                  	clc	
   332 0000ECFD 26 A6               	ROL 	CNT1
   333 0000ECFF A5 A6               	LDA 	CNT1
   334 0000ED01 49 31               	EOR  	#0x31
   335 0000ED03 85 A6               	STA 	CNT1
   336 0000ED05 4C 0B ED            	JMP 	F_crc_check_l_loop_0
   337 0000ED08                     F_crc_check_l_loop_clr:
   338 0000ED08 18                  	CLC 	
   339 0000ED09 26 A6               	ROL 	CNT1
   340 0000ED0B                     F_crc_check_l_loop_0:
   341 0000ED0B C6 A8               	DEC		CNT3
   342 0000ED0D D0 E7               	BNE 	F_crc_check_l_loop
   343                              ;================
   344 0000ED0F A5 A6               	LDA 	CNT1
   345 0000ED11 C5 AB               	CMP		CNT6
   346 0000ED13 D0 02               	BNE		F_crc_check_err
   347 0000ED15 38                  	SEC 
   348 0000ED16 60                  	RTS
   349 0000ED17                     F_crc_check_err:
   350 0000ED17 18                  	CLC
   351 0000ED18 60                  	RTS		
   352                              	
   353                              	
