   423 0000ED7B                     MUL_HEX:;双字节 * 双字节 -->4字节;IN:X_H,X_L ; Y_H,Y_L,
   424                              	;OUT:OUT_H,OUT_1,OUT_M,OUT_L;
   425 0000ED7B A9 00               	LDA		#00H
   426 0000ED7D 85 B5               	STA		OUT_H;清零
   427 0000ED7F 85 B4               	STA		OUT_1
   428 0000ED81 85 B3               	STA		OUT_M
   429 0000ED83 85 B2               	STA		OUT_L
   430 0000ED85 A2 10               	LDX		#$10	;16BIT
   431 0000ED87                     MUL_LOOP:
   432                              ;	CLC
   433 0000ED87 06 B2               	ASL		OUT_L
   434 0000ED89 26 B3               	ROL		OUT_M
   435 0000ED8B 26 B4               	ROL		OUT_1
   436 0000ED8D 26 B5               	ROL		OUT_H
   437                              
   438 0000ED8F 26 B1               	ROL		Y_L
   439 0000ED91 26 B0               	ROL		Y_H
   440 0000ED93 90 19               	BCC		TO_LOOP0	;C=0 JMP
   441 0000ED95 18                  	CLC		;CLEAR C
   442 0000ED96 A5 AF               	LDA		X_L
   443 0000ED98 65 B2               	ADC		OUT_L
   444 0000ED9A 85 B2               	STA		OUT_L
   445 0000ED9C A5 AC               	LDA		X_H
   446 0000ED9E 65 B3               	ADC		OUT_M
   447 0000EDA0 85 B3               	STA		OUT_M
   448 0000EDA2 A9 00               	LDA		#00
   449 0000EDA4 65 B4               	ADC		OUT_1
   450 0000EDA6 85 B4               	STA		OUT_1
   451 0000EDA8 A9 00               	LDA		#00
   452 0000EDAA 65 B5               	ADC		OUT_H
   453 0000EDAC 85 B5               	STA		OUT_H
