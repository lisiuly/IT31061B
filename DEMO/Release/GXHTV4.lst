   355 0000ED19                     DIV_HEX:;IN:OUT_H,OUT_1,OUT_M,OUT_L; Y_H,Y_L;OUT:X_H,X_1,X_M,X_L
   356                              	;余数:CNT5,CNT6: USE:X,Y
   357 0000ED19 A9 00               	lda		#00
   358 0000ED1B 85 AC               	STA		X_H
   359 0000ED1D 85 AD               	STA		X_1
   360 0000ED1F 85 AE               	STA		X_M
   361 0000ED21 85 AF               	STA		X_L
   362                              
   363 0000ED23 85 A7               	STA		CNT2
   364 0000ED25 85 A8               	STA		CNT3
   365 0000ED27 85 A9               	STA		CNT4
   366                              
   367 0000ED29 A5 B0               	LDA		Y_H;除数为零跳出
   368 0000ED2B D0 04               	BNE		NDIV1;Z=0
   369 0000ED2D A5 B1               	LDA		Y_L
   370 0000ED2F F0 49               	BEQ		NDIV_END;Z=1
   371 0000ED31                     NDIV1:
   372 0000ED31 A2 20               	LDX		#32;16
   373 0000ED33                     NDIV2:
   374 0000ED33 18                  	CLC
   375 0000ED34 26 B2               	ROL		OUT_L	;被除数
   376 0000ED36 26 B3               	ROL		OUT_M
   377 0000ED38 26 B4               	ROL		OUT_1
   378 0000ED3A 26 B5               	ROL		OUT_H
   379                              
   380 0000ED3C 26 A9               	ROL		CNT4	;余数
   381 0000ED3E 26 A8               	ROL		CNT3
   382 0000ED40 26 A7               	ROL		CNT2	;溢出位
   383                              
   384 0000ED42 26 AF               	ROL		X_L		;OUT????????
   385 0000ED44 26 AE               	ROL		X_M
   386 0000ED46 26 AD               	ROL		X_1
   387 0000ED48 26 AC               	ROL		X_H
   388                              
   389 0000ED4A A5 A7               	LDA		CNT2
   390 0000ED4C D0 16               	BNE		NDIV_SUB	;Z=0
   391 0000ED4E 38                  	SEC
   392 0000ED4F A5 A8               	LDA		CNT3
   393 0000ED51 E5 B0               	SBC		Y_H
   394 0000ED53 F0 05               	BEQ		NDIV_7	;Z=1
   395 0000ED55 B0 0D               	BCS		NDIV_SUB
   396 0000ED57 4C 77 ED            	JMP		NDIV4	;不够减????
   397 0000ED5A                     NDIV_7:
   398 0000ED5A 38                  	SEC
   399 0000ED5B A5 A9               	LDA		CNT4
   400 0000ED5D E5 B1               	SBC		Y_L
   401 0000ED5F B0 03               	BCS		NDIV_SUB;C=1
   402 0000ED61 4C 77 ED            	JMP		NDIV4	;不够减
   403 0000ED64                     NDIV_SUB:
   404 0000ED64 A9 00               	LDA		#00
   405 0000ED66 85 A7               	STA		CNT2
   406 0000ED68 38                  	SEC
   407 0000ED69 A5 A9               	LDA		CNT4
   408 0000ED6B E5 B1               	SBC		Y_L
   409 0000ED6D 85 A9               	STA		CNT4
   410 0000ED6F A5 A8               	LDA		CNT3
   411 0000ED71 E5 B0               	SBC		Y_H
   412 0000ED73 85 A8               	STA		CNT3
   413                              
   414 0000ED75 E6 AF               	INC		X_L	;OUT LOW BIT
   415                              
   416 0000ED77                     NDIV4:
   417 0000ED77 CA                  	DEX
   418 0000ED78 D0 B9               	BNE		NDIV2	;Z=0
   419                              
   420 0000ED7A                     NDIV_END:
