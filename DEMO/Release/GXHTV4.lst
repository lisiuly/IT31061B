   183                              ;.COMMENT	@
   184                              ;  Input CNT4,CNT5
   185                              ;======================================================================
   186 0000EC2B                     CAL_IC_TEMP:   ;IN:CNT4,CNT5
   187                                  ;T=(-450 + ST * 1750/65535)/10
   188 0000EC2B A5 A9                   	LDA            	CNT4
   189 0000EC2D 85 AC                   	STA          	X_H
   190 0000EC2F A5 AA                   	LDA            	CNT5
   191 0000EC31 85 AF                   	STA           	X_L
   192                                  	
   193 0000EC33 A9 D6                   	LDA          	#0D6H        ;1750 =6D6
   194 0000EC35 85 B1                   	STA           	Y_L
   195 0000EC37 A9 06                   	LDA           	#06H
   196 0000EC39 85 B0                   	STA           	Y_H
   197 0000EC3B 20 7B ED                	JSR            	MUL_HEX     ;/65536=10000H
   198 0000EC3E A9 FF                   	LDA	    		#0FFH
   199 0000EC40 85 B0                   	STA	   			Y_H
   200 0000EC42 A9 FF                   	LDA	    		#0FFH
   201 0000EC44 85 B1                   	STA    			Y_L
   202 0000EC46 20 19 ED            		JSR				DIV_HEX		;OUT:X
   203                              	
   204 0000EC49 38                  		SEC
   205 0000EC4A A5 AF               		LDA				X_L
   206 0000EC4C E9 C2               		SBC				#0xC2
   207 0000EC4E A5 AE               		LDA				X_M 
   208 0000EC50 E9 01               		SBC				#0x01
   209                               
   210 0000EC52 90 23               		BCC            CAL_TEMP_PLUS
   211                              ;=======  + =======================
   212 0000EC54 38                  		SEC
   213 0000EC55 A5 AF               		LDA				X_L
   214 0000EC57 E9 C2               		SBC				#0xC2
   215 0000EC59 85 A4               		STA				TEMP_INTEGAL
   216 0000EC5B A5 AE               		lda				X_M
   217 0000EC5D E9 01               		SBC				#0x01
   218 0000EC5F 85 A3                    	STA				TEMP_INTEGAH
   219                              
   220 0000EC61 38                  		SEC
   221 0000EC62 A5 A4               		LDA			TEMP_INTEGAL
   222 0000EC64 E9 BC               		SBC			#0xBC
   223 0000EC66 A5 A3               		LDA			TEMP_INTEGAH
   224 0000EC68 E9 02               		SBC			#0x02
   225                              
   226 0000EC6A 90 31                   	BCC			CAL_TEMP_OUT
   227 0000EC6C A9 02                   	LDA			#02H
   228 0000EC6E 85 A3                   	STA			TEMP_INTEGAH
   229 0000EC70 A9 BC                   	LDA			#0BCH
   230 0000EC72 85 A4                   	STA			TEMP_INTEGAL
   231 0000EC74 4C 9D EC                	JMP			CAL_TEMP_OUT
   232 0000EC77                     CAL_TEMP_PLUS: ; -
   233 0000EC77 38                  		SEC
   234 0000EC78 A9 C2               		LDA			#0C2H
   235 0000EC7A E5 AF               		SBC			X_L 
   236 0000EC7C 85 A4               		STA			TEMP_INTEGAL
   237 0000EC7E A9 01               		LDA			#0X01
   238 0000EC80 E5 AE               		SBC			X_M 
   239 0000EC82 85 A3               		STA			TEMP_INTEGAH
   240                              ;		BSF			TEMP_INTEGAH,BIT7		;-
   241 0000EC84 A5 A3               		LDA			TEMP_INTEGAH
   242 0000EC86 09 80               		ORA			#0x80
   243 0000EC88 85 A3               		STA			TEMP_INTEGAH
   244                              
   245 0000EC8A 38                  		SEC
   246 0000EC8B A5 A4               		LDA			TEMP_INTEGAL
   247 0000EC8D E9 C8               		SBC			#0xC8
   248 0000EC8F A5 A3               		LDA			TEMP_INTEGAH
   249 0000EC91 E9 80               		SBC			#0x080
   250 0000EC93 90 08               		BCC			CAL_TEMP_OUT
   251 0000EC95 A9 80                   	LDA			#080H
   252 0000EC97 85 A3                   	STA			TEMP_INTEGAH
   253 0000EC99 A9 C8                   	LDA			#0C8H
   254 0000EC9B 85 A4                   	STA			TEMP_INTEGAL
   255 0000EC9D                     CAL_TEMP_OUT:
   256 0000EC9D 60                  		RTS
   257                              ;======================================================================
   258                              ;======================================================================
   259 0000EC9E                     CAL_IC_HUM:   ;IN:CNT4,CNT5
   260                                  ;T=100* S / 65533
   261 0000EC9E A5 A9                   	LDA      	CNT4
   262 0000ECA0 85 AC               		STA        	X_H
   263 0000ECA2 A5 AA                   	LDA       	CNT5
   264 0000ECA4 85 AF                   	STA        	X_L
   265 0000ECA6 A9 64                   	LDA      	#064H        ;125 = 7D
   266 0000ECA8 85 B1                   	STA     	Y_L
   267 0000ECAA A9 00                   	LDA			#00
   268 0000ECAC 85 B0                   	STA        	Y_H
   269 0000ECAE 20 7B ED                	JSR         MUL_HEX     ;/65536=10000H
   270 0000ECB1 A9 FF                   	LDA	    	#0FFH
   271 0000ECB3 85 B0                   	STA	   		Y_H
   272 0000ECB5 A9 FD                   	LDA	    	#0FDH
   273 0000ECB7 85 B1                   	STA    		Y_L
   274 0000ECB9 20 19 ED            		JSR			DIV_HEX		;OUT:X
   275 0000ECBC A5 AF               		LDA			X_L
   276 0000ECBE 85 A5               		STA			HUM
   277                              ;======================
   278                              ;		BBR7		HUM,CAL_HUM_OUT
   279                              ;		LDA			#00H
   280                              ;   	STA             HUM
   281 0000ECC0                     CAL_HUM_OUT:
   282                              ;==========================================
   283                              ;==========================================
   284 0000ECC0 60                  		RTS
