   109 0000EBC1                     .CODE
   110                              ;==========================================
   111                              ; IRQ INTERRUPT SERVICE ROUTINE
   112                              ;==========================================
   113                              ;======================================================================
   114                              ; 通过 D_I2C 底层发送转换命令，再读取 6 字节原始数据。
   115                              ; 读取成功后更新 TEMP_INTEGAH/TEMP_INTEGAL/HUM。
   116                              ;======================================================================
   117 0000EBC1                     F_ReadGXHTV4Data:
   118 0000EBC1 20 33 EF            		JSR			F_IIC_start
   119 0000EBC4 A0 88               		LDY			#I2C_ID_GXHTV4
   120 0000EBC6 20 59 EF            		JSR			F_IIC_Set8bit
   121 0000EBC9 20 C4 EF            		JSR			F_RACK
   122 0000EBCC 90 42               		BCC			F_ReadGXHTV4StopExit
   123 0000EBCE A0 24               		LDY			#CMD_MEASURE_TH
   124 0000EBD0 20 59 EF            		JSR			F_IIC_Set8bit
   125 0000EBD3 20 C4 EF            		JSR			F_RACK
   126 0000EBD6 90 38               		BCC			F_ReadGXHTV4StopExit
   127 0000EBD8 20 46 EF            		JSR			F_IIC_stop
   128                              
   129 0000EBDB 20 14 EC            		JSR			F_GXHTV4WaitReady
   130 0000EBDE 20 41 F0            		JSR			F_I2C_ReadData
   131                              
   132 0000EBE1 AD BE 00            		LDA			R_SaveData+0
   133 0000EBE4 85 A9               		STA			CNT4
   134 0000EBE6 AD BF 00            		LDA			R_SaveData+1
   135 0000EBE9 85 AA               		STA			CNT5
   136 0000EBEB AD C0 00            		LDA			R_SaveData+2
   137 0000EBEE 85 AB               		STA			CNT6
   138 0000EBF0 20 C1 EC            		JSR			F_crc_check_handle
   139 0000EBF3 90 1E               		BCC			F_ReadGXHTV4Data_Exit
   140 0000EBF5 20 2B EC            		JSR			CAL_IC_TEMP
   141                              
   142 0000EBF8 AD C1 00            		LDA			R_SaveData+3
   143 0000EBFB 85 A9               		STA			CNT4
   144 0000EBFD AD C2 00            		LDA			R_SaveData+4
   145 0000EC00 85 AA               		STA			CNT5
   146 0000EC02 AD C3 00            		LDA			R_SaveData+5
   147 0000EC05 85 AB               		STA			CNT6
   148 0000EC07 20 C1 EC            		JSR			F_crc_check_handle
   149 0000EC0A 90 07               		BCC			F_ReadGXHTV4Data_Exit
   150 0000EC0C 20 9E EC            		JSR			CAL_IC_HUM
   151 0000EC0F 60                  		RTS
   152                              
   153 0000EC10                     F_ReadGXHTV4StopExit:
   154 0000EC10 20 46 EF            		JSR			F_IIC_stop
   155                              
   156 0000EC13                     F_ReadGXHTV4Data_Exit:
   157 0000EC13 60                  		RTS
   158                              
   159 0000EC14                     F_GXHTV4WaitReady:
   160                              		; 0x24 是 0.1s 加热测量命令，这里等待约 160ms，先把“时间不够”排除掉。
   161 0000EC14 A9 02               		LDA			#02H
   162 0000EC16 48                  		PHA
   163 0000EC17                     F_GXHTV4WaitReady_A:
   164 0000EC17 A0 FF               		LDY			#0FFH
   165 0000EC19                     F_GXHTV4WaitReady_Y:
   166 0000EC19 A2 FF               		LDX			#0FFH
   167 0000EC1B                     F_GXHTV4WaitReady_X:
   168 0000EC1B CA                  		DEX
   169 0000EC1C D0 FD               		BNE			F_GXHTV4WaitReady_X
   170 0000EC1E 88                  		DEY
   171 0000EC1F D0 F8               		BNE			F_GXHTV4WaitReady_Y
   172 0000EC21 68                  		PLA
   173 0000EC22 38                  		SEC
   174 0000EC23 E9 01               		SBC			#01H
   175 0000EC25 F0 03               		BEQ			F_GXHTV4WaitReady_Done
   176 0000EC27 48                  		PHA
   177 0000EC28 D0 ED               		BNE			F_GXHTV4WaitReady_A
   178                              		
   179 0000EC2A                     F_GXHTV4WaitReady_Done:
   180 0000EC2A 60                  		RTS
