   610                      <       ;-----------------------------------------------------------------------------
   611                      <       ; Macro Name:	%FillSram
   612                      <       ; Description:	Fill data to SRAM whole space
   613                      <       ; Input:		mData
   614                      <       ;-----------------------------------------------------------------------------	
   615                      <       %FillSram		.MACRO	mData
   616                      <       		
   617                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   618                      <       		STA		C_SramAddrStart
   619                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   620                      <       		STA		C_SramAddrStart+1
   621                      <       		
   622                      <       		LDX     #0
   623                      <       ?L_FillLoop#:
   624                      <               LDA     mData
   625                      <       		STA     (C_SramAddrStart,X)
   626                      <       		
   627                      <       		LDA     C_SramAddrStart+1
   628                      <       		CMP     #.HIGH.C_SramAddrEnd
   629                      <       		BCC     ?L_IncSramAddr#
   630                      <       		LDA     C_SramAddrStart
   631                      <       		CMP     #.LOW.C_SramAddrEnd
   632                      <       		BCS     ?L_End#
   633                      <       		
   634                      <       ?L_IncSramAddr#:    ;Increase sram address
   635                      <               INC     C_SramAddrStart
   636                      <       		BNE     ?L_FillLoop#
   637                      <       		INC     C_SramAddrStart+1
   638                      <       		%WatchDogClear
   639                      <               JMP     ?L_FillLoop#
   640                      <       ?L_End#:
   641                      <               
   642                      <               LDA     mData
   643                      <               STA     C_SramAddrStart
   644                      <               STA     C_SramAddrStart+1
   645                      <               
   646                      <               LDX		#00H
   647                      <       ?L_HSRAMloop:
   648                      <       		LDA		mData
   649                      <       		STA		$180,X
   650                      <       		INX	
   651                      <       		CPX		#80H
   652                      <       		BNE		?L_HSRAMloop
   653                      <       		
   654                      <       	.ENDM
   655                      <       	
   656                      <       ;-----------------------------------------------------------------------------
   657                      <       ; Macro Name:	%ClrSRAM
   658                      <       ; Description:	Clear SRAM $60 ~ $95F
   659                      <       ;-----------------------------------------------------------------------------	
   660                      <       %ClrSRAM:	.MACRO
   661                      <       
   662                      <       		%FillSram	#0
   663                      <       
   664                      <       	.ENDM
