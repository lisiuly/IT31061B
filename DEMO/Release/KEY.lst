  1293 0000E2D4                     .CODE
  1294                              
  1295                              ; ĘäČë: PE0/PE1/PE2 µ±Ç°°´ĽüµçĆ˝ˇ˘ŔúĘ·ĽüÖµşÍČĄ¶¶×´Ě¬ˇŁ
  1296                              ; Ęäłö: ¸üĐÂ R_KeyValue/R_OldKeyValueŁ¬˛˘ÔÚ°´ĽüĘÍ·ĹĘ±·Ö·˘µ˝¶ÔÓ¦¶Ě°´ą¦ÄÜˇŁ
  1297                              ; µ÷ĘÔ: ż´ R_KeyTempˇ˘R_KeyValueˇ˘R_OldKeyValueˇ˘R_DebounceCnt µÄ±ä»ŻˇŁ
  1298 0000E2D4                     F_KeyScan:	
  1299                              		; PE0 = LIGHT, PE1 = C/F, PE2 = CH
  1300 0000E2D4 A5 03               		LDA		P_IO_PortE_Data
  1301 0000E2D6 29 07               		AND		#(D_Bit2+D_Bit1+D_Bit0)
  1302 0000E2D8 F0 38               		BEQ		?ReleaseAllKey
  1303                              
  1304 0000E2DA A9 00               		LDA		#00H
  1305 0000E2DC 85 92               		STA		R_KeyTemp
  1306                              
  1307 0000E2DE A5 03               		LDA		P_IO_PortE_Data
  1308 0000E2E0 29 01               		AND		#D_Bit0
  1309 0000E2E2 F0 06               		BEQ		?L_CheckFcClearKey
  1310 0000E2E4 A5 92               		LDA		R_KeyTemp
  1311 0000E2E6 09 04               		ORA		#D_KeyLight
  1312 0000E2E8 85 92               		STA		R_KeyTemp
  1313                              
  1314 0000E2EA                     	?L_CheckFcClearKey:
  1315 0000E2EA A5 03               		LDA		P_IO_PortE_Data
  1316 0000E2EC 29 02               		AND		#D_Bit1
  1317 0000E2EE F0 06               		BEQ		?L_CheckAllTimeKey
  1318 0000E2F0 A5 92               		LDA		R_KeyTemp
  1319 0000E2F2 09 01               		ORA		#D_KeyFcClear
  1320 0000E2F4 85 92               		STA		R_KeyTemp
  1321                              
  1322 0000E2F6                     	?L_CheckAllTimeKey:
  1323 0000E2F6 A5 03               		LDA		P_IO_PortE_Data
  1324 0000E2F8 29 04               		AND		#D_Bit2
  1325 0000E2FA F0 06               		BEQ		?L_HaveKey
  1326 0000E2FC A5 92               		LDA		R_KeyTemp
  1327 0000E2FE 09 02               		ORA		#D_KeyAllTime
  1328 0000E300 85 92               		STA		R_KeyTemp
  1329                              
  1330 0000E302                     	?L_HaveKey:
  1331 0000E302 A5 92               		LDA		R_KeyTemp
  1332 0000E304 C5 93               		CMP		R_KeyValue
  1333 0000E306 F0 42               		BEQ		?CheckKeyDebounce
  1334 0000E308 A5 92               		LDA		R_KeyTemp
  1335 0000E30A 85 93               		STA		R_KeyValue
  1336 0000E30C A9 02               		LDA		#C_KeyDebounce
  1337 0000E30E 85 95               		STA		R_DebounceCnt
  1338 0000E310 58                  		CLI
  1339 0000E311 60                  		RTS
  1340                              				
  1341 0000E312                     ?ReleaseAllKey:					;°´ĽüĘÍ·Ĺ
  1342                              		%btst	R_KeyFlag,D_KeyRelDis,?L_Exit	
  1343 0000E312 A5 8A             1           lda     R_KeyFlag               ;ex.   
  1344 0000E314 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1345 0000E316 D0 1B             1           bne     ?L_Exit               ;  if(10H.0=1) goto N 
  1346 0000E318 A5 94               		LDA	R_OldKeyValue
  1347 0000E31A F0 17               		BEQ	?L_Exit
  1348                              		
  1349 0000E31C                     	?L_Dis_KeyTone:		
  1350 0000E31C A5 94               		LDA		R_OldKeyValue
  1351 0000E31E C9 04               		CMP		#D_KeyLight
