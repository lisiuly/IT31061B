   224                      <       ;**********************************************************************
   225                      <       ;ROM Checksum
   226                      <       ;**********************************************************************
   227                      <       ;.IF (GPL813P01Ax+GPL813P01Bx+GPL813P01Cx)
   228                      <       ;	D_BankNum:						.EQU	1	
   229                      <       ;.ENDIF
   230                      <       
   231                      <       	D_Bank0UserRomStartAddr:		.EQU	0xE000		;0x4800 ~ 0x7FDF:User ROM Code
   232                      <       	D_Bank0UserRomEndAddr:			.EQU	0xFFDF
   233                      <       	D_NMIandResetVectorStartAddr:	.EQU	0xFFFC		;0xFFF8 ~ 0xFFF9:User ROM Code, 0xFFFA ~ 0xFFFF:NMI & Reset & IRQ vector
   234                      <       	D_NMIandResetVectorEndAddr:		.EQU	0xFFFF
   235                      <       
   236                      <       ; ========================================================================================
   237                      <       ; Macro Name	: M_UserRomChecksum
   238                      <       ; Parameters	: None
   239                      <       ; Return Value	: R_ChecksumResult: bit[7:0]
   240                      <       ;				: R_ChecksumResult + 1: bit[15:8]
   241                      <       ;				: R_ChecksumResult + 2: bit[23:16]
   242                      <       ;				: R_ChecksumResult + 3: bit[31:24]
   243                      <       ; Description	: Calculate user ROM area code checksum
   244                      <       ; Destroy		: A, Y
   245                      <       ; Example		: %M_UserRomChecksum	R_ChecksumAddrPtr, R_ChecksumResult
   246                      <       ; ========================================================================================	
   247                      <       %M_UserRomChecksum:	.MACRO	R_ChecksumAddrPtr, R_ChecksumResult
   248                      <       	
   249                      <       	LDA		#0
   250                      <       	STA		R_ChecksumResult						;Result Byte0
   251                      <       	STA		R_ChecksumResult + 1				;Result Byte1
   252                      <       	STA		R_ChecksumResult + 2				;Result Byte2
   253                      <       	STA		R_ChecksumResult + 3				;Result Byte3
   254                      <       ;=================== Bank 0 ==================================================	
   255                      <       	LDA		#.HIGH.D_Bank0UserRomStartAddr
   256                      <       	STA		R_ChecksumAddrPtr + 1				;Start High Byte
   257                      <       	LDA		#.LOW.D_Bank0UserRomStartAddr
   258                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   259                      <       		
   260                      <       	LDY		#0	
   261                      <       
   262                      <       L_ChecksumLoop1?
   263                      <       	STA		P_WDT_Flag_Clear	
   264                      <       	CLC
   265                      <       	LDA		(R_ChecksumAddrPtr),Y
   266                      <       	ADC		R_ChecksumResult						;Result Low Byte
   267                      <       	STA		R_ChecksumResult						;Result Low Byte
   268                      <       	BCC		L_CheckAddress1?
   269                      <       	INC		R_ChecksumResult + 1				;Result Byte1
   270                      <       	BNE		L_CheckAddress1?
   271                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   272                      <       	BNE		L_CheckAddress1?
   273                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   274                      <       		
   275                      <       L_CheckAddress1?:
   276                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   277                      <       	CMP		#.HIGH.D_Bank0UserRomEndAddr		;End High Byte
   278                      <       	BNE		L_IncreaseAdd1?
   279                      <       	
   280                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   281                      <       	CMP		#.LOW.D_Bank0UserRomEndAddr			;End Low Byte
   282                      <       	BEQ		L_ExitRomSum1?
   283                      <       	
   284                      <       L_IncreaseAdd1?:
   285                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   286                      <       	BNE		L_ChecksumLoop1?
   287                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   288                      <       	JMP		L_ChecksumLoop1?	
   289                      <       		
   290                      <       L_ExitRomSum1?:	
   291                      <       
   292                      <       ;===================NMI & Reset Vector==================================================		
   293                      <       	LDA		#.HIGH.D_NMIandResetVectorStartAddr
   294                      <       	STA		R_ChecksumAddrPtr + 1				; Start High Byte
   295                      <       	LDA		#.LOW.D_NMIandResetVectorStartAddr
   296                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   297                      <       		
   298                      <       L_ChecksumLoop2?
   299                      <       	STA		P_WDT_Flag_Clear		
   300                      <       	CLC
   301                      <       	LDA		(R_ChecksumAddrPtr),Y
   302                      <       	ADC		R_ChecksumResult						;Result Low Byte
   303                      <       	STA		R_ChecksumResult						;Result Low Byte
   304                      <       	BCC		L_CheckAddress2?
   305                      <       	INC		R_ChecksumResult + 1				;Result Byte2
   306                      <       	BNE		L_CheckAddress2?
   307                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   308                      <       	BNE		L_CheckAddress2?
   309                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   310                      <       		
   311                      <       L_CheckAddress2?:
   312                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   313                      <       	CMP		#.HIGH.D_NMIandResetVectorEndAddr	;End High Byte
   314                      <       	BNE		L_IncreaseAdd2?
   315                      <       	
   316                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   317                      <       	CMP		#.LOW.D_NMIandResetVectorEndAddr	;End Low Byte
   318                      <       	BEQ		L_ExitRomSum2?
   319                      <       	
   320                      <       L_IncreaseAdd2?:
   321                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   322                      <       	BNE		L_ChecksumLoop2?
   323                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   324                      <       	JMP		L_ChecksumLoop2?	
   325                      <       		
   326                      <       L_ExitRomSum2?:	
   327                      <       ;;=====================Bank area================================================		
   328                      <       	
   329                      <       	.ENDM
   330                      <       ;================================================================================
   331                      <       
   332                      <       			.ENDIF
   333                      <       .ENDIF
   334                      <       	.ENDIF
