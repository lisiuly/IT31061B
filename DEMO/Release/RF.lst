  2343                              
  2344 0000FBE1                     RF_SetPacketMask:
  2345 0000FBE1 E0 00               		CPX		#00H
  2346 0000FBE3 F0 05               		BEQ		RF_SetPacketMaskDone
  2347 0000FBE5 4A                  		LSR		A
  2348 0000FBE6 CA                  		DEX
  2349 0000FBE7 4C E1 FB            		JMP		RF_SetPacketMask
  2350                              
  2351 0000FBEA                     RF_SetPacketMaskDone:
