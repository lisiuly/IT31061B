  2216                              ; 输入: 2kHz 中断节拍下的 PD1 当前电平。
  2217                              ; 输出: 维护低电平样本计数，并在一次低脉冲结束后换算成 50us tick 喂给解码入口。
  2218                              ; 调试: 先看 R_RFSamplePrev、R_RFLowSampleCnt；一次低电平结束后看 R_RFPulseTicks。
  2219 0000FB1F                     F_RF_Service2KHzSample:		; 2kHz 采样 PD1，把低电平样本数换算成 50us tick 后送入 F_RF_FeedLowPulseTicks
  2220 0000FB1F AD A5 01            		LDA		R_RFStatus
  2221 0000FB22 29 09               		AND		#(D_RFLongRecv+D_RFRecvBusy)
  2222 0000FB24 D0 0D               		BNE		RF_Service2KHzSample_Active
  2223                              		; 未处于接收状态时只同步输入电平，不累计脉宽。
  2224 0000FB26 A5 13               		LDA		P_IO_PortD_Data
  2225 0000FB28 29 02               		AND		#D_Bit1
  2226 0000FB2A 8D BE 01            		STA		R_RFSamplePrev
  2227 0000FB2D A9 00               		LDA		#00H
  2228 0000FB2F 8D BF 01            		STA		R_RFLowSampleCnt
  2229 0000FB32 60                  		RTS
  2230                              
  2231 0000FB33                     RF_Service2KHzSample_Active:
  2232 0000FB33 A5 13               		LDA		P_IO_PortD_Data
  2233 0000FB35 29 02               		AND		#D_Bit1
  2234                              		; PD1 为高时，如果上一拍也是高，就什么都不做；如果上一拍是低，就表示一段低脉冲结束了。
  2235 0000FB37 F0 0B               		BEQ		RF_Service2KHzSample_Low
  2236 0000FB39 AD BE 01            		LDA		R_RFSamplePrev
  2237 0000FB3C F0 21               		BEQ		RF_Service2KHzSample_LowEnd
  2238 0000FB3E A9 02               		LDA		#D_Bit1
  2239 0000FB40 8D BE 01            		STA		R_RFSamplePrev
  2240 0000FB43 60                  		RTS
  2241                              
  2242 0000FB44                     RF_Service2KHzSample_Low:
  2243 0000FB44 AD BE 01            		LDA		R_RFSamplePrev
  2244 0000FB47 F0 0B               		BEQ		RF_Service2KHzSample_LowHold
  2245                              		; 刚从高跳低，开始统计这段低电平持续了多少个 2kHz 样本。
  2246 0000FB49 A9 00               		LDA		#00H
  2247 0000FB4B 8D BE 01            		STA		R_RFSamplePrev
  2248 0000FB4E A9 01               		LDA		#01H
  2249 0000FB50 8D BF 01            		STA		R_RFLowSampleCnt
  2250 0000FB53 60                  		RTS
  2251                              
  2252 0000FB54                     RF_Service2KHzSample_LowHold:
  2253 0000FB54 AD BF 01            		LDA		R_RFLowSampleCnt
  2254 0000FB57 C9 FE               		CMP		#0FEH
  2255                              		; 饱和保护，防止异常长低电平把计数溢出。
  2256 0000FB59 B0 03               		BCS		RF_Service2KHzSample_End
  2257 0000FB5B EE BF 01            		INC		R_RFLowSampleCnt
  2258 0000FB5E                     RF_Service2KHzSample_End:
  2259 0000FB5E 60                  		RTS
  2260                              
  2261 0000FB5F                     RF_Service2KHzSample_LowEnd:
  2262 0000FB5F A9 02               		LDA		#D_Bit1
  2263 0000FB61 8D BE 01            		STA		R_RFSamplePrev
  2264 0000FB64 AD BF 01            		LDA		R_RFLowSampleCnt
  2265 0000FB67 F0 F5               		BEQ		RF_Service2KHzSample_End
  2266                              		; 2kHz 一个样本是 500us，这里乘以 10 换算成 50us tick。
  2267 0000FB69 0A                  		ASL		A
  2268 0000FB6A 8D BD 01            		STA		R_RFPulseTicks
  2269 0000FB6D 0A                  		ASL		A
  2270 0000FB6E 0A                  		ASL		A
