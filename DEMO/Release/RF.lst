   621                      <       ;-----------------------------------------------------------------------------
   622                      <       ; Macro Name:	%FillSram
   623                      <       ; Description:	Fill data to SRAM whole space
   624                      <       ; Input:		mData
   625                      <       ;-----------------------------------------------------------------------------	
   626                      <       %FillSram		.MACRO	mData
   627                      <       		
   628                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   629                      <       		STA		C_SramAddrStart
   630                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   631                      <       		STA		C_SramAddrStart+1
   632                      <       		
   633                      <       		LDX     #0
   634                      <       ?L_FillLoop#:
   635                      <               LDA     mData
   636                      <       		STA     (C_SramAddrStart,X)
   637                      <       		
   638                      <       		LDA     C_SramAddrStart+1
   639                      <       		CMP     #.HIGH.C_SramAddrEnd
   640                      <       		BCC     ?L_IncSramAddr#
   641                      <       		LDA     C_SramAddrStart
   642                      <       		CMP     #.LOW.C_SramAddrEnd
   643                      <       		BCS     ?L_End#
   644                      <       		
   645                      <       ?L_IncSramAddr#:    ;Increase sram address
   646                      <               INC     C_SramAddrStart
   647                      <       		BNE     ?L_FillLoop#
   648                      <       		INC     C_SramAddrStart+1
   649                      <       		%WatchDogClear
   650                      <               JMP     ?L_FillLoop#
   651                      <       ?L_End#:
   652                      <               
   653                      <               LDA     mData
   654                      <               STA     C_SramAddrStart
   655                      <               STA     C_SramAddrStart+1
   656                      <               
   657                      <               LDX		#00H
   658                      <       ?L_HSRAMloop:
   659                      <       		LDA		mData
   660                      <       		STA		$180,X
   661                      <       		INX	
   662                      <       		CPX		#80H
   663                      <       		BNE		?L_HSRAMloop
   664                      <       		
   665                      <       	.ENDM
   666                      <       	
   667                      <       ;-----------------------------------------------------------------------------
   668                      <       ; Macro Name:	%ClrSRAM
   669                      <       ; Description:	Clear SRAM $60 ~ $95F
   670                      <       ;-----------------------------------------------------------------------------	
   671                      <       %ClrSRAM:	.MACRO
   672                      <       
   673                      <       		%FillSram	#0
   674                      <       
   675                      <       	.ENDM
   676                      <       ;-----------------------------------------------------------------------------
   677                      <       ;-----------------------------------------------------------------------------
   678                      <       ; Macro Name:	%FillLcdDpram
   679                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   680                      <       ;-----------------------------------------------------------------------------
   681                      <       %FillLcdDpram	.MACRO	mData
   682                      <       		
   683                      <       		%WatchDogClear
   684                      <       		LDX		#00H
   685                      <       		LDY		#00H
   686                      <       ?L_ClrDpramLoop:
   687                      <       		LDA     mData
   688                      <       		STA		$3E00,X
   689                      <       		INY
   690                      <       		CPY		#04H
   691                      <       		BNE		?L_ClrDpramLoopI
   692                      <       		LDY		#00H
   693                      <       		TXA
   694                      <       		CLC
   695                      <       		ADC		#0CH
   696                      <       		TAX
   697                      <       ?L_ClrDpramLoopI:		
   698                      <       		INX
   699                      <       		CPX		#80H
   700                      <       		BNE		?L_ClrDpramLoop
   701                      <       	.ENDM
