  2273 0000FB73 20 DB FA            		JSR		F_RF_FeedLowPulseTicks
  2274 0000FB76 A9 00               		LDA		#00H
  2275 0000FB78 8D BF 01            		STA		R_RFLowSampleCnt
  2276 0000FB7B 60                  		RTS
  2277                              
  2278                              ; 输入: 当前帧缓存 R_RFPacket0~4 已经收满 36bit。
  2279                              ; 输出: 双帧确认通过后按通道和 ID 规则落库，并在成功时统一走接收成功收口。
  2280                              ; 调试: 先看 R_RFPacket0~4，再看 R_RFPending0~4、R_RFRequestChannel、R_RF1IdL~R_RF3IdL。
  2281 0000FB7C                     F_RF_ParsePacket:			; 满 36bit 后做双帧确认，再按通道码和已绑定 ID 决定是否落库
  2282 0000FB7C AD AF 01            		LDA		R_RFBitCnt
  2283 0000FB7F C9 24               		CMP		#C_RFPacketBits36
  2284 0000FB81 90 5B               		BCC		RF_ParsePacket_End
  2285                              		; 旧逻辑在单帧满 36bit 后立即落库并判成功，和协议“连续两帧一致后才有效”冲突。
  2286 0000FB83 20 E0 F9            		JSR		F_RF_IsCurrentFrameConfirmed
  2287 0000FB86 90 53               		BCC		RF_ParsePacket_Clear
  2288                              
  2289                              		; Packet1 bit5~4 是通道码：30h/00h 走 CH1，20h 走 CH2，其余按 CH3 处理。
  2290 0000FB88 AD B1 01            		LDA		R_RFPacket1
  2291 0000FB8B 29 30               		AND		#30H
  2292 0000FB8D C9 30               		CMP		#30H
  2293 0000FB8F F0 0B               		BEQ		RF_ParsePacket_CH1
  2294 0000FB91 C9 00               		CMP		#00H
  2295 0000FB93 F0 07               		BEQ		RF_ParsePacket_CH1
  2296 0000FB95 C9 20               		CMP		#20H
  2297 0000FB97 F0 19               		BEQ		RF_ParsePacket_CH2
  2298 0000FB99 4C C8 FB            		JMP		RF_ParsePacket_CH3
  2299                              
  2300 0000FB9C                     RF_ParsePacket_CH1:
  2301                              		; 先把这帧归到 CH1，再做“是否允许写 CH1”的 ID/NeedPair 判断。
  2302 0000FB9C A9 01               		LDA		#D_RFCh1
  2303 0000FB9E 8D A8 01            		STA		R_RFRequestChannel
  2304 0000FBA1 20 19 FA            		JSR		F_RF_IsRequestChannelPacketAccepted
  2305 0000FBA4 90 35               		BCC		RF_ParsePacket_Clear
  2306                              		; 验收通过才落库，并收口这次接收窗口。
  2307 0000FBA6 20 1D FC            		JSR		F_RF_LoadPacketToRequestChannel
  2308 0000FBA9 20 B6 F9            		JSR		F_RF_ClearPendingFrame
  2309 0000FBAC 20 58 F7            		JSR		F_RF_OnReceiveOK
  2310 0000FBAF 4C DB FB            		JMP		RF_ParsePacket_Clear
  2311                              
  2312 0000FBB2                     RF_ParsePacket_CH2:
  2313 0000FBB2 A9 02               		LDA		#D_RFCh2
  2314 0000FBB4 8D A8 01            		STA		R_RFRequestChannel
  2315 0000FBB7 20 19 FA            		JSR		F_RF_IsRequestChannelPacketAccepted
  2316 0000FBBA 90 1F               		BCC		RF_ParsePacket_Clear
  2317 0000FBBC 20 1D FC            		JSR		F_RF_LoadPacketToRequestChannel
  2318 0000FBBF 20 B6 F9            		JSR		F_RF_ClearPendingFrame
  2319 0000FBC2 20 58 F7            		JSR		F_RF_OnReceiveOK
  2320 0000FBC5 4C DB FB            		JMP		RF_ParsePacket_Clear
  2321                              
  2322 0000FBC8                     RF_ParsePacket_CH3:
  2323 0000FBC8 A9 03               		LDA		#D_RFCh3
  2324 0000FBCA 8D A8 01            		STA		R_RFRequestChannel
  2325 0000FBCD 20 19 FA            		JSR		F_RF_IsRequestChannelPacketAccepted
  2326 0000FBD0 90 09               		BCC		RF_ParsePacket_Clear
  2327 0000FBD2 20 1D FC            		JSR		F_RF_LoadPacketToRequestChannel
  2328 0000FBD5 20 B6 F9            		JSR		F_RF_ClearPendingFrame
  2329 0000FBD8 20 58 F7            		JSR		F_RF_OnReceiveOK
