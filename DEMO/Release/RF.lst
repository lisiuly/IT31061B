  2417 0000FC4E 29 0F               		AND		#0FH
  2418 0000FC50 0A                  		ASL		A
  2419 0000FC51 0A                  		ASL		A
  2420 0000FC52 0A                  		ASL		A
  2421 0000FC53 0A                  		ASL		A
  2422 0000FC54 9D C7 01            		STA		R_RF1Hum,X
  2423 0000FC57 AD B4 01            		LDA		R_RFPacket4
