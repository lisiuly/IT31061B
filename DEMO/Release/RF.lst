  2198                              		; 1ms 低脉宽判成 bit1。
  2199 0000FB0B 20 7F FA            		JSR		F_RF_AppendBit1
  2200 0000FB0E 4C 14 FB            		JMP		RF_FeedLowPulse_AfterBit
  2201                              
  2202 0000FB11                     RF_FeedLowPulse_Bit0:
  2203                              		; 2ms 低脉宽判成 bit0。
  2204 0000FB11 20 74 FA            		JSR		F_RF_AppendBit0
  2205                              
  2206 0000FB14                     RF_FeedLowPulse_AfterBit:
  2207 0000FB14 AD AF 01            		LDA		R_RFBitCnt
  2208 0000FB17 C9 24               		CMP		#C_RFPacketBits36
  2209 0000FB19 90 03               		BCC		RF_FeedLowPulse_End
  2210                              		; 满 36bit 后立刻转解包，避免继续吞掉后面重复发的同帧数据。
  2211 0000FB1B 4C 7C FB            		JMP		F_RF_ParsePacket
