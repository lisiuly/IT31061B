  2407 0000FC3C AD B1 01            		LDA		R_RFPacket1
  2408 0000FC3F 29 08               		AND		#08H
  2409 0000FC41 F0 08               		BEQ		RF_LoadPacketTempReady
  2410 0000FC43 BD C5 01            		LDA		R_RF1TempH,X
  2411 0000FC46 09 F0               		ORA		#0F0H
  2412 0000FC48 9D C5 01            		STA		R_RF1TempH,X
  2413 0000FC4B                     RF_LoadPacketTempReady:
