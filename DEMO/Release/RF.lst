  1241                              
  1242                              ;==========================================
  1243                              ; code starting 
  1244                              ;==========================================
  1245 0000F56C                     .CODE
  1246                              
  1247                              ; 输入: 无。
  1248                              ; 输出: 清所有 RF 运行态，三路通道都回到 NeedPair，默认当前显示 CH1。
  1249                              ; 调试: 上电后先看 R_RFStatus、R_RFChannel、R_RFViewChannel、R_RF1Flags~R_RF3Flags。
  1250 0000F56C                     F_RF_Init:					; RF模块初始化
  1251 0000F56C A9 00               		LDA		#00H
  1252 0000F56E 8D A5 01            		STA		R_RFStatus
  1253 0000F571 8D A8 01            		STA		R_RFRequestChannel
  1254 0000F574 8D A9 01            		STA		R_RFLongRecvTm
  1255 0000F577 8D AA 01            		STA		R_RFAutoSwitchTm
  1256 0000F57A 8D AB 01            		STA		R_RFRecvWindowTm
  1257 0000F57D 8D AF 01            		STA		R_RFBitCnt
  1258 0000F580 8D B6 01            		STA		R_RFPendingValid
  1259 0000F583 8D BC 01            		STA		R_RFCaptureActive
  1260 0000F586 8D BE 01            		STA		R_RFSamplePrev
  1261 0000F589 8D BF 01            		STA		R_RFLowSampleCnt
  1262 0000F58C 8D C0 01            		STA		R_RFHalfSecDiv
  1263 0000F58F 8D C9 01            		STA		R_RF1MissMin
  1264 0000F592 8D CA 01            		STA		R_RF1RetryStage
  1265 0000F595 8D CB 01            		STA		R_RF1RetryTm
