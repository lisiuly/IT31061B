  2392 0000FC20 20 43 F6            		JSR		F_RF_LoadSelectedChannelOffsets
  2393                              
  2394 0000FC23                     RF_LoadPacketToChannelCommon:
  2395 0000FC23 A9 00               		LDA		#00H
