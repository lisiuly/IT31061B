  2370 0000FBFF 20 DF FB            		JSR		F_RF_BuildPacketBitMask
  2371 0000FC02 0D B2 01            		ORA		R_RFPacket2
  2372 0000FC05 8D B2 01            		STA		R_RFPacket2
