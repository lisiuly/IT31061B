   693                      <       %F_Initinal_IO	.MACRO
   694                      <       		LDA		#00000000b		
   695                      <       		STA		P_IO_PortA_Dir
   696                      <       		LDA		#00000000b		
   697                      <       		STA		P_IO_PortA_Data	
   698                      <       		
   699                      <       		LDA		#0
   700                      <       		STA		P_IO_PortB_Attrib
   701                      <       		LDA		#00000011b		
   702                      <       		STA		P_IO_PortB_Dir
   703                      <       		LDA		#00000000b		
   704                      <       		STA		P_IO_PortB_Data		;PB1隙貯匂⇧PB0嘘高
   705                      <       
