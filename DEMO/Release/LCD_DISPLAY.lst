   708                      <       		LDA		#00000000b
   709                      <       		STA		P_IO_PortC_Data	
   710                      <       		
   711                      <       		LDA		#00h
   712                      <       		STA		P_IO_PortD_Attrib		
   713                      <       		LDA		#00000001b		
   714                      <       		STA		P_IO_PortD_Dir
   715                      <       		STA		P_IOD_DIR_Map	
   716                      <       		LDA		#00000010b
   717                      <       		STA		P_IO_PortD_Data		
   718                      <       		STA		R_PortD_Data_Buf
   719                      <       
   720                      <       		LDA		#00000000b			;PE0/PE1/PE2 畠何恬葎梓囚補秘
   721                      <       		STA		P_IO_PortE_Dir
   722                      <       		LDA		#00000000b			
   723                      <       		STA		P_IO_PortE_Data		
   724                      <       		
   725                      <       		LDA		#00
   726                      <       		STA		P_IO_Ctrl			;all as normal IO
   727                      <       		.ENDM
