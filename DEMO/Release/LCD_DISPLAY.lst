  2643                              ;===================================================================
  2644                              ; Shared record initialization helper, still used by KEY.asm.
  2645                              ;===================================================================
  2646                              .PUBLIC			F_Start_RFCMM_Value
  2647                              ; 補秘: 輝念厮将彈姥挫議片坪梁物業𠮟幣産贋嚥憲催炎崗。
  2648                              ; 補竃: 兜兵晒梁物業恷寄/恷弌芝村産贋⇧工貧窮朔自峙嚥芝村匈鹸喘。
  2649                              ; 距編: 心 R_TempMin/Max、R_MIN/MAXDispTemper_F、R_HumMin/Max 頁倦瓜輝念峙顕固。
  2650 0000E5E6                     F_Start_RFCMM_Value:
  2651                              	%bitr	R_TempFlag1,(D_MaxTemp+D_MinTemp)
  2652 0000E5E6 AD A4 01          1           lda     R_TempFlag1               ;ex.  
  2653 0000E5E9 29 FC             1           and     #.NOT.(D_MaxTemp+D_MinTemp)         ;  %bitr 10H,_BIT0;  10H.0=0
  2654 0000E5EB 8D A4 01          1           sta     R_TempFlag1
  2655 0000E5EE A9 00               	LDA		#00H
  2656 0000E5F0 AD 9B 01            	LDA		R_DispTemper+0
  2657 0000E5F3 8D 9F 01            	STA		R_TempMin+0
  2658 0000E5F6 8D 9D 01            	STA		R_TempMax+0
  2659 0000E5F9 AD 9C 01            	LDA		R_DispTemper+1
  2660 0000E5FC 8D A0 01            	STA		R_TempMin+1
  2661 0000E5FF 8D 9E 01            	STA		R_TempMax+1
  2662 0000E602 AD 95 01            	LDA		R_DispTemper_F
  2663 0000E605 8D 99 01            	STA		R_MINDispTemper_F
  2664 0000E608 8D 97 01            	STA		R_MAXDispTemper_F
  2665                              
  2666 0000E60B AD 96 01            	LDA		R_DispTemper_F+1
  2667 0000E60E 8D 9A 01            	STA		R_MINDispTemper_F+1
  2668 0000E611 8D 98 01            	STA		R_MAXDispTemper_F+1
  2669                              
  2670 0000E614 AD A1 01            	LDA		R_DispHum
  2671 0000E617 8D A2 01            	STA		R_HumMax
  2672 0000E61A 8D A3 01            	STA		R_HumMin
  2673                              
  2674 0000E61D AD 90 01            	LDA		R_SpecFlag
  2675 0000E620 8D 92 01            	STA		R_TempMax_Sign
  2676 0000E623 8D 91 01            	STA		R_TempMin_Sign
  2677                              
  2678 0000E626 AD A1 00            	LDA		R_TempFlag
  2679 0000E629 29 04               	AND		#D_TempFReg
  2680 0000E62B 0D 92 01            	ORA		R_TempMax_Sign
  2681 0000E62E 8D 92 01            	STA		R_TempMax_Sign
  2682                              
  2683 0000E631 AD A1 00            	LDA		R_TempFlag
  2684 0000E634 29 04               	AND		#D_TempFReg
  2685 0000E636 0D 91 01            	ORA		R_TempMin_Sign
  2686 0000E639 8D 91 01            	STA		R_TempMin_Sign
  2687 0000E63C 60                  	RTS
