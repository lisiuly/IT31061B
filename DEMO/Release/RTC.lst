   406                      <       		LDA		#0
   407                      <       		
   408                      <       ?L_ClrLoop#:
   409                      <       		STA		$60,X
   410                      <       		DEX
   411                      <       		BPL		?L_ClrLoop#	
   412                      <       
   413                      <       	.ENDM
