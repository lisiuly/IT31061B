   744 00000083                     .PAGE0
   745                              ;
   746 00000083 FF FF FF            RTC		             .DS	 3
   747                              	; RTC+0 --> Hour (BCD)
   748                              	; RTC+1 --> Minute (BCD)
   749                              	; RTC+2 --> Second (BCD)
   750                              	;  -------------------------------------------
   751                              	; |             | RTC+0   | RTC+1   | RTC+2   |
   752                              	; |-------------|---------|---------|---------|
   753                              	; | Description | Hour    | Minute  | Second  |
   754                              	; |	            | 00 - 23 | 00 - 59 | 00 - 59 |        
   755                              	; |		        | (BCD)   | (BCD)   | (BCD)   |         |
   756                              	;  -------------------------------------------
   757                              ;
   758 00000086 FF                  R_TimeStatus	    .DS	    1       ;(.7 reserved!!!)
   759                              HalfSecToggle			EQU		01000000B
   760                              AddSecondOnly			EQU		00100000B
   761                              AddOthers				EQU		00010000B
   762 00000087 FF                  TR00				.DS	    1
   763 00000088 FF                  TR01				.DS		1
   764                              ;------------------------------------------------------------------------------
   765 0000E231                     .CODE
   766                              ;==============================================================================
   767 0000E231                     F_RealTimeClock:	;Level 1
   768 0000E231 A9 40               	LDA	#HalfSecToggle
   769 0000E233 45 86               	EOR	R_TimeStatus
   770 0000E235 85 86               	STA	R_TimeStatus
   771 0000E237 29 40               	AND	#HalfSecToggle
   772 0000E239 D0 19               	BNE	L_Time99	; 0.5 second only!!!
   773                              ;	1 second!!!
   774 0000E23B 20 6D E2            	JSR	INC_SEC	;Level 2  
   775 0000E23E 90 0E               	BCC	L_OnlySEcAdd
   776                              
   777 0000E240 20 72 E2            	JSR	INC_MIN	;Level 2
   778 0000E243 90 05               	BCC	L_OnlyMinAdd
   779                              	
   780                              	
   781 0000E245 20 7F E2            	JSR	INC_HR	;Level 2
   782                              	; 28ąć¸ńµ±Ç°˛úĆ·Ö»Ďű·ŃĘ±·ÖĂëÓë AddOthers ±ęÖľŁ¬˛»ÔŮ¶Á DATE/ĐÇĆÚˇŁ
   783                              	; ľÉĘ±ÖÓ˛úĆ·µÄČŐĆÚ˝řÎ»Á´ĎČĆÁ±Î±ŁÁôŁ¬±ÜĂâĽĚĐřÎ¬»¤Î´ĘąÓĂ×´Ě¬ˇŁ
   784 0000E248 90 00               	BCC	L_OnlyHourAdd
   785                              	; JSR	INC_DAT	;Level 3
   786                              	; BCC	L_Time01
   787                              	; JSR	INC_MON	;Level 2
   788                              	; BCC	L_Time01
   789                              	; JSR	INC_YER	;Level 2
   790 0000E24A                     L_Time01:
   791                              	; JSR	WEEKCAL	;Level 3
   792                              	; JSR	MAXDCMP	;Level 3
   793 0000E24A                     L_OnlyHourAdd:
   794 0000E24A                     L_OnlyMinAdd:	
   795 0000E24A A9 10               	LDA	#AddOthers
   796 0000E24C D0 02               	BNE	L_AddAll	;@JMP
   797 0000E24E                     L_OnlySEcAdd:
   798 0000E24E A9 20               	LDA	#AddSecondOnly
   799 0000E250                     L_AddAll:
   800 0000E250 05 86               	ORA	R_TimeStatus
   801 0000E252 85 86               	STA	R_TimeStatus
   802 0000E254                     L_Time99:
   803 0000E254 60                  	RTS
   804                              ;
   805                              ;------------------------------------------------------------------------------
   806                              ;
   807 0000E255                     F_ClearIncStatus:
   808 0000E255 A9 CF               	LDA	#(.NOT.(AddSecondOnly+AddOthers))
   809 0000E257 25 86               	AND	R_TimeStatus
   810 0000E259 85 86               	STA	R_TimeStatus
   811 0000E25B 60                  	RTS
   812                              ;
   813                              ;------------------------------------------------------------------------------
   814                              ;
   815 0000E25C                     F_ResetRealTimeClock:          ;żŞ»úĎÔĘľłőÖµ(Ä¬ČĎÖµ)
   816 0000E25C A9 00               	LDA	#00H
   817 0000E25E 85 83               	STA	RTC+0
   818 0000E260 A9 00               	LDA	#00H
   819 0000E262 85 84               	STA	RTC+1
   820 0000E264 A9 00               	LDA	#00H		;test use
   821 0000E266 85 85               	STA	RTC+2	
   822 0000E268 A9 10               	LDA	#AddOthers
   823 0000E26A 85 86               	STA	R_TimeStatus
   824 0000E26C 60                  	RTS
   825                              
   826 0000E26D                     INC_SEC:
   827 0000E26D A2 85               	LDX	#RTC+2   ;second
   828 0000E26F 4C 74 E2            	JMP	INC_MIN1
   829 0000E272                     INC_MIN:
   830 0000E272 A2 84               	LDX	#RTC+1   ;Minute
   831 0000E274                     INC_MIN1:
   832 0000E274 A9 59               	LDA	#59H
   833 0000E276 85 88               	STA	TR01
   834 0000E278                     INC_MIN2:
   835 0000E278 A9 00               	LDA	#00
   836 0000E27A 85 87               	STA	TR00
   837 0000E27C 4C 88 E2            	JMP	INC_DET
   838                              ;
   839 0000E27F                     INC_HR:
   840 0000E27F A2 83               	LDX	#RTC+0
   841 0000E281                     INC_HR1:
   842 0000E281 A9 23               	LDA	#23H
   843 0000E283                     INC_HR2:
   844 0000E283 85 88               	STA	TR01
   845 0000E285 4C 78 E2            	JMP	INC_MIN2
   846 0000E288                     INC_DET:
   847 0000E288 A5 86               	LDA	R_TimeStatus
   848 0000E28A 30 13               	BMI	DEC_DET
   849 0000E28C B5 00               	LDA	0,X
   850 0000E28E C5 88               	CMP	TR01
   851 0000E290 B0 07               	BCS	INC_D01
   852 0000E292 A9 01               	LDA	#01
   853 0000E294 85 87               	STA	TR00
   854 0000E296 4C B1 E2            	JMP	ADC_RT
   855 0000E299                     INC_D01:
   856 0000E299 A5 87               	LDA	TR00
   857 0000E29B                     INC_D02:
   858 0000E29B 95 00               	STA	0,X
   859 0000E29D 38                  	SEC
   860 0000E29E 60                  	RTS
   861                              ;
   862 0000E29F                     DEC_DET:
   863 0000E29F B5 00               	LDA	0,X
   864 0000E2A1 C5 87               	CMP	TR00
   865 0000E2A3 F0 07               	BEQ	DEC_D01
   866 0000E2A5 A9 99               	LDA	#99H
   867 0000E2A7 85 87               	STA	TR00
   868 0000E2A9 4C B1 E2            	JMP	ADC_RT
   869 0000E2AC                     DEC_D01:
   870 0000E2AC A5 88               	LDA	TR01
   871 0000E2AE 4C 9B E2            	JMP	INC_D02
   872                              ;
   873                              ; Use:	TR00 - variable
   874                              ;	TR01 - (X)
   875                              ;	(X) = TR01+TR00
   876 0000E2B1                     ADC_RT:
   877 0000E2B1 18                  	CLC
   878 0000E2B2 B5 00               	LDA	0,X
   879 0000E2B4 85 88               	STA	TR01
   880 0000E2B6 29 0F               	AND	#00001111B
   881 0000E2B8 65 87               	ADC	TR00
   882 0000E2BA 69 06               	ADC	#6
   883 0000E2BC 45 87               	EOR	TR00
   884 0000E2BE 29 F0               	AND	#11110000B
   885 0000E2C0 F0 02               	BEQ	L_TimeAdd01
   886 0000E2C2 A9 06               	LDA	#6
   887 0000E2C4                     L_TimeAdd01:
   888 0000E2C4 65 87               	ADC	TR00
   889 0000E2C6 65 88               	ADC	TR01
   890 0000E2C8 B0 04               	BCS	L_TimeAdd02
   891 0000E2CA C9 9A               	CMP	#9AH
   892 0000E2CC 90 02               	BCC	L_TimeAdd03
   893 0000E2CE                     L_TimeAdd02:
   894 0000E2CE 69 5F               	ADC	#05FH
   895 0000E2D0                     L_TimeAdd03:
   896 0000E2D0 95 00               	STA	0,X
   897 0000E2D2 18                  	CLC
   898 0000E2D3 60                  	RTS
