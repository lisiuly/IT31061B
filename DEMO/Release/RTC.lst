   185                      <       ;----------------------------------------------------------
   186                      <       ;/***********************************************/
   187                      <       ;         i.L=1 
   188                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   189                      <                 lda     i               ;ex.  
   190                      <                 ora     #L              ;  %bits 10H,_BIT0
   191                      <       		                   ;  10H.0=1
   192                      <                 sta     i               ;
   193                      <                .ENDM    
   194                      <       
   195                      <       ;/***********************************************/
   196                      <       ;         i.L=0
   197                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   198                      <                 lda     i               ;ex.  
   199                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   200                      <                 sta     i
   201                      <                .ENDM    
   202                      <       
   203                      <       ;/***********************************************/
   204                      <       ;         if(i.L==1) goto N
   205                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   206                      <                 lda     i               ;ex.   
   207                      <                 and     #L              ;  %btst 10H,_BIT0,N
   208                      <                 bne     N               ;  if(10H.0=1) goto N 
   209                      <                .ENDM    
   210                      <                                         
   211                      <       ;/***********************************************/
   212                      <       ;         if(i.L==0) goto N
   213                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   214                      <                 lda     i               ;ex.   
   215                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   216                      <                 beq     N               ;  if(10H.0=0) goto N 
   217                      <                .ENDM    
   218                      <       ;/***********************************************/
   219                      <       ;         if(i==#0) goto N
   220                      <       %jz:     .MACRO   i,N             ;BYTE i;
   221                      <                 lda     i               ;ex.
   222                      <                 beq     N               ;  %jz 10H,N
   223                      <                .ENDM                    ;  if(10H==#0) goto N
   224                      <       
   225                      <       ;/***********************************************/
   226                      <       ;         if(i!=#0) goto N
   227                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   228                      <                 lda     i               ;ex.
   229                      <                 bne     N               ;  %jnz 10H,N
   230                      <                .ENDM                    ;  if($10!=#0) goto N
