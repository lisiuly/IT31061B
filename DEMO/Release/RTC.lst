   262                      <       ; Macro Name:	%InitLCD
   263                      <       ; Description:	Initialize LCD configuration after power on
   264                      <       ;-----------------------------------------------------------------------------	
   265                      <       %InitLCD:		.MACRO
   266                      <       
   267                      <       		LDA		#(D_Duty_1_5+D_Bias_1_3+D_ScanEnable)
   268                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   269                      <       		
   270                      <       		LDA     #D_VLCD_28            ;VLCD = 4.5V (max value)
   271                      <       ;		LDA		#D_VLCD_VDD
   272                      <       		STA     P_LCD_VLCD_Ctrl
   273                      <       	
   274                      <       	.ENDM
   275                      <       ;-----------------------------------------------------------------------------
   276                      <       ; Macro Name:	%FillSram
   277                      <       ; Description:	Fill data to SRAM whole space
   278                      <       ; Input:		mData
   279                      <       ;-----------------------------------------------------------------------------	
   280                      <       %FillSram		.MACRO	mData
   281                      <       		
   282                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   283                      <       		STA		C_SramAddrStart
   284                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   285                      <       		STA		C_SramAddrStart+1
   286                      <       		
   287                      <       		LDX     #0
   288                      <       ?L_FillLoop#:
   289                      <               LDA     mData
   290                      <       		STA     (C_SramAddrStart,X)
   291                      <       		
   292                      <       		LDA     C_SramAddrStart+1
   293                      <       		CMP     #.HIGH.C_SramAddrEnd
   294                      <       		BCC     ?L_IncSramAddr#
   295                      <       		LDA     C_SramAddrStart
   296                      <       		CMP     #.LOW.C_SramAddrEnd
   297                      <       		BCS     ?L_End#
   298                      <       		
   299                      <       ?L_IncSramAddr#:    ;Increase sram address
   300                      <               INC     C_SramAddrStart
   301                      <       		BNE     ?L_FillLoop#
   302                      <       		INC     C_SramAddrStart+1
   303                      <       		%WatchDogClear
   304                      <               JMP     ?L_FillLoop#
   305                      <       ?L_End#:
   306                      <               
   307                      <               LDA     mData
   308                      <               STA     C_SramAddrStart
   309                      <               STA     C_SramAddrStart+1
   310                      <               
   311                      <               LDX		#00H
   312                      <       ?L_HSRAMloop:
   313                      <       		LDA		mData
   314                      <       		STA		$180,X
   315                      <       		INX	
   316                      <       		CPX		#80H
   317                      <       		BNE		?L_HSRAMloop
   318                      <       		
   319                      <       	.ENDM
   320                      <       	
   321                      <       ;-----------------------------------------------------------------------------
   322                      <       ; Macro Name:	%ClrSRAM
   323                      <       ; Description:	Clear SRAM $60 ~ $95F
   324                      <       ;-----------------------------------------------------------------------------	
   325                      <       %ClrSRAM:	.MACRO
   326                      <       
   327                      <       		%FillSram	#0
   328                      <       
   329                      <       	.ENDM
   330                      <       ;-----------------------------------------------------------------------------
   331                      <       ;-----------------------------------------------------------------------------
   332                      <       ; Macro Name:	%FillLcdDpram
   333                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   334                      <       ;-----------------------------------------------------------------------------
   335                      <       %FillLcdDpram	.MACRO	mData
   336                      <       		
   337                      <       		%WatchDogClear
   338                      <       		LDX		#00H
   339                      <       		LDY		#00H
   340                      <       ?L_ClrDpramLoop:
   341                      <       		LDA     mData
   342                      <       		STA		$3E00,X
   343                      <       		INY
   344                      <       		CPY		#04H
   345                      <       		BNE		?L_ClrDpramLoopI
   346                      <       		LDY		#00H
   347                      <       		TXA
   348                      <       		CLC
   349                      <       		ADC		#0CH
   350                      <       		TAX
   351                      <       ?L_ClrDpramLoopI:		
   352                      <       		INX
   353                      <       		CPX		#80H
   354                      <       		BNE		?L_ClrDpramLoop
   355                      <       	.ENDM
