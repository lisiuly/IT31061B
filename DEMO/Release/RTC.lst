    42                      <       ;Macro Name: %M_ClearWatchDog
    43                      <       ;Purpose: Clear Watchdog
    44                      <       ;Destroy: A
    45                      <       ;;============================================================================
    46                      <       %M_ClearWatchDog:		.MACRO 
    47                      <       	LDA		#D_WDT_Clear
    48                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
    49                      <       	.ENDM
    50                      <       ;;============================================================================
    51                      <       ;Macro Name: %M_DisAllInt
    52                      <       ;Purpose: Disable all interrupt 
    53                      <       ;Destroy: A
    54                      <       ;;============================================================================
    55                      <       %F_InitINT:		.MACRO
    56                      <       		LDA		#00000111b		;2HZ Ł¨bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
    57                      <       		STA		P_TIMER_TimeBase_Sel		
    58                      <       		LDA		#D_2KHzInt+D_128HzInt+D_TMBAInt+D_TMBBInt;+D_Timer0Int
    59                      <       		STA		P_INT_Ctrl
    60                      <       		LDA		#00
    61                      <       		STA		P_INT_Ctrl2		;disable TMR1 INT
    62                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
    63                      <       ;		STA		P_TIMER_Timer0_Ctrl
    64                      <       ;		LDA		#0xC8
    65                      <       ;		LDA		#0xFC
    66                      <       ;		STA		P_TIMER_TM0Data_LB		;8k
    67                      <       ;		LDA		#0xFF
    68                      <       ;		STA		P_TIMER_TM0Data_HB
    69                      <       	.ENDM
