    99                      <       ;		%M_ClearWatchDog
   100                      <       ;		LDX		#00H
   101                      <       ;		LDA     mData
   102                      <       ;?L_ClrDpramLoop:
   103                      <       ;		STA		$50,X
   104                      <       ;		INX
   105                      <       ;		CPX		#10H
   106                      <       ;		BNE		?L_ClrDpramLoop	
   107                      <       ;
   108                      <       ;	.ENDM
