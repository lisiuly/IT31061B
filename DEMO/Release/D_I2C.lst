   388 000000B8 FF                  P_IOB_DIR_Map		.DS	1		;
   389 000000B9 FF                  P_IOC_DIR_Map		.DS	1		;
   390 000000BA FF                  P_IOD_DIR_Map		.DS	1		;
   391 000000BB FF                  P_IOA_DIR_Map		.DS	1	
