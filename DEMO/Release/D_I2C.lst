   705                              .PUBLIC	F_I2C_WriteData			
   706                              ;~~~~~~~~~~~~~~~~~~~~	
   707 0000F01C                     F_I2C_WriteData: ;扢掘華硊酗僅1 byte; 杅擂酗僅1 word
   708                              ;		STA		R_Wbuff+0
   709 0000F01C 86 B7               		STX		R_Wbuff1		
   710 0000F01E 20 33 EF            		JSR		F_IIC_start		
   711 0000F021 A0 88               		LDY		#(C_SlaveAddr+C_Write)
