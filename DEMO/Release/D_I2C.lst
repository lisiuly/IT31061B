   398                              ;==========================================
   399                              ; code starting 
   400                              ;==========================================
   401 0000EEA5                     .CODE
   402                              ;-------------SetIO Pin------------------------
   403                              ;***************************************
   404 0000EEA5                     B_SDA_0:	;Set SDA output L
   405 0000EEA5 A5 BA               		LDA		P_IOD_DIR_Map
   406 0000EEA7 09 10               		ORA		#I2C_SDA
   407 0000EEA9 85 BA               		STA		P_IOD_DIR_Map
   408 0000EEAB 85 11               		STA		P_IO_PortD_Dir
   409 0000EEAD A5 BC               		LDA		R_PortD_Data_Buf
   410 0000EEAF 29 EF               		AND		#.not.I2C_SDA
   411 0000EEB1 85 BC               		STA		R_PortD_Data_Buf
   412 0000EEB3 85 13               		STA		P_IO_PortD_Data
   413 0000EEB5 60                  			RTS			
   414                              ;***************************************
   415                              .public			B_SDA_1
   416 0000EEB6                     B_SDA_1:	;Set SDA output H
   417 0000EEB6 A5 BA               		LDA		P_IOD_DIR_Map
   418 0000EEB8 09 10               		ORA		#I2C_SDA
   419 0000EEBA 85 BA               		STA		P_IOD_DIR_Map
   420 0000EEBC 85 11               		STA		P_IO_PortD_Dir
   421 0000EEBE A5 BC               		LDA		R_PortD_Data_Buf
   422 0000EEC0 09 10               		ORA		#I2C_SDA
   423 0000EEC2 85 BC               		STA		R_PortD_Data_Buf
   424 0000EEC4 85 13               		STA		P_IO_PortD_Data
   425 0000EEC6 60                  			RTS	
   426                              ;***************************************			
   427 0000EEC7                     B_SCL_0:	;Set SCL output L
   428 0000EEC7 A5 BA               		LDA		P_IOD_DIR_Map
   429 0000EEC9 09 08               		ORA		#I2C_SCL
   430 0000EECB 85 BA               		STA		P_IOD_DIR_Map
   431 0000EECD 85 11               		STA		P_IO_PortD_Dir
   432 0000EECF A5 BC               		LDA		R_PortD_Data_Buf
   433 0000EED1 29 F7               		AND		#.not.I2C_SCL
   434 0000EED3 85 BC               		STA		R_PortD_Data_Buf
   435 0000EED5 85 13               		STA		P_IO_PortD_Data
   436 0000EED7 60                  		RTS	
   437                              ;***************************************
   438                              .PUBLIC		B_SCL_1
   439 0000EED8                     B_SCL_1:	;Set SCL output H
   440 0000EED8 A5 BA               		LDA		P_IOD_DIR_Map
   441 0000EEDA 09 08               		ORA		#I2C_SCL
   442 0000EEDC 85 BA               		STA		P_IOD_DIR_Map
   443 0000EEDE 85 11               		STA		P_IO_PortD_Dir
   444 0000EEE0 A5 BC               		LDA		R_PortD_Data_Buf
   445 0000EEE2 09 08               		ORA		#I2C_SCL
   446 0000EEE4 85 BC               		STA		R_PortD_Data_Buf
   447 0000EEE6 85 13               		STA		P_IO_PortD_Data
   448 0000EEE8 60                  		RTS	
   449                              ;***************************************			
   450 0000EEE9                     B_SCLSDA_0:	;Set SCL & SDA output L
   451 0000EEE9 A5 BA               		LDA		P_IOD_DIR_Map
   452 0000EEEB 09 18               		ORA		#I2C_SCL_SDA_VAL
   453 0000EEED 85 BA               		STA		P_IOD_DIR_Map
   454 0000EEEF 85 11               		STA		P_IO_PortD_Dir
   455 0000EEF1 A5 BC               		LDA		R_PortD_Data_Buf
   456 0000EEF3 29 E7               		AND		#.not.I2C_SCL_SDA_VAL
   457 0000EEF5 85 BC               		STA		R_PortD_Data_Buf
   458 0000EEF7 85 13               		STA		P_IO_PortD_Data		;SCL
   459 0000EEF9 60                  		RTS				
   460                              ;***************************************			
   461 0000EEFA                     B_SCLSDA_1:	;Set SCL & SDA output H
   462 0000EEFA A5 BA               		LDA		P_IOD_DIR_Map
   463 0000EEFC 09 18               		ORA		#I2C_SCL_SDA_VAL
   464 0000EEFE 85 BA               		STA		P_IOD_DIR_Map
   465 0000EF00 85 11               		STA		P_IO_PortD_Dir
   466 0000EF02 A5 BC               		LDA		R_PortD_Data_Buf
   467 0000EF04 09 18               		ORA		#I2C_SCL_SDA_VAL
   468 0000EF06 85 BC               		STA		R_PortD_Data_Buf
   469 0000EF08 85 13               		STA		P_IO_PortD_Data		;SCL
   470 0000EF0A 60                  		RTS	
   471                              ;***************************************
   472                              .PUBLIC		B_SDA_F
   473 0000EF0B                     B_SDA_F:	;Release SDA so the slave can drive ACK/data bits
   474 0000EF0B A5 BA               		LDA		P_IOD_DIR_Map
   475 0000EF0D 29 EF               		AND		#.not.I2C_SDA
   476 0000EF0F 85 BA               		STA		P_IOD_DIR_Map
   477 0000EF11 85 11               		STA		P_IO_PortD_Dir
   478 0000EF13 A5 BC               		LDA		R_PortD_Data_Buf
   479 0000EF15 09 10               		ORA		#I2C_SDA
   480 0000EF17 85 BC               		STA		R_PortD_Data_Buf
   481 0000EF19 85 13               		STA		P_IO_PortD_Data		;SDA
   482 0000EF1B 60                  		RTS
