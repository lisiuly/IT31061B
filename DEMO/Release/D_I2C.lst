   713                              ;		JSR		F_ACK	
   714                              		
   715                              ;		LDY		R_Wbuff+0
   716                              ;		JSR		F_IIC_Set8bit
   717                              ;		JSR		F_ACK
   718 0000F026 20 C4 EF            		JSR		F_RACK		
   719 0000F029 A5 C5               		LDA		R_ACK_Err
   720 0000F02B D0 10               		BNE		I2C_Write_Err	; 閉奀/拸茼湘ㄛ泐蛌善渣昫揭燴
   721                              			
   722 0000F02D A4 B7               		LDY		R_Wbuff1		
   723 0000F02F 20 59 EF            		JSR		F_IIC_Set8bit	
   724 0000F032 20 C4 EF            		JSR		F_RACK                    ; 潰聆杅擂茼湘
   725 0000F035 A5 C5               		LDA		R_ACK_Err
   726 0000F037 D0 04               		BNE		I2C_Write_Err            ; 杅擂拸茼湘ㄛ泐蛌善渣昫揭燴		
   727 0000F039 20 46 EF            		JSR		F_IIC_stop
   728                              		
   729 0000F03C 60                  		RTS
   730 0000F03D                     	I2C_Write_Err:
   731 0000F03D 20 46 EF            		JSR		F_IIC_stop
   732 0000F040 60                  		RTS
   733                              ;******************************************************************************************************
   734                              ; 靡    備: F_I2C_ReadData
   735                              ; 怀    ⻌: A->扢掘腔杻忷敵湔け華硊;
   736                              ; 怀    堤:	R_Wbuff+0		
