   752                              ;		JSR		F_IIC_stop		
   753 0000F041 20 33 EF            		JSR		F_IIC_start ; 笭陔ぎ雄I2C軞盄
   754 0000F044 A0 89               		LDY		#(C_SlaveAddr+C_Read)
   755 0000F046 20 59 EF            		JSR		F_IIC_Set8bit
