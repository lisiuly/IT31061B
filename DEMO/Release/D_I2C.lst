   485                              ; 導 PA4/PA5 唳掛腔蛁庋妗珋眒痄壺ㄛ絞ゴ茞璃嘐隅峈 PD3=SCL﹜PD4=SDA﹝
   486 0000EF1C                     F_I2C_Delay:
   487 0000EF1C A9 00               		LDA		#00
   488 0000EF1E 85 0F               	   STA	   P_WDT_Flag_Clear
   489 0000EF20 EA                  		NOP
   490 0000EF21 EA                  		NOP
   491 0000EF22 EA                  		NOP
   492 0000EF23 EA                  		NOP
   493 0000EF24 EA                  		NOP
   494 0000EF25 EA                  		NOP
   495 0000EF26 EA                  		NOP
   496 0000EF27 EA                  		NOP
   497 0000EF28 EA                  		NOP
   498 0000EF29 EA                  		NOP
   499 0000EF2A EA                  		NOP
   500 0000EF2B EA                  		NOP
   501 0000EF2C EA                  		NOP
   502 0000EF2D EA                  		NOP
   503 0000EF2E EA                  		NOP
   504 0000EF2F EA                  		NOP
   505 0000EF30 EA                  		NOP
   506 0000EF31 EA                  		NOP
   507                              
   508 0000EF32 60                  			RTS
   509                              ;=========================================================
   510                              .PUBLIC	F_IIC_start			
   511                              ;****************************************			
   512 0000EF33                     F_IIC_start:	; SCL == H, SDA = H to L
   513 0000EF33 20 FA EE            		JSR		B_SCLSDA_1
   514 0000EF36 20 1C EF            		JSR		F_I2C_Delay
   515 0000EF39 20 1C EF            		JSR		F_I2C_Delay
   516 0000EF3C 20 A5 EE            		JSR		B_SDA_0
   517 0000EF3F 20 1C EF            		JSR		F_I2C_Delay
   518 0000EF42 20 1C EF            		JSR		F_I2C_Delay	
   519 0000EF45 60                  			RTS
   520                              ;=========================================================
   521                              .PUBLIC	F_IIC_stop				
   522                              ;****************************************			
   523 0000EF46                     F_IIC_stop:		; SCL == L, SDA = L to H
   524 0000EF46 20 E9 EE            		JSR		B_SCLSDA_0
   525 0000EF49 20 1C EF            		JSR		F_I2C_Delay
   526 0000EF4C 20 D8 EE            		JSR		B_SCL_1
   527 0000EF4F 20 1C EF            		JSR		F_I2C_Delay
   528 0000EF52 20 B6 EE            		JSR		B_SDA_1
   529 0000EF55 20 1C EF            		JSR		F_I2C_Delay	
   530 0000EF58 60                  			RTS	
   531                              ;=========================================================
   532                              .PUBLIC	F_IIC_Set8bit			
   533                              ;****************************************	
   534 0000EF59                     F_IIC_Set8bit:	; Y = input 8bit data value	
   535 0000EF59 20 C7 EE            		JSR		B_SCL_0
   536 0000EF5C 20 1C EF            		JSR		F_I2C_Delay
   537                              		;X = bit count; Y = be write byte
   538 0000EF5F A2 08               		LDX		#8
   539 0000EF61                     	?loop:	
   540 0000EF61 98                  		TYA               ; 珂參Y樓婥善Aㄛ祥党蜊Y
   541 0000EF62 29 80               		AND		#0x80        ; 枑龰郔詢弇ㄗ0x80=10000000Bㄘ
   542 0000EF64 F0 06               		BEQ		?set_0       ; 郔詢弇峈0 ↙ 楷0
   543 0000EF66                     	?set_1:	
   544 0000EF66 20 B6 EE            		JSR		B_SDA_1		
   545 0000EF69 4C 6F EF            		JMP		?next
   546 0000EF6C                     	?set_0:
   547 0000EF6C 20 A5 EE            		JSR		B_SDA_0
   548 0000EF6F                     	?next:	
   549 0000EF6F 20 1C EF            		JSR		F_I2C_Delay
   550 0000EF72 20 D8 EE            		JSR		B_SCL_1
   551 0000EF75 20 1C EF            		JSR		F_I2C_Delay
   552 0000EF78 20 C7 EE            		JSR		B_SCL_0
   553 0000EF7B 20 1C EF            		JSR		F_I2C_Delay
   554                              		; 痄弇紱釬溫婓郔綴ㄗ瓚剿俇婬痄弇ㄘ
   555 0000EF7E 98                  		TYA
   556 0000EF7F 0A                  		ASL		A			; 酘痄1弇ㄛ袧掘狟珨弇
   557 0000EF80 A8                  		TAY	
   558 0000EF81 CA                  		DEX		
   559 0000EF82 D0 DD               		BNE		?loop	
   560 0000EF84 60                  		RTS	
   561                              ;		TYA
   562                              ;		ASL		A			;植詢善腴羲宎換
   563                              ;	;	LSR		A			;植腴善詢羲宎換
   564                              ;		TAY	
   565                              ;		BCS		?set_1
   566                              ;	?set_0:
   567                              ;		JSR		B_SDA_0
   568                              ;		JMP		?next
   569                              ;	?set_1:	
   570                              ;		JSR		B_SDA_1		
   571                              ;	?next:	
   572                              ;		JSR		F_I2C_Delay
   573                              ;		JSR		B_SCL_1
   574                              ;		JSR		F_I2C_Delay
   575                              ;		JSR		B_SCL_0
   576                              ;		JSR		F_I2C_Delay
   577                              ;		DEX		
   578                              ;		BNE		?loop	
   579                              ;			RTS
   580                              ;=========================================================	
   581                              .PUBLIC	F_IIC_get8bit			
   582                              ;****************************************			
   583 0000EF85                     F_IIC_get8bit:	; Y = output 8bit data value
   584                              		;扢离SDA諳峈Input floating袨怓
   585 0000EF85 20 0B EF            		JSR		B_SDA_F
   586                              		;X桶尨bit腔跺杅,Y桶尨黍堤腔硉
   587 0000EF88 A2 08               		LDX		#8
   588 0000EF8A A0 00               		LDY		#0
   589 0000EF8C                     	?loop:
   590                              		; SCK = 1 and Delay		
   591 0000EF8C 20 D8 EE            		JSR		B_SCL_1
   592 0000EF8F 20 1C EF            		JSR		F_I2C_Delay
   593 0000EF92 20 1C EF            		JSR		F_I2C_Delay
   594                              		; Get SDA and Save to Y
   595 0000EF95 A5 13               		LDA		P_I2C_Dat
   596 0000EF97 29 10               		AND		#I2C_SDA
   597 0000EF99 C9 10               		CMP		#I2C_SDA
   598 0000EF9B 98                  		TYA
   599 0000EF9C 2A                  		ROL		A			;植詢善腴諉彶
   600                              	;	ROR		A			;植腴善詢諉彶
   601 0000EF9D A8                  		TAY
   602                              		;SCK = 0 and Delay
   603 0000EF9E 20 C7 EE            		JSR		B_SCL_0
   604 0000EFA1 20 1C EF            		JSR		F_I2C_Delay	
   605 0000EFA4 20 1C EF            		JSR		F_I2C_Delay
   606                              		; Check finish of 8 bit move out or not
   607 0000EFA7 CA                  		DEX
   608 0000EFA8 D0 E2               		BNE		?loop
   609                              		;扢离SDA output	low, 諉狟懂岆SACK麼SNACK,
   610 0000EFAA 20 A5 EE            		JSR		B_SDA_0		
   611 0000EFAD 60                  			RTS	
   612                              ;=========================================================
   613                              .PUBLIC	F_ACK	;楷冞ACK
   614                              ;****************************************			
   615 0000EFAE                     F_ACK:	;Check ACK & Send ACK [[no check ACK but only wait one scycle]]
   616 0000EFAE 20 A5 EE            		JSR		B_SDA_0
   617 0000EFB1 20 1C EF            		JSR		F_I2C_Delay
   618 0000EFB4 20 D8 EE            		JSR		B_SCL_1
   619 0000EFB7 20 1C EF            		JSR		F_I2C_Delay
   620 0000EFBA 20 C7 EE            		JSR		B_SCL_0
   621 0000EFBD 20 1C EF            		JSR		F_I2C_Delay
   622 0000EFC0 20 1C EF            		JSR		F_I2C_Delay
   623 0000EFC3 60                  			RTS	
   624                              ;=========================================================
   625                              .PUBLIC	F_RACK  ;諉彶ACK
   626                              ;****************************************						
   627 0000EFC4                     F_RACK:
   628 0000EFC4 20 0B EF            		JSR		B_SDA_F
   629 0000EFC7 20 1C EF            		JSR		F_I2C_Delay	
   630                              		;------------------------
   631 0000EFCA A9 00               		LDA		#0		
   632 0000EFCC 85 C5               		STA		R_ACK_Err
   633 0000EFCE 85 C4               		STA		R_ACK_Timeout	
   634 0000EFD0 20 D8 EE            		JSR		B_SCL_1
   635 0000EFD3 20 1C EF            		JSR		F_I2C_Delay
   636 0000EFD6                     	?wait:	
   637 0000EFD6 A9 00               		LDA		#00
   638 0000EFD8 85 0F               	   STA	   P_WDT_Flag_Clear
   639                              
   640 0000EFDA E6 C4               		INC		R_ACK_Timeout
   641                              		
   642 0000EFDC A5 C4               		LDA		R_ACK_Timeout
   643 0000EFDE C9 80               		CMP		#0x80			; 閉奀蓒硉ㄗ褫覃淕ㄛ⺼0x80＞1msㄛ剒⑤饜斕腔F_I2C_Delay奀酗ㄘ
   644 0000EFE0 B0 14               		BCS		?ACK_Timeout
   645                              		
   646 0000EFE2 A5 13               		LDA		P_I2C_Dat	
   647 0000EFE4 29 10               		AND		#I2C_SDA
   648 0000EFE6 D0 EE               		BNE		?wait
   649                              		
   650                              	;	BNE		?FailRACK
   651 0000EFE8 20 C7 EE            		JSR		B_SCL_0
   652 0000EFEB 20 1C EF            		JSR		F_I2C_Delay
   653 0000EFEE 20 1C EF            		JSR		F_I2C_Delay
   654                              		;扢离SDA output	low,
   655 0000EFF1 20 A5 EE            		JSR		B_SDA_0
   656 0000EFF4 38                  		SEC				; ACK received
   657 0000EFF5 60                  		RTS
   658 0000EFF6                     	?ACK_Timeout:
   659 0000EFF6 A9 01               		LDA		#0x01	
   660 0000EFF8 85 C5               		STA		R_ACK_Err
   661 0000EFFA 20 C7 EE            		JSR		B_SCL_0
   662 0000EFFD 20 1C EF            		JSR		F_I2C_Delay
   663 0000F000 20 1C EF            		JSR		F_I2C_Delay
   664 0000F003 20 A5 EE            		JSR		B_SDA_0
   665 0000F006 18                  		CLC				; ACK timeout / NAK
   666 0000F007 60                  		RTS
   667                              
   668                              
   669                              			
   670                              ;=========================================================	
   671                              .PUBLIC F_NACK	;楷冞NACK		
   672                              ;****************************************			
   673 0000F008                     F_NACK: ;Send NACK
   674 0000F008 20 B6 EE            		JSR		B_SDA_1
   675 0000F00B 20 1C EF            		JSR		F_I2C_Delay
   676 0000F00E 20 D8 EE            		JSR		B_SCL_1
   677 0000F011 20 1C EF            		JSR		F_I2C_Delay
   678 0000F014 20 C7 EE            		JSR		B_SCL_0
   679 0000F017 20 1C EF            		JSR		F_I2C_Delay
   680 0000F01A 60                  			RTS	
