   234                      <       ;**********************************************************************
   235                      <       ;ROM Checksum
   236                      <       ;**********************************************************************
   237                      <       ;.IF (GPL813P01Ax+GPL813P01Bx+GPL813P01Cx)
   238                      <       ;	D_BankNum:						.EQU	1	
   239                      <       ;.ENDIF
   240                      <       
   241                      <       	D_Bank0UserRomStartAddr:		.EQU	0xE000		;0x4800 ~ 0x7FDF:User ROM Code
   242                      <       	D_Bank0UserRomEndAddr:			.EQU	0xFFDF
   243                      <       	D_NMIandResetVectorStartAddr:	.EQU	0xFFFC		;0xFFF8 ~ 0xFFF9:User ROM Code, 0xFFFA ~ 0xFFFF:NMI & Reset & IRQ vector
   244                      <       	D_NMIandResetVectorEndAddr:		.EQU	0xFFFF
   245                      <       
   246                      <       ; ========================================================================================
   247                      <       ; Macro Name	: M_UserRomChecksum
   248                      <       ; Parameters	: None
   249                      <       ; Return Value	: R_ChecksumResult: bit[7:0]
   250                      <       ;				: R_ChecksumResult + 1: bit[15:8]
   251                      <       ;				: R_ChecksumResult + 2: bit[23:16]
   252                      <       ;				: R_ChecksumResult + 3: bit[31:24]
   253                      <       ; Description	: Calculate user ROM area code checksum
   254                      <       ; Destroy		: A, Y
   255                      <       ; Example		: %M_UserRomChecksum	R_ChecksumAddrPtr, R_ChecksumResult
   256                      <       ; ========================================================================================	
   257                      <       %M_UserRomChecksum:	.MACRO	R_ChecksumAddrPtr, R_ChecksumResult
   258                      <       	
   259                      <       	LDA		#0
   260                      <       	STA		R_ChecksumResult						;Result Byte0
   261                      <       	STA		R_ChecksumResult + 1				;Result Byte1
   262                      <       	STA		R_ChecksumResult + 2				;Result Byte2
   263                      <       	STA		R_ChecksumResult + 3				;Result Byte3
   264                      <       ;=================== Bank 0 ==================================================	
   265                      <       	LDA		#.HIGH.D_Bank0UserRomStartAddr
   266                      <       	STA		R_ChecksumAddrPtr + 1				;Start High Byte
   267                      <       	LDA		#.LOW.D_Bank0UserRomStartAddr
   268                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   269                      <       		
   270                      <       	LDY		#0	
   271                      <       
   272                      <       L_ChecksumLoop1?
   273                      <       	STA		P_WDT_Flag_Clear	
   274                      <       	CLC
   275                      <       	LDA		(R_ChecksumAddrPtr),Y
   276                      <       	ADC		R_ChecksumResult						;Result Low Byte
   277                      <       	STA		R_ChecksumResult						;Result Low Byte
   278                      <       	BCC		L_CheckAddress1?
   279                      <       	INC		R_ChecksumResult + 1				;Result Byte1
   280                      <       	BNE		L_CheckAddress1?
   281                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   282                      <       	BNE		L_CheckAddress1?
   283                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   284                      <       		
   285                      <       L_CheckAddress1?:
   286                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   287                      <       	CMP		#.HIGH.D_Bank0UserRomEndAddr		;End High Byte
   288                      <       	BNE		L_IncreaseAdd1?
   289                      <       	
   290                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   291                      <       	CMP		#.LOW.D_Bank0UserRomEndAddr			;End Low Byte
   292                      <       	BEQ		L_ExitRomSum1?
   293                      <       	
   294                      <       L_IncreaseAdd1?:
   295                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   296                      <       	BNE		L_ChecksumLoop1?
   297                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   298                      <       	JMP		L_ChecksumLoop1?	
   299                      <       		
   300                      <       L_ExitRomSum1?:	
   301                      <       
   302                      <       ;===================NMI & Reset Vector==================================================		
   303                      <       	LDA		#.HIGH.D_NMIandResetVectorStartAddr
   304                      <       	STA		R_ChecksumAddrPtr + 1				; Start High Byte
   305                      <       	LDA		#.LOW.D_NMIandResetVectorStartAddr
   306                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   307                      <       		
   308                      <       L_ChecksumLoop2?
   309                      <       	STA		P_WDT_Flag_Clear		
   310                      <       	CLC
   311                      <       	LDA		(R_ChecksumAddrPtr),Y
   312                      <       	ADC		R_ChecksumResult						;Result Low Byte
   313                      <       	STA		R_ChecksumResult						;Result Low Byte
   314                      <       	BCC		L_CheckAddress2?
   315                      <       	INC		R_ChecksumResult + 1				;Result Byte2
   316                      <       	BNE		L_CheckAddress2?
   317                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   318                      <       	BNE		L_CheckAddress2?
   319                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   320                      <       		
   321                      <       L_CheckAddress2?:
   322                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   323                      <       	CMP		#.HIGH.D_NMIandResetVectorEndAddr	;End High Byte
   324                      <       	BNE		L_IncreaseAdd2?
   325                      <       	
   326                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   327                      <       	CMP		#.LOW.D_NMIandResetVectorEndAddr	;End Low Byte
   328                      <       	BEQ		L_ExitRomSum2?
   329                      <       	
   330                      <       L_IncreaseAdd2?:
   331                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   332                      <       	BNE		L_ChecksumLoop2?
   333                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   334                      <       	JMP		L_ChecksumLoop2?	
   335                      <       		
   336                      <       L_ExitRomSum2?:	
   337                      <       ;;=====================Bank area================================================		
   338                      <       	
   339                      <       	.ENDM
   340                      <       ;================================================================================
   341                      <       
   342                      <       			.ENDIF
   343                      <       .ENDIF
   344                      <       	.ENDIF
