   718                      <       		STA		P_IO_PortC_Data	
   719                      <       		
   720                      <       		LDA		#00h
   721                      <       		STA		P_IO_PortD_Attrib		
   722                      <       		LDA		#00000001b		
   723                      <       		STA		P_IO_PortD_Dir
   724                      <       		STA		P_IOD_DIR_Map	
   725                      <       		LDA		#00000010b
   726                      <       		STA		P_IO_PortD_Data		
   727                      <       		STA		R_PortD_Data_Buf
