  1347                              ;==========================================
  1348                              ;Variable RAM declare area
  1349                              ;==========================================
  1350 00000080                     .PAGE0 ; PAGE指定列在一页上的最大列数和一行上最大的字符数
  1351 00000080 FF                  R_2Hz		ds	1
  1352 00000081 FF                  R_128Hz		ds	1
  1353 00000082 FF                  R_INTFlag	ds	1
  1354                              
  1355                              ;IOD_Attmap	ds	1
  1356                              ;IOD_Dirmap	ds	1
  1357                              ;IOD_Datmap	ds	1
  1358                              ;==========================================
  1359                              ; code starting 
  1360                              ;==========================================
  1361 0000E000                     .CODE
  1362 0000E000                     V_RESET:
  1363                              ; User_Code_Start:
  1364                              ; Code_Start:
  1365 0000E000 78                  		SEI					; 置中断禁止位
  1366 0000E001 A2 FF               		LDX		#FFH		;
  1367 0000E003 9A                  		TXS					;x-->栈指针
  1368                              
  1369 0000E004 A5 08               		LDA		P_WAKEUP_Ctrl	;唤醒源代码控制寄存器
  1370 0000E006 AA                  		TAX
  1371 0000E007 29 03               		AND		#(D_WakeupKey+D_WakeupTMBA);+D_Wakeup128Hz) ;WakeupKey+TimeBaseA wake up(1/2hz)---------开启128Hz唤醒
  1372 0000E009 F0 36               		BEQ		L_PowerOn        ;No Wakeup     
  1373                              		
  1374 0000E00B A9 00                       LDA		#00
  1375 0000E00D 85 08               		STA		P_WAKEUP_Ctrl    ;clear wakeup flag
