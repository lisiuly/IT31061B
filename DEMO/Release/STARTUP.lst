   610                      <       %InitLCD:		.MACRO
   611                      <       
   612                      <       		LDA		#(D_Duty_1_5+D_Bias_1_3+D_ScanEnable)
   613                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   614                      <       		
