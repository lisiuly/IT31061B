  1397 0000F0D8 09 10             1           ora     #AddOthers              ;  %bits 10H,_BIT0
  1398                            1 		                   ;  10H.0=1
  1399 0000F0DA 8D 86 00          1           sta     R_TimeStatus               ;
  1400 0000F0DD 4C 3B F1            	JMP		F_GetTHVlaue
