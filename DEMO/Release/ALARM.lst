   432                      <       	
   433                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   434                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   435                      <       		
