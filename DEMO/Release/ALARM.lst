  1391 0000F0D0 29 EF             1           and     #.NOT.D_Neg         ;  %bitr 10H,_BIT0;  10H.0=0
  1392 0000F0D2 8D 90 01          1           sta     R_SpecFlag
  1393                              
  1394 0000F0D5                     LoadTemperatureValue:
