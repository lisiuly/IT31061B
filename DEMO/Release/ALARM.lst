  1381                              	%bits	R_SpecFlag,D_Neg
  1382 0000F0C2 AD 90 01          1           lda     R_SpecFlag               ;ex.  
  1383 0000F0C5 09 10             1           ora     #D_Neg              ;  %bits 10H,_BIT0
  1384                            1 		                   ;  10H.0=1
  1385 0000F0C7 8D 90 01          1           sta     R_SpecFlag               ;
  1386 0000F0CA 4C D5 F0            	JMP		LoadTemperatureValue
  1387                              
