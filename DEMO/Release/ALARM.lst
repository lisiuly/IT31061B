  1551 0000F1B7 AD 90 01          1           lda     R_SpecFlag               ;ex.   
  1552 0000F1BA 29 10             1           and     #D_Neg              ;  %btst 10H,_BIT0,N
  1553 0000F1BC D0 17             1           bne     JudgeTempLL               ;  if(10H.0=1) goto N 
  1554 0000F1BE AD 9B 01            	LDA		R_DispTemper+0
  1555 0000F1C1 C9 05               	CMP		#05H
  1556 0000F1C3 90 0F               	BCC		JudgeTempExit
  1557 0000F1C5 D0 05               	BNE		SetTempHH
  1558 0000F1C7 AD 9C 01            	LDA		R_DispTemper+1
  1559 0000F1CA F0 08               	BEQ		JudgeTempExit
  1560 0000F1CC                     SetTempHH:
  1561                              	%bits	R_SpecFlag,D_TempHH
  1562 0000F1CC AD 90 01          1           lda     R_SpecFlag               ;ex.  
  1563 0000F1CF 09 40             1           ora     #D_TempHH              ;  %bits 10H,_BIT0
  1564                            1 		                   ;  10H.0=1
  1565 0000F1D1 8D 90 01          1           sta     R_SpecFlag               ;
  1566 0000F1D4                     JudgeTempExit:
  1567 0000F1D4 60                  	RTS
  1568                              
  1569 0000F1D5                     JudgeTempLL:
  1570 0000F1D5 AD 9B 01            	LDA		R_DispTemper+0
  1571 0000F1D8 C9 01               	CMP		#01H
  1572 0000F1DA 90 F8               	BCC		JudgeTempExit
  1573                              	%bits	R_SpecFlag,D_TempLL
  1574 0000F1DC AD 90 01          1           lda     R_SpecFlag               ;ex.  
  1575 0000F1DF 09 20             1           ora     #D_TempLL              ;  %bits 10H,_BIT0
  1576                            1 		                   ;  10H.0=1
  1577 0000F1E1 8D 90 01          1           sta     R_SpecFlag               ;
  1578 0000F1E4 60                  	RTS
  1579                              
  1580                              ; 输入：当前室内湿度显示状态。
  1581                              ; 输出：当前产品固定不产生湿度 HH/LL，直接返回。
