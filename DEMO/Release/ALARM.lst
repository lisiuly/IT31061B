  1514 0000F185 AD 86 01            	LDA		R_HUM
  1515 0000F188 F0 0A               	BEQ		ProcessHumidity_Clamp1
  1516 0000F18A C9 64               	CMP		#C_HumRaw100
  1517 0000F18C 90 0C               	BCC		ProcessHumidity_ConvertBCD
  1518 0000F18E A9 99               	LDA		#C_HumDisp99
  1519 0000F190 8D A1 01            	STA		R_DispHum
  1520 0000F193 60                  	RTS
  1521                              
  1522 0000F194                     ProcessHumidity_Clamp1:
  1523 0000F194 A9 01               	LDA		#01H
  1524 0000F196 8D A1 01            	STA		R_DispHum
  1525 0000F199 60                  	RTS
  1526                              
  1527 0000F19A                     ProcessHumidity_ConvertBCD:
  1528 0000F19A A2 00               	LDX		#00H
  1529 0000F19C AD 86 01            	LDA		R_HUM
  1530 0000F19F 20 B2 ED            	JSR		F_CAL_HEX_BCD2
  1531 0000F1A2 AD B2 00            	LDA		OUT_L
