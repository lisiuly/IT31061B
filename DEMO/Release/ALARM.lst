  1475                              ;-------------------------------------------------------
  1476                              ; 输入：R_TempCH, R_TempCL 当前温度原始值。
  1477                              ; 输出：生成室内摄氏显示缓冲，并继续生成华氏显示缓冲。
  1478                              ; 调试：看 R_DispTemper+0/+1 与原始温度的 BCD 对应关系。
  1479 0000F14A                     ProcessTemperature:
  1480 0000F14A AD 84 01            	LDA		R_TempCH
  1481 0000F14D 29 7F               	AND		#7FH
  1482 0000F14F AA                  	TAX
  1483 0000F150 AD 85 01            	LDA		R_TempCL
  1484 0000F153 20 B2 ED            	JSR		F_CAL_HEX_BCD2
  1485 0000F156 AD B3 00            	LDA		OUT_M
  1486 0000F159 8D 9B 01            	STA		R_DispTemper+0
  1487 0000F15C AD B2 00            	LDA		OUT_L
  1488 0000F15F 8D 9C 01            	STA		R_DispTemper+1
  1489 0000F162 4C 65 F1            	JMP		ConvertToFahrenheit
  1490                              
  1491                              ;-------------------------------------------------------
  1492                              ; 输入：R_TempCH, R_TempCL 当前温度原始值。
  1493                              ; 输出：生成室内华氏显示缓冲 R_DispTemper_F。
  1494                              ; 调试：看 X_M/X_L 和 R_DispTemper_F 是否与换算结果一致。
  1495 0000F165                     ConvertToFahrenheit:
  1496 0000F165 AD 84 01            	LDA		R_TempCH
  1497 0000F168 AA                  	TAX
  1498 0000F169 AD 85 01            	LDA		R_TempCL
  1499 0000F16C 20 09 EE            	JSR		F_CHANGE_CF
  1500 0000F16F AE AE 00            	LDX		X_M
  1501 0000F172 AD AF 00            	LDA		X_L
  1502 0000F175 20 B2 ED            	JSR		F_CAL_HEX_BCD2
  1503 0000F178 AD B3 00            	LDA		OUT_M
  1504 0000F17B 8D 95 01            	STA		R_DispTemper_F+0
  1505 0000F17E AD B2 00            	LDA		OUT_L
  1506 0000F181 8D 96 01            	STA		R_DispTemper_F+1
  1507 0000F184 60                  	RTS
  1508                              
  1509                              ;-------------------------------------------------------
  1510                              ; 输入：R_HUM 当前原始湿度值。
  1511                              ; 输出：把湿度夹到 1~99 后转换成 BCD 显示格式。
