  1536                              ; 函数: F_Judge_HHLL
  1537                              ; 作用: 重算当前温湿度 HH/LL 状态位。
  1538 0000F1A9                     F_Judge_HHLL:
  1539                              	%bitr	R_SpecFlag,(D_TempLL+D_TempHH+D_HumLL+D_HumHH)
  1540 0000F1A9 AD 90 01          1           lda     R_SpecFlag               ;ex.  
  1541 0000F1AC 29 99             1           and     #.NOT.(D_TempLL+D_TempHH+D_HumLL+D_HumHH)         ;  %bitr 10H,_BIT0;  10H.0=0
  1542 0000F1AE 8D 90 01          1           sta     R_SpecFlag
  1543 0000F1B1 20 B7 F1            	JSR		F_Judge_TempHHLL
  1544 0000F1B4 4C E5 F1            	JMP		F_Judge_HumHHLL
  1545                              
  1546                              ; 输入：当前室内温度显示缓冲与负号标志。
  1547                              ; 输出：按规格重算温度 HH/LL 状态位。
  1548                              ; 调试：看 D_TempHH/D_TempLL 在高低边界附近是否按预期翻转。
