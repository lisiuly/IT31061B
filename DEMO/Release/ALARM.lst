  1336 0000F084                     .CODE
  1337                              ;-------------------------------------------------------
  1338                              ; 函数: F_JudgeRFC
  1339                              ; 作用: 温湿度采样统一入口，只在整分 00 秒的半秒边沿触发一次。
  1340                              .PUBLIC		F_JudgeRFC
  1341 0000F084                     F_JudgeRFC:
  1342                              	%btst	R_KeyFlag,D_KeyRelDis,ExitJudge
  1343 0000F084 AD 8A 00          1           lda     R_KeyFlag               ;ex.   
  1344 0000F087 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1345 0000F089 D0 55             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1346                              	%btst	R_RFStatus,D_RFLongRecv,ExitJudge
  1347 0000F08B AD A5 01          1           lda     R_RFStatus               ;ex.   
  1348 0000F08E 29 01             1           and     #D_RFLongRecv              ;  %btst 10H,_BIT0,N
  1349 0000F090 D0 4E             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1350 0000F092 AD 85 00            	LDA		RTC+2
  1351 0000F095 C9 00               	CMP		#00H
  1352 0000F097 D0 47               	BNE		ExitJudge
  1353                              	%btst	R_TimeStatus,HalfSecToggle,ExitJudge
  1354 0000F099 AD 86 00          1           lda     R_TimeStatus               ;ex.   
  1355 0000F09C 29 40             1           and     #HalfSecToggle              ;  %btst 10H,_BIT0,N
  1356 0000F09E D0 40             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1357 0000F0A0 4C A3 F0            	JMP		F_UpdateTHFromGXHTV4
  1358                              
  1359                              ;-------------------------------------------------------
  1360                              ; 函数: F_UpdateTHFromGXHTV4
  1361                              ; 作用: 从 GXHTV4 读取原始温湿度值，并转入本模块换算链。
  1362                              .PUBLIC		F_UpdateTHFromGXHTV4
  1363 0000F0A3                     F_UpdateTHFromGXHTV4:
  1364 0000F0A3 20 C1 EB            	JSR		F_ReadGXHTV4Data
