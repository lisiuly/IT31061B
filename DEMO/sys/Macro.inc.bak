;==========================================================================
;Macro Name: %M_SetPC7_InputPL                 Attrib     Dir    Data
;Purpose: Set PortC7 iutput pull low            0          0      1
;Destroy: A
;==========================================================================
%M_SetPC7_InputPL:	.MACRO
	    LDA		P_IO_PortC_Attrib
		AND     #7FH
		STA		P_IO_PortC_Attrib
		
		LDA		P_IO_PortC_Dir
		AND     #7FH
		STA		P_IO_PortC_Dir
		
		LDA		P_IO_PortC_Buffer
		ORA		#10000000B
		STA		P_IO_PortC_Data

			.ENDM
;==========================================================================
;Macro Name: %M_SetPC7_InputPH               Attrib     Dir    Data
;Purpose: Set PortC7 iutput pull high         1          0      1
;Destroy: A
;==========================================================================
%M_SetPC7_InputPH:	.MACRO
	    LDA		P_IO_PortC_Attrib
		ORA     #80H
		STA		P_IO_PortC_Attrib
		
		LDA		P_IO_PortC_Dir
		AND     #7FH
		STA		P_IO_PortC_Dir
		
		LDA		P_IO_PortC_Buffer
		ORA		#10000000B
		STA		P_IO_PortC_Data

			.ENDM
;==========================================================================
;Macro Name: %M_SetPC7_Output               Attrib     Dir    Data
;Purpose: Set PortC7 driving  low            0          1      0
;Destroy: A
;==========================================================================
%M_SetPC7_OutputL:	.MACRO
        LDA		P_IO_PortC_Attrib
		AND     #7FH
		STA		P_IO_PortC_Attrib
		
		LDA		P_IO_PortC_Dir
		ORA     #80H
		STA		P_IO_PortC_Dir
		
		LDA		P_IO_PortC_Buffer
		AND		#01111111b
		STA		P_IO_PortC_Data
			.ENDM
;==========================================================================
;Macro Name: %M_SetPC7_Output             Attrib     Dir    Data
;Purpose: Set PortC7 driving  high          0         1      1
;Destroy: A
;==========================================================================
%M_SetPC7_OutputH:	.MACRO
        LDA		P_IO_PortC_Attrib
		AND     #7FH
		STA		P_IO_PortC_Attrib
		
		LDA		P_IO_PortC_Dir
		ORA     #80H
		STA		P_IO_PortC_Dir
		
		LDA		P_IO_PortC_Buffer
		ORA		#10000000B
		STA		P_IO_PortC_Data
		
			.ENDM
;----------------------------------------------------------
;/***********************************************/
;         i.L=1 
%bits:   .MACRO   i,L             ;BYTE i;  
          lda     i               ;ex.  
          ora     #L              ;  %bits 10H,_BIT0
		                   ;  10H.0=1
          sta     i               ;
         .ENDM    

;/***********************************************/
;         i.L=0
%bitr:   .MACRO   i,L             ;BYTE i;  
          lda     i               ;ex.  
          and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
          sta     i
         .ENDM    

;/***********************************************/
;         if(i.L==1) goto N
%btst:   .MACRO   i,L,N           ;BYTE i;  
          lda     i               ;ex.   
          and     #L              ;  %btst 10H,_BIT0,N
          bne     N               ;  if(10H.0=1) goto N 
         .ENDM    
                                  
;/***********************************************/
;         if(i.L==0) goto N
%btsf:   .MACRO   i,L,N           ;BYTE i;    
          lda     i               ;ex.   
          and     #L              ;  %btsf 10H,_BIT0,N
          beq     N               ;  if(10H.0=0) goto N 
         .ENDM    
  
;-----------------------------------------------------------------------------
; Macro Name:	%InitSystem
; Description:	Initial system port
;-----------------------------------------------------------------------------
%InitSystem		.MACRO
		LDA		#0
		STA		P_Reset_Status	;Clear AC key reset flag
		%Enable32KLF
	.ENDM
;-----------------------------------------------------------------------------
; Macro Name:	%Disable32KLF
; Description:	Disable Low Frequency
;-----------------------------------------------------------------------------
%Disable32KLF	.MACRO

		LDA		#D_LFDisable
		STA		P_CLK_32768_En

		.ENDM
;-----------------------------------------------------------------------------
; Macro Name:	%Enable32KLF
; Description:	Enable Low Frequency
;-----------------------------------------------------------------------------
%Enable32KLF		.MACRO

		LDA		#D_LFEnable
		STA		P_CLK_32768_En

	.ENDM		
;-----------------------------------------------------------------------------
; Macro Name:	%InitLCD
; Description:	Initialize LCD configuration after power on
;-----------------------------------------------------------------------------	
%InitLCD:		.MACRO

		LDA		#(D_Duty_1_4+D_Bias_1_3+D_ScanEnable)
		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
		
		LDA     #D_VLCD_33            ;VLCD = 4.5V (max value)
		STA     P_LCD_VLCD_Ctrl
	
	.ENDM
;-----------------------------------------------------------------------------
; Macro Name:	%FillSram
; Description:	Fill data to SRAM whole space
; Input:		mData
;-----------------------------------------------------------------------------	
%FillSram		.MACRO	mData
		
		LDA		#.LOW.(C_SramAddrStart+2)
		STA		C_SramAddrStart
		LDA		#.HIGH.(C_SramAddrStart+2)
		STA		C_SramAddrStart+1
		
		LDX     #0
?L_FillLoop#:
        LDA     mData
		STA     (C_SramAddrStart,X)
		
		LDA     C_SramAddrStart+1
		CMP     #.HIGH.C_SramAddrEnd
		BCC     ?L_IncSramAddr#
		LDA     C_SramAddrStart
		CMP     #.LOW.C_SramAddrEnd
		BCS     ?L_End#
		
?L_IncSramAddr#:    ;Increase sram address
        INC     C_SramAddrStart
		BNE     ?L_FillLoop#
		INC     C_SramAddrStart+1
		%WatchDogClear
        JMP     ?L_FillLoop#
?L_End#:
        
        LDA     mData
        STA     C_SramAddrStart
        STA     C_SramAddrStart+1
        
        LDX		#00H
?L_HSRAMloop:
		LDA		mData
		STA		$180,X
		INX	
		CPX		#80H
		BNE		?L_HSRAMloop
		
	.ENDM
	
;-----------------------------------------------------------------------------
; Macro Name:	%ClrSRAM
; Description:	Clear SRAM $60 ~ $95F
;-----------------------------------------------------------------------------	
%ClrSRAM:	.MACRO

		%FillSram	#0

	.ENDM
;-----------------------------------------------------------------------------
;-----------------------------------------------------------------------------
; Macro Name:	%FillLcdDpram
; Description:	Fill LCD DPRAM $3E00 ~$3FFF
;-----------------------------------------------------------------------------
%FillLcdDpram	.MACRO	mData
		
		%WatchDogClear
		LDX		#00H
		LDY		#00H
?L_ClrDpramLoop:
		LDA     mData
		STA		$3E00,X
		INY
		CPY		#04H
		BNE		?L_ClrDpramLoopI
		LDY		#00H
		TXA
		CLC
		ADC		#0CH
		TAX
?L_ClrDpramLoopI:		
		INX
		CPX		#80H
		BNE		?L_ClrDpramLoop
	.ENDM
;-----------------------------------------------------------------------------
%F_Initinal_IO	.MACRO
		LDA		#00001111b
		STA		P_IO_PortA_Dir
		LDA		#00001111b
		STA		P_IO_PortA_Data		;ÏČPA0-3ŨũÎŠLEDÆÁĩÄSEGĢŽÔÚÉĻÃčĘąŌēŌŠŨũÎŠ°īžüĩÄĘäČëŋÚ
		
		LDA		#0
		STA		P_IO_PortB_Attrib
		LDA		#11111000b		; 
		STA		P_IO_PortB_Dir
		LDA		#00001000b		;PB3-7ŨũÎŠLEDÆÁĩÄCOMŋÚĢŽÔÚēŧÁÁĘąŌŠĘäģöļß
		STA		P_IO_PortB_Data	

		LDA		#00H
		STA		P_IO_PortC_Dir
		LDA		#00000000b
		STA		P_IO_PortC_Data		;PCŋÚÎīÓÃĩ―ĢŽČŦēŋÉčÖÃ input pull low
		
		LDA		#0
		STA		P_IO_PortD_Attrib
		LDA		#00100000b		;
		STA		P_IO_PortD_Dir
		LDA		#00011100b			;PD1ŨũÎŠÍâĩįžėēâĢŽŌŠĘäČëÏÂĀ­ĢŽPD5ŨũÎŠ·äÃųÆũđĶÄÜĢŽŌŠĘäģöĩÍ
		STA		P_IO_PortD_Data		;PD2/3/4ŨũÎŠRFCđĶÄÜĢŽģõĘžŌŠinput floating
		
		LDA		#11110111b
		STA		P_IO_PortE_Dir
		LDA		#11110111b			;PE0,ŨũÎŠ°īžüĩÄđŦđēķËĘäģöļßĢŽPE3ÎīÓÃĢŽÖÃinput pull low 
		STA		P_IO_PortE_Data		;PE1,2,4,5,6ŨũÎŠLEDÆÁĩÄSEG output high,PE7ŨũÎŠLEDÆÁĩÄCOM5
		
		LDA		#00
		STA		P_IO_Ctrl	;all as normal IO
		.ENDM
;-----------------------------------------------------------------------------
; Clear watch dog
%WatchDogClear	 .MACRO

	   STA	   P_WDT_Flag_Clear

	   .ENDM
;-----------------------------------------------------------------------------
; Macro Name:	%ClrPage0_60H_6FH
; Description:	Clear SRAM $60 ~ $7F
;-----------------------------------------------------------------------------	
%ClrPage0_60H_6FH:	.MACRO

		LDX		#0FH
		LDA		#0
		
?L_ClrLoop#:
		STA		$60,X
		DEX
		BPL		?L_ClrLoop#	

	.ENDM
;-----------------------------------------------------------------------------
; Macro Name:	%PushAll                                                        
; Description:	Push                                                          
;-----------------------------------------------------------------------------
%PushAll:		.MACRO                                                            
		PHP                                                                         
		PHA                                                                         
		TXA                                                                         
		PHA                                                                         
		TYA                                                                         
		PHA                                                                         
                                                                       
			.ENDM                                                                   
;-----------------------------------------------------------------------------
; Macro Name:	%PopAll                                                         
; Description:	Pop                                                           
;-----------------------------------------------------------------------------
%PopAll:		.MACRO                                                            
                                                    
		PLA                                                                         
		TAY                                                                         
		PLA                                                                         
		TAX                                                                         
		PLA                                                                         
		PLP                                                                         
			.ENDM	                                
		



