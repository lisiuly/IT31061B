   702                      <       %F_Initinal_IO	.MACRO
   703                      <       		LDA		#00000000b		
   704                      <       		STA		P_IO_PortA_Dir
   705                      <       		LDA		#00000000b		
   706                      <       		STA		P_IO_PortA_Data	
   707                      <       		
   708                      <       		LDA		#0
   709                      <       		STA		P_IO_PortB_Attrib
   710                      <       		LDA		#00000011b		
   711                      <       		STA		P_IO_PortB_Dir
   712                      <       		LDA		#00000000b		
