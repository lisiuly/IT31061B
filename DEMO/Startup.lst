   621                      <       ; Macro Name:	%FillSram
   622                      <       ; Description:	Fill data to SRAM whole space
   623                      <       ; Input:		mData
   624                      <       ;-----------------------------------------------------------------------------	
   625                      <       %FillSram		.MACRO	mData
   626                      <       		
   627                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   628                      <       		STA		C_SramAddrStart
   629                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   630                      <       		STA		C_SramAddrStart+1
   631                      <       		
   632                      <       		LDX     #0
   633                      <       ?L_FillLoop#:
   634                      <               LDA     mData
   635                      <       		STA     (C_SramAddrStart,X)
   636                      <       		
   637                      <       		LDA     C_SramAddrStart+1
   638                      <       		CMP     #.HIGH.C_SramAddrEnd
   639                      <       		BCC     ?L_IncSramAddr#
   640                      <       		LDA     C_SramAddrStart
   641                      <       		CMP     #.LOW.C_SramAddrEnd
   642                      <       		BCS     ?L_End#
   643                      <       		
   644                      <       ?L_IncSramAddr#:    ;Increase sram address
   645                      <               INC     C_SramAddrStart
   646                      <       		BNE     ?L_FillLoop#
   647                      <       		INC     C_SramAddrStart+1
   648                      <       		%WatchDogClear
   649                      <               JMP     ?L_FillLoop#
   650                      <       ?L_End#:
   651                      <               
   652                      <               LDA     mData
   653                      <               STA     C_SramAddrStart
   654                      <               STA     C_SramAddrStart+1
   655                      <               
   656                      <               LDX		#00H
   657                      <       ?L_HSRAMloop:
   658                      <       		LDA		mData
   659                      <       		STA		$180,X
   660                      <       		INX	
   661                      <       		CPX		#80H
   662                      <       		BNE		?L_HSRAMloop
   663                      <       		
   664                      <       	.ENDM
   665                      <       	
   666                      <       ;-----------------------------------------------------------------------------
   667                      <       ; Macro Name:	%ClrSRAM
   668                      <       ; Description:	Clear SRAM $60 ~ $95F
   669                      <       ;-----------------------------------------------------------------------------	
   670                      <       %ClrSRAM:	.MACRO
   671                      <       
   672                      <       		%FillSram	#0
   673                      <       
   674                      <       	.ENDM
   675                      <       ;-----------------------------------------------------------------------------
   676                      <       ;-----------------------------------------------------------------------------
   677                      <       ; Macro Name:	%FillLcdDpram
   678                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   679                      <       ;-----------------------------------------------------------------------------
   680                      <       %FillLcdDpram	.MACRO	mData
   681                      <       		
   682                      <       		%WatchDogClear
   683                      <       		LDX		#00H
   684                      <       		LDY		#00H
   685                      <       ?L_ClrDpramLoop:
   686                      <       		LDA     mData
   687                      <       		STA		$3E00,X
   688                      <       		INY
   689                      <       		CPY		#04H
   690                      <       		BNE		?L_ClrDpramLoopI
   691                      <       		LDY		#00H
   692                      <       		TXA
   693                      <       		CLC
   694                      <       		ADC		#0CH
   695                      <       		TAX
   696                      <       ?L_ClrDpramLoopI:		
   697                      <       		INX
   698                      <       		CPX		#80H
   699                      <       		BNE		?L_ClrDpramLoop
   700                      <       	.ENDM
