   876                      <       LCDConvert		.MACRO  com,seg
   877                      <       ;			DB	com*8+(seg/8)+00H,1<<(seg.AND.07H)
   878                      <       ;			DB	(com*8+07H)-(seg/8),1<<(seg.AND.07H)	;LB25B
   879                      <       ;			DB	com*4+(seg/8)+50H,1<<(seg.AND.07H)	;L11A\B
   880                      <       ;			DB	com*6+(seg/8)+20H,1<<(seg.AND.07H)	;L31B
   881                      <       ;LCDConvert:		.Macro	com,seg
   882                      <       ;			DB	com*4+(seg/8)+A0H,1<<(seg.AND.07H)	;GPL10A
   883                      <       			DB	com*10H+(seg/8)+00H,1<<(seg.AND.07H)	;GPL813P01;
   884                      <       			
   885                      <       			.ENDM
