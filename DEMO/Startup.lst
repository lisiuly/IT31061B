  1235                      <       ; RF发码协议位宽:
  1236                      <       ; Bit0 = 高500us + 低2000us
  1237                      <       ; Bit1 = 高500us + 低1000us
  1238                      <       C_RFBitHigh500us		equ	500
  1239                      <       C_RFBit0Low2000us		equ	2000
  1240                      <       C_RFBit1Low1000us		equ	1000
  1241                      <       C_RFPacketBits36		equ	36
  1242                      <       
  1243                      <       ; RF收码低脉宽按 Timer0 实测约 4.096kHz 的样本数喂入:
  1244                      <       ; bit1 约 4~5 sample，bit0 约 8~9 sample，停止位约 16~20 sample。
  1245                      <       C_RFBitHighMinSample		equ	01H
  1246                      <       C_RFBitHighMaxSample		equ	03H
  1247                      <       C_RFBit1LowMinSample		equ	03H
  1248                      <       C_RFBit1LowMaxSample		equ	06H
  1249                      <       C_RFBit0LowMinSample		equ	07H
  1250                      <       C_RFBit0LowMaxSample		equ	0AH
  1251                      <       C_RFStopLowMinSample		equ	0FH
  1252                      <       C_RFStopLowMaxSample		equ	16H
