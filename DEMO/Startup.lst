   717                      <       		LDA		#00000000b
   718                      <       		STA		P_IO_PortC_Data		; PC7 debug output, default low.
   719                      <       		
   720                      <       		LDA		#00h
   721                      <       		STA		P_IO_PortD_Attrib		
   722                      <       		LDA		#00000001b		
   723                      <       		STA		P_IO_PortD_Dir
   724                      <       		STA		P_IOD_DIR_Map	
   725                      <       		LDA		#00000010b
   726                      <       		STA		P_IO_PortD_Data		
   727                      <       		STA		R_PortD_Data_Buf
   728                      <       
   729                      <       		LDA		#00000000b			;PE0/PE1/PE2 全部作为按键输入
   730                      <       		STA		P_IO_PortE_Dir
   731                      <       		LDA		#00000000b			
   732                      <       		STA		P_IO_PortE_Data		
   733                      <       		
   734                      <       		LDA		#00
   735                      <       		STA		P_IO_Ctrl			;all as normal IO
   736                      <       		.ENDM
