   530                      <       ;----------------------------------------------------------
   531                      <       ;/***********************************************/
   532                      <       ;         i.L=1 
   533                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   534                      <                 lda     i               ;ex.  
   535                      <                 ora     #L              ;  %bits 10H,_BIT0
   536                      <       		                   ;  10H.0=1
   537                      <                 sta     i               ;
   538                      <                .ENDM    
   539                      <       
   540                      <       ;/***********************************************/
   541                      <       ;         i.L=0
   542                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   543                      <                 lda     i               ;ex.  
   544                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   545                      <                 sta     i
   546                      <                .ENDM    
   547                      <       
   548                      <       ;/***********************************************/
   549                      <       ;         if(i.L==1) goto N
   550                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   551                      <                 lda     i               ;ex.   
   552                      <                 and     #L              ;  %btst 10H,_BIT0,N
   553                      <                 bne     N               ;  if(10H.0=1) goto N 
   554                      <                .ENDM    
   555                      <                                         
   556                      <       ;/***********************************************/
   557                      <       ;         if(i.L==0) goto N
   558                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   559                      <                 lda     i               ;ex.   
   560                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   561                      <                 beq     N               ;  if(10H.0=0) goto N 
   562                      <                .ENDM    
   563                      <       ;/***********************************************/
   564                      <       ;         if(i==#0) goto N
   565                      <       %jz:     .MACRO   i,N             ;BYTE i;
   566                      <                 lda     i               ;ex.
   567                      <                 beq     N               ;  %jz 10H,N
   568                      <                .ENDM                    ;  if(10H==#0) goto N
   569                      <       
   570                      <       ;/***********************************************/
   571                      <       ;         if(i!=#0) goto N
   572                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   573                      <                 lda     i               ;ex.
   574                      <                 bne     N               ;  %jnz 10H,N
   575                      <                .ENDM                    ;  if($10!=#0) goto N
