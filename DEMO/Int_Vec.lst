   424                      <       ;Macro Name: %M_ClearWatchDog
   425                      <       ;Purpose: Clear Watchdog
   426                      <       ;Destroy: A
   427                      <       ;;============================================================================
   428                      <       %M_ClearWatchDog:		.MACRO 
   429                      <       	LDA		#D_WDT_Clear
   430                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   431                      <       	.ENDM
   432                      <       ;;============================================================================
   433                      <       ;Macro Name: %M_DisAllInt
   434                      <       ;Purpose: Disable all interrupt 
   435                      <       ;Destroy: A
   436                      <       ;;============================================================================
   437                      <       %F_InitINT:		.MACRO
   438                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   439                      <       		STA		P_TIMER_TimeBase_Sel		
   440                      <       		LDA		#D_128HzInt+D_TMBAInt+D_TMBBInt;D_Timer0Int+
   441                      <       		STA		P_INT_Ctrl
   442                      <       ;		LDA		#00
   443                      <       ;		STA		P_INT_Ctrl2		;disable TMR1 INT
   444                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   445                      <       ;		STA		P_TIMER_Timer0_Ctrl
   446                      <       ;		LDA		#0FCH
   447                      <       ;		STA		P_TIMER_TM0Data_LB		; Timer0 reload = FFFCh, scope now shows about 4.096kHz IRQ on this board.
   448                      <       ;		LDA		#0FFH
   449                      <       ;		STA		P_TIMER_TM0Data_HB
   450                      <       ;		STA		P_TIMER_TM0Load_Ctrl
   451                      <       	.ENDM
