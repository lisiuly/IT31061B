   913                      <       LCDConvert		.MACRO  com,seg
   914                      <       ;			DB	com*8+(seg/8)+00H,1<<(seg.AND.07H)
   915                      <       ;			DB	(com*8+07H)-(seg/8),1<<(seg.AND.07H)	;LB25B
   916                      <       ;			DB	com*4+(seg/8)+50H,1<<(seg.AND.07H)	;L11A\B
   917                      <       ;			DB	com*6+(seg/8)+20H,1<<(seg.AND.07H)	;L31B
   918                      <       ;LCDConvert:		.Macro	com,seg
   919                      <       ;			DB	com*4+(seg/8)+A0H,1<<(seg.AND.07H)	;GPL10A
   920                      <       			DB	com*10H+(seg/8)+00H,1<<(seg.AND.07H)	;GPL813P01;
   921                      <       			
