   530                      <       ;;==========================================================================
   531                      <       ;;Macro Name: %M_SetPC7_Output               Attrib     Dir    Data
   532                      <       ;;Purpose: Set PortC7 driving  low            0          1      0
   533                      <       ;;Destroy: A
   534                      <       ;;==========================================================================
   535                      <       ;%M_SetPC7_OutputL:	.MACRO
   536                      <       ;        LDA		P_IO_PortC_Attrib
   537                      <       ;		AND     #7FH
   538                      <       ;		STA		P_IO_PortC_Attrib
   539                      <       ;		
   540                      <       ;		LDA		P_IO_PortC_Dir
   541                      <       ;		ORA     #80H
   542                      <       ;		STA		P_IO_PortC_Dir
   543                      <       ;		
   544                      <       ;		LDA		P_IO_PortC_Buffer
   545                      <       ;		AND		#01111111b
   546                      <       ;		STA		P_IO_PortC_Data
   547                      <       ;			.ENDM
   548                      <       ;;==========================================================================
   549                      <       ;;Macro Name: %M_SetPC7_Output             Attrib     Dir    Data
   550                      <       ;;Purpose: Set PortC7 driving  high          0         1      1
   551                      <       ;;Destroy: A
   552                      <       ;;==========================================================================
   553                      <       ;%M_SetPC7_OutputH:	.MACRO
   554                      <       ;        LDA		P_IO_PortC_Attrib
   555                      <       ;		AND     #7FH
   556                      <       ;		STA		P_IO_PortC_Attrib
   557                      <       ;		
   558                      <       ;		LDA		P_IO_PortC_Dir
   559                      <       ;		ORA     #80H
   560                      <       ;		STA		P_IO_PortC_Dir
   561                      <       ;		
   562                      <       ;		LDA		P_IO_PortC_Buffer
   563                      <       ;		ORA		#10000000B
   564                      <       ;		STA		P_IO_PortC_Data
   565                      <       ;		
   566                      <       ;			.ENDM
   567                      <       ;----------------------------------------------------------
   568                      <       ;/***********************************************/
   569                      <       ;         i.L=1 
   570                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   571                      <                 lda     i               ;ex.  
   572                      <                 ora     #L              ;  %bits 10H,_BIT0
   573                      <       		                   ;  10H.0=1
   574                      <                 sta     i               ;
   575                      <                .ENDM    
   576                      <       
   577                      <       ;/***********************************************/
   578                      <       ;         i.L=0
   579                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   580                      <                 lda     i               ;ex.  
   581                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   582                      <                 sta     i
   583                      <                .ENDM    
   584                      <       
   585                      <       ;/***********************************************/
   586                      <       ;         if(i.L==1) goto N
   587                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   588                      <                 lda     i               ;ex.   
   589                      <                 and     #L              ;  %btst 10H,_BIT0,N
   590                      <                 bne     N               ;  if(10H.0=1) goto N 
   591                      <                .ENDM    
   592                      <                                         
   593                      <       ;/***********************************************/
   594                      <       ;         if(i.L==0) goto N
   595                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   596                      <                 lda     i               ;ex.   
   597                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   598                      <                 beq     N               ;  if(10H.0=0) goto N 
   599                      <                .ENDM    
   600                      <       ;/***********************************************/
   601                      <       ;         if(i==#0) goto N
   602                      <       %jz:     .MACRO   i,N             ;BYTE i;
   603                      <                 lda     i               ;ex.
   604                      <                 beq     N               ;  %jz 10H,N
   605                      <                .ENDM                    ;  if(10H==#0) goto N
   606                      <       
   607                      <       ;/***********************************************/
   608                      <       ;         if(i!=#0) goto N
   609                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   610                      <                 lda     i               ;ex.
   611                      <                 bne     N               ;  %jnz 10H,N
   612                      <                .ENDM                    ;  if($10!=#0) goto N
