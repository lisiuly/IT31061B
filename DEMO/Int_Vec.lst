   658                      <       ; Macro Name:	%FillSram
   659                      <       ; Description:	Fill data to SRAM whole space
   660                      <       ; Input:		mData
   661                      <       ;-----------------------------------------------------------------------------	
   662                      <       %FillSram		.MACRO	mData
   663                      <       		
   664                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   665                      <       		STA		C_SramAddrStart
   666                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   667                      <       		STA		C_SramAddrStart+1
   668                      <       		
   669                      <       		LDX     #0
   670                      <       ?L_FillLoop#:
   671                      <               LDA     mData
   672                      <       		STA     (C_SramAddrStart,X)
   673                      <       		
   674                      <       		LDA     C_SramAddrStart+1
   675                      <       		CMP     #.HIGH.C_SramAddrEnd
   676                      <       		BCC     ?L_IncSramAddr#
   677                      <       		LDA     C_SramAddrStart
   678                      <       		CMP     #.LOW.C_SramAddrEnd
   679                      <       		BCS     ?L_End#
   680                      <       		
   681                      <       ?L_IncSramAddr#:    ;Increase sram address
   682                      <               INC     C_SramAddrStart
   683                      <       		BNE     ?L_FillLoop#
   684                      <       		INC     C_SramAddrStart+1
   685                      <       		%WatchDogClear
   686                      <               JMP     ?L_FillLoop#
   687                      <       ?L_End#:
   688                      <               
   689                      <               LDA     mData
   690                      <               STA     C_SramAddrStart
   691                      <               STA     C_SramAddrStart+1
   692                      <               
   693                      <               LDX		#00H
   694                      <       ?L_HSRAMloop:
   695                      <       		LDA		mData
   696                      <       		STA		$180,X
   697                      <       		INX	
   698                      <       		CPX		#80H
   699                      <       		BNE		?L_HSRAMloop
   700                      <       		
   701                      <       	.ENDM
   702                      <       	
   703                      <       ;-----------------------------------------------------------------------------
   704                      <       ; Macro Name:	%ClrSRAM
   705                      <       ; Description:	Clear SRAM $60 ~ $95F
   706                      <       ;-----------------------------------------------------------------------------	
   707                      <       %ClrSRAM:	.MACRO
   708                      <       
   709                      <       		%FillSram	#0
   710                      <       
   711                      <       	.ENDM
   712                      <       ;-----------------------------------------------------------------------------
   713                      <       ;-----------------------------------------------------------------------------
   714                      <       ; Macro Name:	%FillLcdDpram
   715                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   716                      <       ;-----------------------------------------------------------------------------
   717                      <       %FillLcdDpram	.MACRO	mData
   718                      <       		
   719                      <       		%WatchDogClear
   720                      <       		LDX		#00H
   721                      <       		LDY		#00H
   722                      <       ?L_ClrDpramLoop:
   723                      <       		LDA     mData
   724                      <       		STA		$3E00,X
   725                      <       		INY
   726                      <       		CPY		#04H
   727                      <       		BNE		?L_ClrDpramLoopI
   728                      <       		LDY		#00H
   729                      <       		TXA
   730                      <       		CLC
   731                      <       		ADC		#0CH
   732                      <       		TAX
   733                      <       ?L_ClrDpramLoopI:		
   734                      <       		INX
   735                      <       		CPX		#80H
   736                      <       		BNE		?L_ClrDpramLoop
   737                      <       	.ENDM
