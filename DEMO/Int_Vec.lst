   250                      <       ;**********************************************************************
   251                      <       ;ROM Checksum
   252                      <       ;**********************************************************************
   253                      <       ;.IF (GPL813P01Ax+GPL813P01Bx+GPL813P01Cx)
   254                      <       ;	D_BankNum:						.EQU	1	
   255                      <       ;.ENDIF
   256                      <       
   257                      <       	D_Bank0UserRomStartAddr:		.EQU	0xE000		;0x4800 ~ 0x7FDF:User ROM Code
   258                      <       	D_Bank0UserRomEndAddr:			.EQU	0xFFDF
   259                      <       	D_NMIandResetVectorStartAddr:	.EQU	0xFFFC		;0xFFF8 ~ 0xFFF9:User ROM Code, 0xFFFA ~ 0xFFFF:NMI & Reset & IRQ vector
   260                      <       	D_NMIandResetVectorEndAddr:		.EQU	0xFFFF
   261                      <       
   262                      <       ; ========================================================================================
   263                      <       ; Macro Name	: M_UserRomChecksum
   264                      <       ; Parameters	: None
   265                      <       ; Return Value	: R_ChecksumResult: bit[7:0]
   266                      <       ;				: R_ChecksumResult + 1: bit[15:8]
   267                      <       ;				: R_ChecksumResult + 2: bit[23:16]
   268                      <       ;				: R_ChecksumResult + 3: bit[31:24]
   269                      <       ; Description	: Calculate user ROM area code checksum
   270                      <       ; Destroy		: A, Y
   271                      <       ; Example		: %M_UserRomChecksum	R_ChecksumAddrPtr, R_ChecksumResult
   272                      <       ; ========================================================================================	
   273                      <       %M_UserRomChecksum:	.MACRO	R_ChecksumAddrPtr, R_ChecksumResult
   274                      <       	
   275                      <       	LDA		#0
   276                      <       	STA		R_ChecksumResult						;Result Byte0
   277                      <       	STA		R_ChecksumResult + 1				;Result Byte1
   278                      <       	STA		R_ChecksumResult + 2				;Result Byte2
   279                      <       	STA		R_ChecksumResult + 3				;Result Byte3
   280                      <       ;=================== Bank 0 ==================================================	
   281                      <       	LDA		#.HIGH.D_Bank0UserRomStartAddr
   282                      <       	STA		R_ChecksumAddrPtr + 1				;Start High Byte
   283                      <       	LDA		#.LOW.D_Bank0UserRomStartAddr
   284                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   285                      <       		
   286                      <       	LDY		#0	
   287                      <       
   288                      <       L_ChecksumLoop1?
   289                      <       	STA		P_WDT_Flag_Clear	
   290                      <       	CLC
   291                      <       	LDA		(R_ChecksumAddrPtr),Y
   292                      <       	ADC		R_ChecksumResult						;Result Low Byte
   293                      <       	STA		R_ChecksumResult						;Result Low Byte
   294                      <       	BCC		L_CheckAddress1?
   295                      <       	INC		R_ChecksumResult + 1				;Result Byte1
   296                      <       	BNE		L_CheckAddress1?
   297                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   298                      <       	BNE		L_CheckAddress1?
   299                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   300                      <       		
   301                      <       L_CheckAddress1?:
   302                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   303                      <       	CMP		#.HIGH.D_Bank0UserRomEndAddr		;End High Byte
   304                      <       	BNE		L_IncreaseAdd1?
   305                      <       	
   306                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   307                      <       	CMP		#.LOW.D_Bank0UserRomEndAddr			;End Low Byte
   308                      <       	BEQ		L_ExitRomSum1?
   309                      <       	
   310                      <       L_IncreaseAdd1?:
   311                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   312                      <       	BNE		L_ChecksumLoop1?
   313                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   314                      <       	JMP		L_ChecksumLoop1?	
   315                      <       		
   316                      <       L_ExitRomSum1?:	
   317                      <       
   318                      <       ;===================NMI & Reset Vector==================================================		
   319                      <       	LDA		#.HIGH.D_NMIandResetVectorStartAddr
   320                      <       	STA		R_ChecksumAddrPtr + 1				; Start High Byte
   321                      <       	LDA		#.LOW.D_NMIandResetVectorStartAddr
   322                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   323                      <       		
   324                      <       L_ChecksumLoop2?
   325                      <       	STA		P_WDT_Flag_Clear		
   326                      <       	CLC
   327                      <       	LDA		(R_ChecksumAddrPtr),Y
   328                      <       	ADC		R_ChecksumResult						;Result Low Byte
   329                      <       	STA		R_ChecksumResult						;Result Low Byte
   330                      <       	BCC		L_CheckAddress2?
   331                      <       	INC		R_ChecksumResult + 1				;Result Byte2
   332                      <       	BNE		L_CheckAddress2?
   333                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   334                      <       	BNE		L_CheckAddress2?
   335                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   336                      <       		
   337                      <       L_CheckAddress2?:
   338                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   339                      <       	CMP		#.HIGH.D_NMIandResetVectorEndAddr	;End High Byte
   340                      <       	BNE		L_IncreaseAdd2?
   341                      <       	
   342                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   343                      <       	CMP		#.LOW.D_NMIandResetVectorEndAddr	;End Low Byte
   344                      <       	BEQ		L_ExitRomSum2?
   345                      <       	
   346                      <       L_IncreaseAdd2?:
   347                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   348                      <       	BNE		L_ChecksumLoop2?
   349                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   350                      <       	JMP		L_ChecksumLoop2?	
   351                      <       		
   352                      <       L_ExitRomSum2?:	
   353                      <       ;;=====================Bank area================================================		
   354                      <       	
   355                      <       	.ENDM
   356                      <       ;================================================================================
   357                      <       
   358                      <       			.ENDIF
   359                      <       .ENDIF
   360                      <       	.ENDIF
