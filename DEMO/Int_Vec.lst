   740                      <       		LDA		#00000000b		
   741                      <       		STA		P_IO_PortA_Dir
   742                      <       		LDA		#00000000b		
   743                      <       		STA		P_IO_PortA_Data	
   744                      <       		
   745                      <       		LDA		#0
   746                      <       		STA		P_IO_PortB_Attrib
   747                      <       		LDA		#00000011b		
   748                      <       		STA		P_IO_PortB_Dir
   749                      <       		LDA		#00000000b		
   750                      <       		STA		P_IO_PortB_Data		;PB1蜂鸣器，PB0背光
   751                      <       
   752                      <       		LDA		#C_PC7Dir
   753                      <       		STA		P_IO_PortC_Dir
   754                      <       		LDA		#00000000b
   755                      <       		STA		P_IO_PortC_Data		; PC7 debug output, default low.
   756                      <       		
   757                      <       		LDA		#00h
   758                      <       		STA		P_IO_PortD_Attrib		
   759                      <       		LDA		#00000001b		
   760                      <       		STA		P_IO_PortD_Dir
   761                      <       		STA		P_IOD_DIR_Map	
   762                      <       		LDA		#00000010b
   763                      <       		STA		P_IO_PortD_Data		
   764                      <       		STA		R_PortD_Data_Buf
   765                      <       
   766                      <       		LDA		#00000000b			;PE0/PE1/PE2 全部作为按键输入
