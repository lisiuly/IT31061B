   493                      <       ;;Macro Name: %M_SetPC7_InputPL                 Attrib     Dir    Data
   494                      <       ;;Purpose: Set PortC7 iutput pull low            0          0      1
   495                      <       ;;Destroy: A
   496                      <       ;;==========================================================================
   497                      <       ;%M_SetPC7_InputPL:	.MACRO
   498                      <       ;	    LDA		P_IO_PortC_Attrib
   499                      <       ;		AND     #7FH
   500                      <       ;		STA		P_IO_PortC_Attrib
   501                      <       ;		
   502                      <       ;		LDA		P_IO_PortC_Dir
   503                      <       ;		AND     #7FH
   504                      <       ;		STA		P_IO_PortC_Dir
   505                      <       ;		
   506                      <       ;		LDA		P_IO_PortC_Buffer
   507                      <       ;		ORA		#10000000B
   508                      <       ;		STA		P_IO_PortC_Data
   509                      <       ;
   510                      <       ;			.ENDM
   511                      <       ;;==========================================================================
   512                      <       ;;Macro Name: %M_SetPC7_InputPH               Attrib     Dir    Data
   513                      <       ;;Purpose: Set PortC7 iutput pull high         1          0      1
   514                      <       ;;Destroy: A
   515                      <       ;;==========================================================================
   516                      <       ;%M_SetPC7_InputPH:	.MACRO
   517                      <       ;	    LDA		P_IO_PortC_Attrib
   518                      <       ;		ORA     #80H
   519                      <       ;		STA		P_IO_PortC_Attrib
   520                      <       ;		
   521                      <       ;		LDA		P_IO_PortC_Dir
   522                      <       ;		AND     #7FH
   523                      <       ;		STA		P_IO_PortC_Dir
   524                      <       ;		
   525                      <       ;		LDA		P_IO_PortC_Buffer
