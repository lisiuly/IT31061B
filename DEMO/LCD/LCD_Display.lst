  2643                              ;===================================================================
  2644                              ; Shared record initialization helper, still used by KEY.asm.
  2645                              ;===================================================================
  2646                              .PUBLIC			F_Start_RFCMM_Value
  2647 00000182                     F_Start_RFCMM_Value:
  2648                              	%bitr	R_TempFlag1,(D_MaxTemp+D_MinTemp)
  2649 00000182 AD 00 00          1           lda     R_TempFlag1               ;ex.  
  2650 00000185 29 FC             1           and     #.NOT.(D_MaxTemp+D_MinTemp)         ;  %bitr 10H,_BIT0;  10H.0=0
  2651 00000187 8D 00 00          1           sta     R_TempFlag1
  2652 0000018A A9 00               	LDA		#00H
  2653 0000018C AD 00 00            	LDA		R_DispTemper+0
  2654 0000018F 8D 00 00            	STA		R_TempMin+0
  2655 00000192 8D 00 00            	STA		R_TempMax+0
  2656 00000195 AD 01 00            	LDA		R_DispTemper+1
  2657 00000198 8D 01 00            	STA		R_TempMin+1
  2658 0000019B 8D 01 00            	STA		R_TempMax+1
  2659 0000019E AD 00 00            	LDA		R_DispTemper_F
  2660 000001A1 8D 00 00            	STA		R_MINDispTemper_F
  2661 000001A4 8D 00 00            	STA		R_MAXDispTemper_F
  2662                              
  2663 000001A7 AD 01 00            	LDA		R_DispTemper_F+1
  2664 000001AA 8D 01 00            	STA		R_MINDispTemper_F+1
  2665 000001AD 8D 01 00            	STA		R_MAXDispTemper_F+1
  2666                              
  2667 000001B0 AD 00 00            	LDA		R_DispHum
  2668 000001B3 8D 00 00            	STA		R_HumMax
  2669 000001B6 8D 00 00            	STA		R_HumMin
  2670                              
  2671 000001B9 AD 00 00            	LDA		R_SpecFlag
  2672 000001BC 8D 00 00            	STA		R_TempMax_Sign
  2673 000001BF 8D 00 00            	STA		R_TempMin_Sign
  2674                              
  2675 000001C2 AD 00 00            	LDA		R_TempFlag
  2676 000001C5 29 04               	AND		#D_TempFReg
  2677 000001C7 0D 00 00            	ORA		R_TempMax_Sign
  2678 000001CA 8D 00 00            	STA		R_TempMax_Sign
