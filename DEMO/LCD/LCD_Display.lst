   503                      <       ;;Macro Name: %M_SetPC7_Output             Attrib     Dir    Data
   504                      <       ;;Purpose: Set PortC7 driving  high          0         1      1
   505                      <       ;;Destroy: A
   506                      <       ;;==========================================================================
   507                      <       ;%M_SetPC7_OutputH:	.MACRO
   508                      <       ;        LDA		P_IO_PortC_Attrib
   509                      <       ;		AND     #7FH
   510                      <       ;		STA		P_IO_PortC_Attrib
   511                      <       ;		
   512                      <       ;		LDA		P_IO_PortC_Dir
   513                      <       ;		ORA     #80H
   514                      <       ;		STA		P_IO_PortC_Dir
   515                      <       ;		
   516                      <       ;		LDA		P_IO_PortC_Buffer
   517                      <       ;		ORA		#10000000B
   518                      <       ;		STA		P_IO_PortC_Data
   519                      <       ;		
   520                      <       ;			.ENDM
   521                      <       ;----------------------------------------------------------
   522                      <       ;/***********************************************/
   523                      <       ;         i.L=1 
   524                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   525                      <                 lda     i               ;ex.  
   526                      <                 ora     #L              ;  %bits 10H,_BIT0
   527                      <       		                   ;  10H.0=1
   528                      <                 sta     i               ;
   529                      <                .ENDM    
   530                      <       
   531                      <       ;/***********************************************/
   532                      <       ;         i.L=0
   533                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   534                      <                 lda     i               ;ex.  
   535                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   536                      <                 sta     i
   537                      <                .ENDM    
   538                      <       
   539                      <       ;/***********************************************/
   540                      <       ;         if(i.L==1) goto N
   541                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   542                      <                 lda     i               ;ex.   
   543                      <                 and     #L              ;  %btst 10H,_BIT0,N
   544                      <                 bne     N               ;  if(10H.0=1) goto N 
   545                      <                .ENDM    
   546                      <                                         
   547                      <       ;/***********************************************/
   548                      <       ;         if(i.L==0) goto N
   549                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   550                      <                 lda     i               ;ex.   
   551                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   552                      <                 beq     N               ;  if(10H.0=0) goto N 
   553                      <                .ENDM    
   554                      <       ;/***********************************************/
   555                      <       ;         if(i==#0) goto N
   556                      <       %jz:     .MACRO   i,N             ;BYTE i;
   557                      <                 lda     i               ;ex.
   558                      <                 beq     N               ;  %jz 10H,N
   559                      <                .ENDM                    ;  if(10H==#0) goto N
   560                      <       
   561                      <       ;/***********************************************/
   562                      <       ;         if(i!=#0) goto N
   563                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   564                      <                 lda     i               ;ex.
   565                      <                 bne     N               ;  %jnz 10H,N
   566                      <                .ENDM                    ;  if($10!=#0) goto N
