  1159                      <       ; RF发码协议位宽:
  1160                      <       ; Bit0 = 高500us + 低2000us
  1161                      <       ; Bit1 = 高500us + 低1000us
  1162                      <       C_RFBitHigh500us		equ	500
  1163                      <       C_RFBit0Low2000us		equ	2000
  1164                      <       C_RFBit1Low1000us		equ	1000
  1165                      <       C_RFPacketBits36		equ	36
  1166                      <       
  1167                      <       ; RF收码低脉宽按 Timer0 实测约 4.096kHz 的样本数喂入:
  1168                      <       ; bit1 约 4~5 sample，bit0 约 8~9 sample，停止位约 16~20 sample。
  1169                      <       C_RFBitHighMinSample		equ	01H
  1170                      <       C_RFBitHighMaxSample		equ	03H
  1171                      <       C_RFBit1LowMinSample		equ	03H
  1172                      <       C_RFBit1LowMaxSample		equ	06H
  1173                      <       C_RFBit0LowMinSample		equ	07H
  1174                      <       C_RFBit0LowMaxSample		equ	0AH
  1175                      <       C_RFStopLowMinSample		equ	0FH
  1176                      <       C_RFStopLowMaxSample		equ	16H
