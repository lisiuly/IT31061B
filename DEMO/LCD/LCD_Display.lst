  2981                              ; 调试: 切 CH1/CH2/CH3/Auto 时看 X/Y 是否落在 0/0、0Ah/1、14h/2。
  2982 0000032B                     Disp_ProductLoadRFViewOffset:
  2983                              			; X 返回通道数据偏移(0/10/20)，Y 返回趋势数组索引(0/1/2)。
  2984 0000032B A2 00               			LDX		#00H
  2985 0000032D A0 00               			LDY		#00H
  2986 0000032F AD 00 00            			LDA		R_RFViewChannel
  2987 00000332 C9 02               			CMP		#D_RFCh2
  2988 00000334 D0 05               			BNE		Disp_ProductLoadRFViewOffset_CheckCh3
  2989 00000336 A2 0A               			LDX		#0AH
  2990 00000338 A0 01               			LDY		#01H
  2991 0000033A 60                  			RTS
  2992 0000033B                     Disp_ProductLoadRFViewOffset_CheckCh3:
  2993 0000033B C9 03               			CMP		#D_RFCh3
  2994 0000033D D0 04               			BNE		Disp_ProductLoadRFViewOffset_End
  2995 0000033F A2 14               			LDX		#14H
  2996 00000341 A0 02               			LDY		#02H
