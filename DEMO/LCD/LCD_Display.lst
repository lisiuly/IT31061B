   668                      <       ; Macro Name:	%FillLcdDpram
   669                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   670                      <       ;-----------------------------------------------------------------------------
   671                      <       %FillLcdDpram	.MACRO	mData
   672                      <       		
   673                      <       		%WatchDogClear
   674                      <       		LDX		#00H
   675                      <       		LDY		#00H
   676                      <       ?L_ClrDpramLoop:
   677                      <       		LDA     mData
   678                      <       		STA		$3E00,X
   679                      <       		INY
   680                      <       		CPY		#04H
   681                      <       		BNE		?L_ClrDpramLoopI
   682                      <       		LDY		#00H
   683                      <       		TXA
   684                      <       		CLC
   685                      <       		ADC		#0CH
   686                      <       		TAX
   687                      <       ?L_ClrDpramLoopI:		
   688                      <       		INX
   689                      <       		CPX		#80H
   690                      <       		BNE		?L_ClrDpramLoop
   691                      <       	.ENDM
