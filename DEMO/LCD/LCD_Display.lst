   225                      <       ;**********************************************************************
   226                      <       ;ROM Checksum
   227                      <       ;**********************************************************************
   228                      <       ;.IF (GPL813P01Ax+GPL813P01Bx+GPL813P01Cx)
   229                      <       ;	D_BankNum:						.EQU	1	
   230                      <       ;.ENDIF
   231                      <       
   232                      <       	D_Bank0UserRomStartAddr:		.EQU	0xE000		;0x4800 ~ 0x7FDF:User ROM Code
   233                      <       	D_Bank0UserRomEndAddr:			.EQU	0xFFDF
   234                      <       	D_NMIandResetVectorStartAddr:	.EQU	0xFFFC		;0xFFF8 ~ 0xFFF9:User ROM Code, 0xFFFA ~ 0xFFFF:NMI & Reset & IRQ vector
   235                      <       	D_NMIandResetVectorEndAddr:		.EQU	0xFFFF
   236                      <       
   237                      <       ; ========================================================================================
   238                      <       ; Macro Name	: M_UserRomChecksum
   239                      <       ; Parameters	: None
   240                      <       ; Return Value	: R_ChecksumResult: bit[7:0]
   241                      <       ;				: R_ChecksumResult + 1: bit[15:8]
   242                      <       ;				: R_ChecksumResult + 2: bit[23:16]
   243                      <       ;				: R_ChecksumResult + 3: bit[31:24]
   244                      <       ; Description	: Calculate user ROM area code checksum
   245                      <       ; Destroy		: A, Y
   246                      <       ; Example		: %M_UserRomChecksum	R_ChecksumAddrPtr, R_ChecksumResult
   247                      <       ; ========================================================================================	
   248                      <       %M_UserRomChecksum:	.MACRO	R_ChecksumAddrPtr, R_ChecksumResult
   249                      <       	
   250                      <       	LDA		#0
   251                      <       	STA		R_ChecksumResult						;Result Byte0
   252                      <       	STA		R_ChecksumResult + 1				;Result Byte1
   253                      <       	STA		R_ChecksumResult + 2				;Result Byte2
   254                      <       	STA		R_ChecksumResult + 3				;Result Byte3
   255                      <       ;=================== Bank 0 ==================================================	
   256                      <       	LDA		#.HIGH.D_Bank0UserRomStartAddr
   257                      <       	STA		R_ChecksumAddrPtr + 1				;Start High Byte
   258                      <       	LDA		#.LOW.D_Bank0UserRomStartAddr
   259                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   260                      <       		
   261                      <       	LDY		#0	
   262                      <       
   263                      <       L_ChecksumLoop1?
   264                      <       	STA		P_WDT_Flag_Clear	
   265                      <       	CLC
   266                      <       	LDA		(R_ChecksumAddrPtr),Y
   267                      <       	ADC		R_ChecksumResult						;Result Low Byte
   268                      <       	STA		R_ChecksumResult						;Result Low Byte
   269                      <       	BCC		L_CheckAddress1?
   270                      <       	INC		R_ChecksumResult + 1				;Result Byte1
   271                      <       	BNE		L_CheckAddress1?
   272                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   273                      <       	BNE		L_CheckAddress1?
   274                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   275                      <       		
   276                      <       L_CheckAddress1?:
   277                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   278                      <       	CMP		#.HIGH.D_Bank0UserRomEndAddr		;End High Byte
   279                      <       	BNE		L_IncreaseAdd1?
   280                      <       	
   281                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   282                      <       	CMP		#.LOW.D_Bank0UserRomEndAddr			;End Low Byte
   283                      <       	BEQ		L_ExitRomSum1?
   284                      <       	
   285                      <       L_IncreaseAdd1?:
   286                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   287                      <       	BNE		L_ChecksumLoop1?
   288                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   289                      <       	JMP		L_ChecksumLoop1?	
   290                      <       		
   291                      <       L_ExitRomSum1?:	
   292                      <       
   293                      <       ;===================NMI & Reset Vector==================================================		
   294                      <       	LDA		#.HIGH.D_NMIandResetVectorStartAddr
   295                      <       	STA		R_ChecksumAddrPtr + 1				; Start High Byte
   296                      <       	LDA		#.LOW.D_NMIandResetVectorStartAddr
   297                      <       	STA		R_ChecksumAddrPtr						;Start Low Byte
   298                      <       		
   299                      <       L_ChecksumLoop2?
   300                      <       	STA		P_WDT_Flag_Clear		
   301                      <       	CLC
   302                      <       	LDA		(R_ChecksumAddrPtr),Y
   303                      <       	ADC		R_ChecksumResult						;Result Low Byte
   304                      <       	STA		R_ChecksumResult						;Result Low Byte
   305                      <       	BCC		L_CheckAddress2?
   306                      <       	INC		R_ChecksumResult + 1				;Result Byte2
   307                      <       	BNE		L_CheckAddress2?
   308                      <       	INC		R_ChecksumResult + 2				;Result Byte3
   309                      <       	BNE		L_CheckAddress2?
   310                      <       	INC		R_ChecksumResult + 3				;Result Byte4
   311                      <       		
   312                      <       L_CheckAddress2?:
   313                      <       	LDA		R_ChecksumAddrPtr + 1				;Address Pointer HB
   314                      <       	CMP		#.HIGH.D_NMIandResetVectorEndAddr	;End High Byte
   315                      <       	BNE		L_IncreaseAdd2?
   316                      <       	
   317                      <       	LDA		R_ChecksumAddrPtr						;Address Pointer LB
   318                      <       	CMP		#.LOW.D_NMIandResetVectorEndAddr	;End Low Byte
   319                      <       	BEQ		L_ExitRomSum2?
   320                      <       	
   321                      <       L_IncreaseAdd2?:
   322                      <       	INC		R_ChecksumAddrPtr						;Address Pointer LB
   323                      <       	BNE		L_ChecksumLoop2?
   324                      <       	INC		R_ChecksumAddrPtr + 1				;Address Pointer HB
   325                      <       	JMP		L_ChecksumLoop2?	
   326                      <       		
   327                      <       L_ExitRomSum2?:	
   328                      <       ;;=====================Bank area================================================		
   329                      <       	
   330                      <       	.ENDM
   331                      <       ;================================================================================
   332                      <       
   333                      <       			.ENDIF
   334                      <       .ENDIF
   335                      <       	.ENDIF
