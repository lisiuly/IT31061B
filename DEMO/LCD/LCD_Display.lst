  2646                              ; ;===================================================================
  2647                              ; ; Shared record initialization helper, still used by KEY.asm.
  2648                              ; ;===================================================================
  2649                              ; .PUBLIC			F_Start_RFCMM_Value
  2650                              ; ; 输入: 当前已经准备好的室内温湿度显示缓存与符号标志。
  2651                              ; ; 输出: 初始化温湿度最大/最小记录缓存，供上电后极值与记录页复用。
  2652                              ; ; 调试: 看 R_TempMin/Max、R_MIN/MAXDispTemper_F、R_HumMin/Max 是否被当前值覆盖。
  2653                              ; F_Start_RFCMM_Value:
  2654                              ; 	%bitr	R_TempFlag1,(D_MaxTemp+D_MinTemp)
  2655                              ; 	LDA		#00H
  2656                              ; 	LDA		R_DispTemper+0
  2657                              ; 	STA		R_TempMin+0
  2658                              ; 	STA		R_TempMax+0
  2659                              ; 	LDA		R_DispTemper+1
  2660                              ; 	STA		R_TempMin+1
  2661                              ; 	STA		R_TempMax+1
  2662                              ; 	LDA		R_DispTemper_F
  2663                              ; 	STA		R_MINDispTemper_F
  2664                              ; 	STA		R_MAXDispTemper_F
  2665                              
  2666                              ; 	LDA		R_DispTemper_F+1
  2667                              ; 	STA		R_MINDispTemper_F+1
  2668                              ; 	STA		R_MAXDispTemper_F+1
  2669                              
  2670                              ; 	LDA		R_DispHum
  2671                              ; 	STA		R_HumMax
  2672                              ; 	STA		R_HumMin
  2673                              
  2674                              ; 	LDA		R_SpecFlag
  2675                              ; 	STA		R_TempMax_Sign
  2676                              ; 	STA		R_TempMin_Sign
  2677                              
  2678                              ; 	LDA		R_TempFlag
  2679                              ; 	AND		#D_TempFReg
  2680                              ; 	ORA		R_TempMax_Sign
  2681                              ; 	STA		R_TempMax_Sign
  2682                              
  2683                              ; 	LDA		R_TempFlag
  2684                              ; 	AND		#D_TempFReg
  2685                              ; 	ORA		R_TempMin_Sign
  2686                              ; 	STA		R_TempMin_Sign
  2687                              ; 	RTS
  2688                              
  2689                              ;==============================================================================
  2690                              ; 产品显示框架
  2691                              ; 86428 规格只保留标准显示页，这里直接走标准刷新链。
  2692                              ;==============================================================================
  2693                              ; 输入: R_TimeStatus 的 AddOthers/AddSecondOnly 以及当前 RF 无数据闪烁状态。
  2694                              ; 输出: 在需要刷新时重绘标准页主体；否则直接返回。
  2695                              ; 调试: 看 R_TimeStatus、Disp_ProductIsOutdoorLostFlashMode 的返回以及 LCD DpRam 是否更新。
  2696 00000182                     F_Display:
  2697 00000182                     F_DisplayProductUI:
  2698 00000182 AD 00 00            			LDA		R_TimeStatus
  2699 00000185 29 10               			AND		#AddOthers
  2700 00000187 D0 0C               			BNE		Disp_ProductUpdateAll
  2701 00000189 AD 00 00            			LDA		R_TimeStatus
  2702 0000018C 29 20               			AND		#AddSecondOnly
  2703 0000018E F0 08               			BEQ		Disp_ProductDisplayExit
  2704 00000190 20 67 03            			JSR		Disp_ProductIsOutdoorLostFlashMode
  2705 00000193 90 03               			BCC		Disp_ProductDisplayExit
  2706                              
  2707 00000195                     Disp_ProductUpdateAll:
  2708                              			; 86428 新玻璃只保留当前页，不再驱动旧页签位。
  2709 00000195 20 99 01            			JSR		Disp_ProductRefreshPagedBody
  2710 00000198                     	Disp_ProductDisplayExit:
  2711 00000198 60                  			RTS
  2712                              
  2713                              ; 输入: 已经判定本次需要刷新整页。
  2714                              ; 输出: 清增量标志并刷新标准显示页的公共主体。
