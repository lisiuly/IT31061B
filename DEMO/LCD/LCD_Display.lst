   611                      <       ;-----------------------------------------------------------------------------
   612                      <       ; Macro Name:	%FillSram
   613                      <       ; Description:	Fill data to SRAM whole space
   614                      <       ; Input:		mData
   615                      <       ;-----------------------------------------------------------------------------	
   616                      <       %FillSram		.MACRO	mData
   617                      <       		
   618                      <       		LDA		#.LOW.(C_SramAddrStart+2)
   619                      <       		STA		C_SramAddrStart
   620                      <       		LDA		#.HIGH.(C_SramAddrStart+2)
   621                      <       		STA		C_SramAddrStart+1
   622                      <       		
   623                      <       		LDX     #0
   624                      <       ?L_FillLoop#:
   625                      <               LDA     mData
   626                      <       		STA     (C_SramAddrStart,X)
   627                      <       		
   628                      <       		LDA     C_SramAddrStart+1
   629                      <       		CMP     #.HIGH.C_SramAddrEnd
   630                      <       		BCC     ?L_IncSramAddr#
   631                      <       		LDA     C_SramAddrStart
   632                      <       		CMP     #.LOW.C_SramAddrEnd
   633                      <       		BCS     ?L_End#
   634                      <       		
   635                      <       ?L_IncSramAddr#:    ;Increase sram address
   636                      <               INC     C_SramAddrStart
   637                      <       		BNE     ?L_FillLoop#
   638                      <       		INC     C_SramAddrStart+1
   639                      <       		%WatchDogClear
   640                      <               JMP     ?L_FillLoop#
   641                      <       ?L_End#:
   642                      <               
   643                      <               LDA     mData
   644                      <               STA     C_SramAddrStart
   645                      <               STA     C_SramAddrStart+1
   646                      <               
   647                      <               LDX		#00H
   648                      <       ?L_HSRAMloop:
   649                      <       		LDA		mData
   650                      <       		STA		$180,X
   651                      <       		INX	
   652                      <       		CPX		#80H
   653                      <       		BNE		?L_HSRAMloop
   654                      <       		
   655                      <       	.ENDM
   656                      <       	
   657                      <       ;-----------------------------------------------------------------------------
   658                      <       ; Macro Name:	%ClrSRAM
   659                      <       ; Description:	Clear SRAM $60 ~ $95F
   660                      <       ;-----------------------------------------------------------------------------	
   661                      <       %ClrSRAM:	.MACRO
   662                      <       
   663                      <       		%FillSram	#0
   664                      <       
   665                      <       	.ENDM
   666                      <       ;-----------------------------------------------------------------------------
   667                      <       ;-----------------------------------------------------------------------------
   668                      <       ; Macro Name:	%FillLcdDpram
   669                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   670                      <       ;-----------------------------------------------------------------------------
   671                      <       %FillLcdDpram	.MACRO	mData
   672                      <       		
   673                      <       		%WatchDogClear
   674                      <       		LDX		#00H
   675                      <       		LDY		#00H
   676                      <       ?L_ClrDpramLoop:
   677                      <       		LDA     mData
   678                      <       		STA		$3E00,X
   679                      <       		INY
   680                      <       		CPY		#04H
   681                      <       		BNE		?L_ClrDpramLoopI
   682                      <       		LDY		#00H
   683                      <       		TXA
   684                      <       		CLC
   685                      <       		ADC		#0CH
   686                      <       		TAX
   687                      <       ?L_ClrDpramLoopI:		
   688                      <       		INX
   689                      <       		CPX		#80H
   690                      <       		BNE		?L_ClrDpramLoop
   691                      <       	.ENDM
