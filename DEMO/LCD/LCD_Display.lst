   378                      <       ;Macro Name: %M_ClearWatchDog
   379                      <       ;Purpose: Clear Watchdog
   380                      <       ;Destroy: A
   381                      <       ;;============================================================================
   382                      <       %M_ClearWatchDog:		.MACRO 
   383                      <       	LDA		#D_WDT_Clear
   384                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   385                      <       	.ENDM
   386                      <       ;;============================================================================
   387                      <       ;Macro Name: %M_DisAllInt
   388                      <       ;Purpose: Disable all interrupt 
   389                      <       ;Destroy: A
   390                      <       ;;============================================================================
   391                      <       %F_InitINT:		.MACRO
   392                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   393                      <       		STA		P_TIMER_TimeBase_Sel		
   394                      <       		LDA		#D_128HzInt+D_TMBAInt+D_TMBBInt;D_Timer0Int+
   395                      <       		STA		P_INT_Ctrl
   396                      <       ;		LDA		#00
   397                      <       ;		STA		P_INT_Ctrl2		;disable TMR1 INT
   398                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   399                      <       ;		STA		P_TIMER_Timer0_Ctrl
   400                      <       ;		LDA		#0FCH
   401                      <       ;		STA		P_TIMER_TM0Data_LB		; Timer0 reload = FFFCh, scope now shows about 4.096kHz IRQ on this board.
   402                      <       ;		LDA		#0FFH
   403                      <       ;		STA		P_TIMER_TM0Data_HB
   404                      <       ;		STA		P_TIMER_TM0Load_Ctrl
   405                      <       	.ENDM
   406                      <       ;;============================================================================
   407                      <       ;Macro Name: %DisableLCD
   408                      <       ;Purpose: Disable LCD
   409                      <       ;Destroy: A
   410                      <       ;;============================================================================
   411                      <       %DisableLCD:		.MACRO
   412                      <       	
   413                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   414                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   415                      <       		
   416                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
   417                      <       		STA     P_LCD_VLCD_Ctrl
   418                      <       	.ENDM
   419                      <       ;-----------------------------------------------------------------------------
   420                      <       ; Macro Name:	%M_InitLCD
   421                      <       ; Description:	Initialize LCD configuration after power on
   422                      <       ;-----------------------------------------------------------------------------	
   423                      <       ;%M_InitLCD:		.MACRO
   424                      <       ;    LDA		#D_LCDMode_Normal+D_LCDSetting_3Bias_4Duty+D_LCDGreenMode_En
   425                      <       ;;	LDA		#(D_LCDMode_Normal+D_LCDSetting_3Bias_4Duty)
   426                      <       ;	STA		P_LCD_Ctrl		;1/4duty,1/3bias,normal scan
   427                      <       ;
