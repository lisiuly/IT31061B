   867                      <       LCDConvert		.MACRO  com,seg
   868                      <       ;			DB	com*8+(seg/8)+00H,1<<(seg.AND.07H)
   869                      <       ;			DB	(com*8+07H)-(seg/8),1<<(seg.AND.07H)	;LB25B
   870                      <       ;			DB	com*4+(seg/8)+50H,1<<(seg.AND.07H)	;L11A\B
   871                      <       ;			DB	com*6+(seg/8)+20H,1<<(seg.AND.07H)	;L31B
   872                      <       ;LCDConvert:		.Macro	com,seg
   873                      <       ;			DB	com*4+(seg/8)+A0H,1<<(seg.AND.07H)	;GPL10A
   874                      <       			DB	com*10H+(seg/8)+00H,1<<(seg.AND.07H)	;GPL813P01;
   875                      <       			
   876                      <       			.ENDM
