;=========================================== 
			;显示七段码
;===========================================
F_DispTheSevenSegChar:
		LDA	T_SevenSegCharBitMapTab,X
	F_DisplaySevenIcon:					;取得显示点的序列的起始地址
		STA	R_Temp1								;R_Temp1存放字符的位映射
		TYA
		ASL	A		; A<128
		TAX
		LDA	T_SevenSegCharPosIndexTab,X
		STA	R_Temp3
		LDA	T_SevenSegCharPosIndexTab+1,X	;取字符的显示映射表的地址
		STA	R_Temp4
	;------
	;dot start addr:R_Temp3,R_Temp4. disp byte:R_Temp1.
	;F_DispByte:
		LDA	#7		
		STA	R_Temp2
	L_DispByte_1:
		LDX	#0
		LDA	(R_Temp3,X)
		STA	R_Temp0
		INC	R_Temp3
		BNE	L_DispByte_1_0
		INC	R_Temp4
	L_DispByte_1_0:
		LDA	(R_Temp3,X)
		INC	R_Temp3
		BNE	L_DispByte_1_1
		INC	R_Temp4
	L_DispByte_1_1:
		LDX	R_Temp0
		ROR	R_Temp1
		BCS	L_DispByte_1_1_1
	L_DispByte_1_1_0:
		STA	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp0
		EOR	R_Temp0
		STA	$3E00,X
		DEC	R_Temp2
		BNE	L_DispByte_1
		RTS
	L_DispByte_1_1_1:
		STA	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp0
		STA	$3E00,X			
		DEC	R_Temp2
		BNE	L_DispByte_1
		RTS
;=============================
;input x
;=============================
F_DisplayBit:
		LDA	T_ICON,x
		STA	R_Temp0
		inx
		LDA	T_ICON,x
		STA	R_Temp1
		LDX	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp1
		STA	$3E00,X			
		RTS
;=============================
;input x
;=============================
F_NoDisplayBit:
		LDA	T_ICON,x
		STA	R_Temp0
		inx
		LDA	T_ICON,x
		EOR	#FFH
		STA	R_Temp1
		LDX	R_Temp0
		LDA	$3E00,X
		and	R_Temp1
		STA	$3E00,X			
		RTS		
;==========================================
; Constant define area
;==========================================
;LCD order
;Pin1_pin18
;c7~c0,s0~s9 (按照LCD图定义值来定义
.if 1		;0, RealChip   1 ;LCD Ev.board
;.IF	
C_Com0		EQU	0x00			;com0
C_Com1		EQU	0x10			;com1
C_Com2		EQU	0x20			;com2
C_Com3		EQU	0x30			;com3
C_Com4		EQU	0x40			;com4
C_Com5		EQU	0x50			;com5
C_Com6		EQU	0x60			;com6
C_Com7		EQU	0x70			;com7
.else
C_Com0		EQU	0x70			;com0
C_Com1		EQU	0x60			;com1
C_Com2		EQU	0x50			;com2
C_Com3		EQU	0x40			;com3
C_Com4		EQU	0x30			;com4
C_Com5		EQU	0x20			;com5
C_Com6		EQU	0x10			;com6
C_Com7		EQU	0x00			;com7
.endif
Seg00		EQU	0
Seg01		EQU	1
Seg02		EQU	14
Seg03		EQU	15
Seg04		EQU	16
Seg05		EQU	17
Seg06		EQU	18
Seg07		EQU	19
Seg08		EQU	20


C_S00		EQU	00000001B
C_S01		EQU	00000010B
C_S02		EQU	00000100B
C_S03		EQU	00001000B
C_S04		EQU	00010000B
C_S05		EQU	00100000B
C_S06		EQU	01000000B
C_S07		EQU	10000000B
C_S08		EQU	00000001B
C_S09		EQU	00000010B
C_S10		EQU	00000100B
C_S11		EQU	00001000B
C_S12		EQU	00010000B
C_S13		EQU	00100000B
C_S14		EQU	01000000B
C_S15		EQU	10000000B
C_S16		EQU	00000001B
C_S17		EQU	00000010B
C_S18		EQU	00000100B
C_S19		EQU	00001000B
C_S20		EQU	00010000B
C_S21		EQU	00100000B
C_S22		EQU	01000000B
C_S23		EQU	10000000B
C_S24		EQU	00000001B
C_S25		EQU	00000010B
C_S26		EQU	00000100B
C_S27		EQU	00001000B
C_S28		EQU	00010000B
C_S29		EQU	00100000B
C_S30		EQU	01000000B
C_S31		EQU	10000000B

C_Seg00		EQU	C_S00
C_Seg01		EQU	C_S01
C_Seg02		EQU	C_S14
C_Seg03		EQU	C_S15
C_Seg04		EQU	C_S16
C_Seg05		EQU	C_S17
C_Seg06		EQU	C_S18
C_Seg07		EQU	C_S19
C_Seg08		EQU	C_S20

;==========================================================
.CODE
;------------------------------
;C_NotDispThisDigital	EQU	0AH
;==========================================================
T_SevenSegCharPosIndexTab:
	DW	T_Digit1DispTab   ;1		;D1
	DW	T_Digit2DispTab   ;2		;D2
	DW	T_Digit3DispTab   ;3		;D3
	DW	T_Digit4DispTab   ;4		;D4

;==========================================================
T_SevenSegCharBitMapTab:
;	       0,         1,       2,        3,        4
	DB	00111111B,00000110B,01011011B,01001111B,01100110B
;	       5,         6,       7,        8,        9
	DB	01101101B,01111101B,00000111B,01111111B,01101111B
;	       A,-空     B,-"V"    C,"L"      D'r'      E'H'      
	DB	00000000B,00111110B,00111000B,01010000B,01110110b
;		F;'-'  	10_Sun	 11_Mon		12_Tue  13-Wed		14-Thu	15-Fri		16-Sat
	DB	01000000B,01000000B,00000001B,00000010B,00000100B,00001000B,00010000B,00100000B
;---
;format:byte index;mask bT_Digit1DispTabit
; ================================
T_Digit1DispTab:   ;;D1				Hour H
	DB	C_Com0+Seg08/8,C_Seg08 ;a
	DB	C_Com1+Seg08/8,C_Seg08 ;b
	DB	C_Com2+Seg08/8,C_Seg08 ;c
	DB	C_Com3+Seg08/8,C_Seg08 ;d 
	DB	C_Com3+Seg09/8,C_Seg09 ;e
	DB	C_Com2+Seg09/8,C_Seg09 ;f 
	DB	C_Com2+Seg09/8,C_Seg09 ;g
T_Digit1DispTabEnd:
; ================================
T_Digit2DispTab:   ;;D2				Hour L
	DB	C_Com0+Seg06/8,C_Seg06 ;a
	DB	C_Com1+Seg06/8,C_Seg06 ;b
	DB	C_Com2+Seg06/8,C_Seg06 ;c
	DB	C_Com3+Seg06/8,C_Seg06 ;d 
	DB	C_Com3+Seg07/8,C_Seg07 ;e
	DB	C_Com1+Seg07/8,C_Seg07 ;f 
	DB	C_Com2+Seg07/8,C_Seg07 ;g
T_Digit2DispTabEnd:					
; ================================
T_Digit3DispTab:   ;;D3				Minute	H
	DB	C_Com0+Seg04/8,C_Seg04 ;a
	DB	C_Com1+Seg04/8,C_Seg04 ;b
	DB	C_Com2+Seg04/8,C_Seg04 ;c
	DB	C_Com3+Seg04/8,C_Seg04 ;d 
	DB	C_Com3+Seg05/8,C_Seg05 ;e
	DB	C_Com1+Seg05/8,C_Seg05 ;f 
	DB	C_Com2+Seg05/8,C_Seg05 ;g
T_Digit3DispTabEnd:
; ================================
T_Digit4DispTab:   ;;D4				Minute L
	DB	C_Com0+Seg02/8,C_Seg02 ;a
	DB	C_Com1+Seg02/8,C_Seg02 ;b
	DB	C_Com2+Seg02/8,C_Seg02 ;c
	DB	C_Com3+Seg02/8,C_Seg02 ;d 
	DB	C_Com3+Seg03/8,C_Seg03 ;e
	DB	C_Com1+Seg03/8,C_Seg03 ;f 
	DB	C_Com2+Seg03/8,C_Seg03 ;g
T_Digit4DispTabEnd:
; ================================	
	
	
T_ICON:
T_AM	EQU	$-T_ICON				;	时钟AM
	DB	C_Com0+Seg07/8,C_Seg07 ;	
T_PM	EQU	$-T_ICON				;	时钟PM
	DB	C_Com0+Seg03/8,C_Seg03 ;
T_COL	EQU	$-T_ICON				;	Colon
	DB	C_Com0+Seg05/8,C_Seg05 ;
	
T_SET	EQU	$-T_ICON				;	SET
	DB	C_Com1+Seg00/8,C_Seg00 ;
	
T_LOCK	EQU	$-T_ICON				;	LOCK
	DB	C_Com2+Seg00/8,C_Seg00 ;
	
T_CLK	EQU	$-T_ICON				;	CLOCK
	DB	C_Com3+Seg00/8,C_Seg00 ;

;*************************************************************************	
.END  	
