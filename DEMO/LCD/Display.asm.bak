;==========================================
;LCD order
;Pin1_pin18
;c7~c0,s0~s9 (按照LCD图定义值来定义
.if 1		;0, RealChip   1 ;LCD Ev.board
;.IF	
C_Com0		EQU	0x00			;com0
C_Com1		EQU	0x10			;com1
C_Com2		EQU	0x20			;com2
C_Com3		EQU	0x30			;com3
C_Com4		EQU	0x40			;com4
C_Com5		EQU	0x50			;com5
C_Com6		EQU	0x60			;com6
C_Com7		EQU	0x70			;com7
.else
C_Com0		EQU	0x70			;com0
C_Com1		EQU	0x60			;com1
C_Com2		EQU	0x50			;com2
C_Com3		EQU	0x40			;com3
C_Com4		EQU	0x30			;com4
C_Com5		EQU	0x20			;com5
C_Com6		EQU	0x10			;com6
C_Com7		EQU	0x00			;com7

.endif
