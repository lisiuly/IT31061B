;==========================================
.SYNTAX 6502
.LINKLIST
.SYMBOLS
;==========================================
; Include file area
;==========================================
.INCLUDE 	GPL813x.inc
.INCLUDE	sys\Macro.inc
.INCLUDE	key\Key.inc
.INCLUDE	rtc\RTC.inc
;.INCLUDE	RFC\RFC_user.inc
;==========================================
; External declare area
;==========================================
;==========================================
; Public declare area
;==========================================
.PUBLIC			F_Display
.PUBLIC			F_DisplayHLValue

;.PUBLIC			F_DisplayBatIcon		
;------------------------------------------
.PUBLIC			R_TempBuf
;==========================================
;Variable RAM declare area
;========================================== 
.PAGE0
R_Temp0			ds		1
R_Temp1			ds		1
R_Temp2			ds		1
R_Temp3			ds		1
R_Temp4			ds		1
R_DisplayTemp	ds		1
R_DispNumValue	ds		1

R_TempBuf		ds		6

R_Charging		ds		1
;==============================================================================
.CODE
;==============================================================================
F_Display:                       ;
	
		LDA		R_TimeStatus
		AND		#AddOthers
		BNE		Update_AllDisp	
		%btsf	R_TimeStatus,HalfSecToggle,Disp_COL
		
		LDX		#T_BT
		JSR		F_NoDisplayBit
		RTS
		
	Update_AllDisp:
		NOP
		JSR		F_ClearIncStatus     ;清标志		
		JSR		F_DispCurrentTemp
		JSR		F_DispTargetTemp     ;显示分钟
		LDX		#T_FIRE
		JSR		F_DisplayBit
	Disp_COL:	
		LDX		#T_BT
		JSR		F_DisplayBit

		RTS
;==========================================================	
;==========================================================
Flash_DispTimeSet:				;设置时间的闪动
		%btst	R_KeyFlag,D_EnableFastAdd,?Disp_AllTimeValue
		%btsf	R_TimeStatus,HalfSecToggle,?Disp_AllTimeValue
		LDA		R_TimeFlashSet
		CMP		#D_SetHour
		BNE		$+5
		JMP		F_NoDisplay_Hour
		CMP		#D_SetMinute
		BNE		$+5
		JMP		F_NoDisplay_Minute
		RTS
?Disp_AllTimeValue:
		JSR		F_ClearIncStatus
		JSR		F_Display_Hour
		JSR		F_Display_Minute
		RTS
;==========================================================	

;==========================================================

		
;==========================================================
;==========================================================		
F_Display_Hour:	
			lda	RTC+0
			TAX
			LDA		T_24To12Table,x
			STA		R_DisplayTemp
			JSR		F_4RORA
			AND		#0FH
			BNE		?L_DispHH
			LDX		#T_FIRE
			JSR		F_NoDisplayBit
			JMP		?L_DispHL
	?L_DispHH:
			LDX		#T_BT
			JSR		F_DisplayBit
	?L_DispHL:
			LDA		R_DisplayTemp
			AND		#0FH
			TAX
			LDY		#01
			jmp		F_DispTheSevenSegChar				
T_24To12Table:
		DB 12H,01H,02H,03H,04H,05H,06H,07H,08H,09H,00H,00H,00H,00H,00H,00H,10H,11H	
 		DB 12H,01H,02H,03H,04H,05H,06H,07H,00H,00H,00H,00H,00H,00H,08H,09H,10H,11H			
;====================
F_NoDisplay_Hour:
;		LDX		#T_BC
;		JSR		F_NoDisplayBit	
		LDX		#0FH
		LDY		#08                 
		JMP		F_DispTheSevenSegChar    ;			
;========================================================== 		
F_Display_Minute:                         ;显示分钟 
		LDA     RTC+1
		JSR		F_4RORA
		AND		#0FH
		TAX			    ;显示的字符
		LDY		#02                 
		JSR		F_DispTheSevenSegChar    ;显示分钟的高位;                
   	    LDA	    RTC+1
        AND		#0FH
		TAX			    ;显示的字符
		LDY		#03                       ;显示分钟的低位   ;
		JMP		F_DispTheSevenSegChar
;----------------------------------------------------------
F_NoDisplay_Minute:
		LDX		#0FH
		LDY		#07                 
		JSR		F_DispTheSevenSegChar    ;	
		LDX		#0FH
		LDY		#06                 
		JMP		F_DispTheSevenSegChar    ;
;==========================================================	
F_4RORA:
		ROR		A
		ROR		A
		ROR		A
		ROR		A
		RTS
;==========================================================
;==========================================================
;==========================================================
;----------------------------------------------------------
;Name:	        ClrSRAM
; Description:	Clear SRAM $80 ~ $FF
;----------------------------------------------------------
F_ClrSRAM:	
		LDA		#.LOW.(C_SramAddrStart+2)
		STA		C_SramAddrStart
		LDA		#.HIGH.(C_SramAddrStart+2)
		STA		C_SramAddrStart+1
		
		LDX     #0
?L_FillLoop#:
        LDA     #0
		STA     (C_SramAddrStart,X)
		
		LDA     C_SramAddrStart+1
		CMP     #.HIGH.C_SramAddrEnd
		BCC     ?L_IncSramAddr#
		LDA     C_SramAddrStart
		CMP     #.LOW.C_SramAddrEnd
		BCS     ?L_End#
		
?L_IncSramAddr#:    ;Increase sram address
        INC     C_SramAddrStart
		BNE     ?L_FillLoop#
		INC     C_SramAddrStart+1
	    STA	    P_WDT_Flag_Clear     ;WatchDogClear  
        JMP     ?L_FillLoop#
?L_End#:
        LDA     #0
        STA     C_SramAddrStart
        STA     C_SramAddrStart+1		
	    RTS
;===============================================================	    
F_DisplayHLValue:
			TAX
			AND	#0FH
			STA	R_TempBuf		;store low 4-bit
			TXA
			JSR		F_4RORA
			AND	#0FH
			RTS
;=========================================== 
			;显示七段码
;===========================================
F_DispTheSevenSegChar:
		LDA	T_SevenSegCharBitMapTab,X
	F_DisplaySevenIcon:					;取得显示点的序列的起始地址
		STA	R_Temp1								;R_Temp1存放字符的位映射
		TYA
		ASL	A		; A<128
		TAX
		LDA	T_SevenSegCharPosIndexTab,X
		STA	R_Temp3
		LDA	T_SevenSegCharPosIndexTab+1,X	;取字符的显示映射表的地址
		STA	R_Temp4
	;------
	;dot start addr:R_Temp3,R_Temp4. disp byte:R_Temp1.
	;F_DispByte:
		LDA	#7
		STA	R_Temp2
	L_DispByte_1:
		LDX	#0
		LDA	(R_Temp3,X)
		STA	R_Temp0
		INC	R_Temp3
		BNE	L_DispByte_1_0
		INC	R_Temp4
	L_DispByte_1_0:
		LDA	(R_Temp3,X)
		INC	R_Temp3
		BNE	L_DispByte_1_1
		INC	R_Temp4
	L_DispByte_1_1:
		LDX	R_Temp0
		ROR	R_Temp1
		BCS	L_DispByte_1_1_1
	L_DispByte_1_1_0:
		STA	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp0
		EOR	R_Temp0
		STA	$3E00,X
		DEC	R_Temp2
		BNE	L_DispByte_1
		RTS
	L_DispByte_1_1_1:
		STA	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp0
		STA	$3E00,X			
		DEC	R_Temp2
		BNE	L_DispByte_1
		RTS
;=============================
;input x
;=============================
F_DisplayBit:
		LDA	T_ICON,x
		STA	R_Temp0
		inx
		LDA	T_ICON,x
		STA	R_Temp1
		LDX	R_Temp0
		LDA	$3E00,X
		ORA	R_Temp1
		STA	$3E00,X			
		RTS
;=============================
;input x
;=============================
F_NoDisplayBit:
		LDA	T_ICON,x
		STA	R_Temp0
		inx
		LDA	T_ICON,x
		EOR	#FFH
		STA	R_Temp1
		LDX	R_Temp0
		LDA	$3E00,X
		and	R_Temp1
		STA	$3E00,X			
		RTS		
