;
;==========================================================
.CODE
;------------------------------
;C_NotDispThisDigital	EQU	0AH
;==========================================================
T_SevenSegCharPosIndexTab:
	DW	T_Digit1DispTab   ;1		;D1
	DW	T_Digit2DispTab   ;2		;D2
	DW	T_Digit3DispTab   ;3		;D3
	DW	T_Digit4DispTab   ;4		;D4
	DW	T_Digit5DispTab   ;5		;D5
	DW	T_Digit6DispTab   ;6		;D6
	DW	T_Digit7DispTab   ;7		;D7
	DW	T_Digit8DispTab   ;8		;D8
;==========================================================
T_SevenSegCharBitMapTab:
;	       0,         1,       2,        3,        4
	DB	00111111B,00000110B,01011011B,01001111B,01100110B
;	       5,         6,       7,        8,        9
	DB	01101101B,01111101B,00000111B,01111111B,01101111B
;	       A,-空     B,-"V"    C,"L"      D'-'       'H'      
	DB	00000000B,00111110B,00111000B,01000000B,01110110b
;		F;'NULL'  		
	DB	00000000B
;---
;format:byte index;mask bT_Digit1DispTabit
; ================================
T_Digit1DispTab:   ;;D1
	DB	C_Com3+Seg02/8,C_Seg02 ;a
	DB	C_Com3+Seg03/8,C_Seg03 ;b
	DB	C_Com1+Seg03/8,C_Seg03 ;c
	DB	C_Com0+Seg02/8,C_Seg02 ;d 
	DB	C_Com1+Seg02/8,C_Seg02 ;e
	DB	C_Com2+Seg02/8,C_Seg02 ;f 
	DB	C_Com2+Seg03/8,C_Seg03 ;g
T_Digit1DispTabEnd:
; ================================
T_Digit2DispTab:   ;;D2
	DB	C_Com3+Seg04/8,C_Seg04 ;a
	DB	C_Com3+Seg05/8,C_Seg05 ;b
	DB	C_Com1+Seg05/8,C_Seg05 ;c
	DB	C_Com0+Seg04/8,C_Seg04 ;d 
	DB	C_Com1+Seg04/8,C_Seg04 ;e
	DB	C_Com2+Seg04/8,C_Seg04 ;f 
	DB	C_Com2+Seg05/8,C_Seg05 ;g
T_Digit2DispTabEnd:
; ================================
T_Digit3DispTab:   ;;D3
	DB	C_Com3+Seg06/8,C_Seg06 ;a
	DB	C_Com3+Seg07/8,C_Seg07 ;b
	DB	C_Com1+Seg07/8,C_Seg07 ;c
	DB	C_Com0+Seg06/8,C_Seg06 ;d 
	DB	C_Com1+Seg06/8,C_Seg06 ;e
	DB	C_Com2+Seg06/8,C_Seg06 ;f 
	DB	C_Com2+Seg07/8,C_Seg07 ;g
T_Digit3DispTabEnd:
; ================================
T_Digit4DispTab:   ;;D4
	DB	C_Com3+Seg08/8,C_Seg08 ;a
	DB	C_Com3+Seg09/8,C_Seg09 ;b
	DB	C_Com1+Seg09/8,C_Seg09 ;c
	DB	C_Com0+Seg08/8,C_Seg08 ;d 
	DB	C_Com1+Seg08/8,C_Seg08 ;e
	DB	C_Com2+Seg08/8,C_Seg08 ;f 
	DB	C_Com2+Seg09/8,C_Seg09 ;g
T_Digit4DispTabEnd:
; ================================	
T_Digit5DispTab:   ;;D5
	DB	C_Com0+Seg26/8,C_Seg26 ;a
	DB	C_Com0+Seg22/8,C_Seg22 ;b
	DB	C_Com2+Seg22/8,C_Seg22 ;c
	DB	C_Com3+Seg26/8,C_Seg26 ;d 
	DB	C_Com2+Seg26/8,C_Seg26 ;e
	DB	C_Com1+Seg26/8,C_Seg26 ;f 
	DB	C_Com1+Seg22/8,C_Seg22 ;g
T_Digit5DispTabEnd:
; ================================	
T_Digit6DispTab:   ;;D6
	DB	C_Com0+Seg21/8,C_Seg21 ;a
	DB	C_Com0+Seg20/8,C_Seg20 ;b
	DB	C_Com2+Seg20/8,C_Seg20 ;c
	DB	C_Com3+Seg21/8,C_Seg21 ;d 
	DB	C_Com2+Seg21/8,C_Seg21 ;e
	DB	C_Com1+Seg21/8,C_Seg21 ;f 
	DB	C_Com1+Seg20/8,C_Seg20 ;g
T_Digit6DispTabEnd:
; ===============================
T_Digit7DispTab:   ;;D7
	DB	C_Com0+Seg19/8,C_Seg19 ;a
	DB	C_Com0+Seg18/8,C_Seg18 ;b
	DB	C_Com2+Seg18/8,C_Seg18 ;c
	DB	C_Com3+Seg19/8,C_Seg19 ;d 
	DB	C_Com2+Seg19/8,C_Seg19 ;e
	DB	C_Com1+Seg19/8,C_Seg19 ;f 
	DB	C_Com1+Seg18/8,C_Seg18 ;g
T_Digit7DispTabEnd:
; ================================	
T_Digit8DispTab:   ;;D8
	DB	C_Com0+Seg17/8,C_Seg17 ;a
	DB	C_Com0+Seg16/8,C_Seg16 ;b
	DB	C_Com2+Seg16/8,C_Seg16 ;c
	DB	C_Com3+Seg17/8,C_Seg17 ;d 
	DB	C_Com2+Seg17/8,C_Seg17 ;e
	DB	C_Com1+Seg17/8,C_Seg17 ;f 
	DB	C_Com1+Seg16/8,C_Seg16 ;g
